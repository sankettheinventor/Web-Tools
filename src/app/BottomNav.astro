---
/* SnapJar app bottom navigation. Rendered only in the app build (Base.astro gates it
   behind IS_APP), so this app-only markup never ships to the website. The center
   "Scan" button is the flagship (file 16): it drives the native ML Kit document
   scanner → PDF → Share/Save, reached via window.Capacitor.registerPlugin so no
   Capacitor import leaks into the web bundle. */
---
<nav class="appbar" aria-label="App navigation">
  <a class="appbar-i" data-nav="home" href="/">
    <span class="abi"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.47 3.84a.75.75 0 0 1 1.06 0l8.69 8.69a.75.75 0 1 0 1.06-1.06l-8.69-8.69a2.25 2.25 0 0 0-3.18 0l-8.69 8.69a.75.75 0 1 0 1.06 1.06l8.69-8.69Z"/><path d="m12 5.43 8.16 8.16c.03.03.06.06.09.09v6.2c0 1.03-.84 1.87-1.88 1.87H15a.75.75 0 0 1-.75-.75v-4.5a.75.75 0 0 0-.75-.75h-3a.75.75 0 0 0-.75.75v4.5a.75.75 0 0 1-.75.75H5.63a1.88 1.88 0 0 1-1.88-1.88v-6.19l.09-.09L12 5.43Z"/></svg></span><span class="abl">Home</span>
  </a>
  <a class="appbar-i" data-nav="pdf" href="/tools/pdf-studio">
    <span class="abi"><svg viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M6 2a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8.5L13.5 2H6Zm7.25 1.75V8c0 .41.34.75.75.75h4.25L13.25 3.75ZM7.75 13a.75.75 0 0 0 0 1.5h8.5a.75.75 0 0 0 0-1.5h-8.5Zm0 3.5a.75.75 0 0 0 0 1.5h5.5a.75.75 0 0 0 0-1.5h-5.5Z" clip-rule="evenodd"/></svg></span><span class="abl">PDF</span>
  </a>
  <div class="appbar-c">
    <button id="navScan" type="button" aria-label="Scan a document">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 8V6a2 2 0 0 1 2-2h2"/><path d="M16 4h2a2 2 0 0 1 2 2v2"/><path d="M20 16v2a2 2 0 0 1-2 2h-2"/><path d="M8 20H6a2 2 0 0 1-2-2v-2"/><path d="M4 12h16"/></svg>
    </button>
    <span class="abl">Scan</span>
  </div>
  <a class="appbar-i" data-nav="recent" href="/recent">
    <span class="abi"><svg viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M12 2.25c-5.39 0-9.75 4.36-9.75 9.75s4.36 9.75 9.75 9.75 9.75-4.36 9.75-9.75S17.39 2.25 12 2.25Zm.75 3.75a.75.75 0 0 0-1.5 0v6c0 .41.34.75.75.75h4.5a.75.75 0 0 0 0-1.5h-3.75V6Z" clip-rule="evenodd"/></svg></span><span class="abl">Recent</span>
  </a>
  <a class="appbar-i" data-nav="image" href="/#image-tools">
    <span class="abi"><svg viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M1.5 6A2.25 2.25 0 0 1 3.75 3.75h16.5A2.25 2.25 0 0 1 22.5 6v12a2.25 2.25 0 0 1-2.25 2.25H3.75A2.25 2.25 0 0 1 1.5 18V6Zm1.5 10.06V18c0 .41.34.75.75.75h16.5a.75.75 0 0 0 .75-.75v-1.94l-2.69-2.69a1.5 1.5 0 0 0-2.12 0l-.88.88.97.97a.75.75 0 1 1-1.06 1.06l-5.16-5.16a1.5 1.5 0 0 0-2.12 0L3 16.06Zm10.13-7.81a1.13 1.13 0 1 1 2.25 0 1.13 1.13 0 0 1-2.25 0Z" clip-rule="evenodd"/></svg></span><span class="abl">Image</span>
  </a>
</nav>

<!-- Premium "Scan anything" sheet (opens from the center Scan button) -->
<div class="scan-sheet" id="scanSheet" hidden>
  <div class="scan-card" role="dialog" aria-modal="true" aria-label="Scan anything">
    <div class="scan-grab"></div>
    <div class="scan-title">Scan anything</div>
    <div class="scan-sub">Crisp, auto-cropped, 100% on your device</div>
    <div class="scan-grid">
      <button class="scan-opt" data-scan="document" type="button"><span class="so-ic" style="--g1:#7c5cff;--g2:#a78bfa"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M7 3h7l4 4v13a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Z"/><path d="M14 3v4h4"/><path d="M9 12h6M9 15.5h4"/></svg></span><span class="so-l">Document</span></button>
      <button class="scan-opt" data-scan="id" type="button"><span class="so-ic" style="--g1:#3b82f6;--g2:#60a5fa"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="6" width="18" height="12.5" rx="2"/><circle cx="8.2" cy="11.3" r="1.9"/><path d="M13 10h5M13 13h5M5.6 15.4c.5-1.2 4.7-1.2 5.2 0"/></svg></span><span class="so-l">ID card</span></button>
      <button class="scan-opt" data-scan="book" type="button"><span class="so-ic" style="--g1:#f59e0b;--g2:#fbbf24"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 6.2C10.4 5 7.9 4.4 5.3 4.4c-.7 0-1.3.6-1.3 1.3v11c0 .7.6 1.2 1.3 1.2 2.6 0 5.1.6 6.7 1.9"/><path d="M12 6.2c1.6-1.2 4.1-1.8 6.7-1.8.7 0 1.3.6 1.3 1.3v11c0 .7-.6 1.2-1.3 1.2-2.6 0-5.1.6-6.7 1.9"/><path d="M12 6.2v13.5"/></svg></span><span class="so-l">Book</span></button>
      <button class="scan-opt" data-scan="signature" type="button"><span class="so-ic" style="--g1:#ff5e7e;--g2:#ff8aa3"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M3.5 19.5c4 .5 6-.5 6-2.2 0-1.2-1.8-1.4-2 0-.2 1.4 1.2 2.4 3 2.4 2.2 0 3.5-1.6 5-4"/><path d="M14.5 7.6l2.4 2.4"/><path d="M12.5 16.5 18.7 10.3a1.7 1.7 0 0 0 0-2.4l-.6-.6a1.7 1.7 0 0 0-2.4 0L9.5 13.5l-.6 3.6 3.6-.6Z"/></svg></span><span class="so-l">Signature</span></button>
      <button class="scan-opt" data-scan="photo" type="button"><span class="so-ic" style="--g1:#10b981;--g2:#34d399"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4.5" width="18" height="15" rx="2.2"/><circle cx="8.5" cy="9.5" r="1.6"/><path d="m20.5 16-4.7-4.7a1.5 1.5 0 0 0-2.1 0L5 19.5"/></svg></span><span class="so-l">Photo</span></button>
      <button class="scan-opt" data-scan="qr" type="button"><span class="so-ic" style="--g1:#6366f1;--g2:#818cf8"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 8.5V6a2 2 0 0 1 2-2h2.5M15.5 4H18a2 2 0 0 1 2 2v2.5M20 15.5V18a2 2 0 0 1-2 2h-2.5M8.5 20H6a2 2 0 0 1-2-2v-2.5"/><path d="M12 8v8M8 12h8" stroke-width="1.6"/></svg></span><span class="so-l">QR scanner</span></button>
      <button class="scan-opt" data-scan="text" type="button"><span class="so-ic" style="--g1:#8b5cf6;--g2:#a78bfa"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 8.5V6a2 2 0 0 1 2-2h2.5M15.5 4H18a2 2 0 0 1 2 2v2.5M20 15.5V18a2 2 0 0 1-2 2h-2.5M8.5 20H6a2 2 0 0 1-2-2v-2.5"/><path d="M8.5 10h7M8.5 13h7M8.5 16h4"/></svg></span><span class="so-l">Scan text</span></button>
    </div>
    <button class="scan-cancel" id="scanCancel" type="button">Cancel</button>
  </div>
</div>

<!-- Leaving message: ask for a rating when the user tries to exit the app -->
<div class="app-modal" id="appRate" hidden>
  <div class="app-modal-card" role="dialog" aria-modal="true" aria-label="Rate SnapJar">
    <div class="amc-ic">⭐</div>
    <h3>Enjoying SnapJar?</h3>
    <p>A quick rating helps SnapJar reach everyone — a <b>virus-free</b>, <b>100% free</b> toolkit with <b>real working tools</b> that keeps your files private.</p>
    <button class="amc-close" id="appRateGo" type="button">Rate the app ⭐</button>
    <button class="amc-later" id="appRateExit" type="button">Exit</button>
  </div>
</div>

<script is:inline>
  (function () {
    /* highlight the active tab from the current path */
    var p = (location.pathname.replace(/\/$/, '').replace(/\.html$/, '') || '/');
    var cat = p === '/' ? 'home'
      : p === '/recent' ? 'recent'
      : p.indexOf('/tools/pdf-studio') === 0 ? 'pdf'
      : /(pdf-tools|compress-pdf|split-pdf|organize-pdf|rotate-pdf|add-page-numbers|watermark-pdf|extract-pages|remove-pages|jpg-to-pdf|pdf-to-jpg|text-to-pdf)/.test(p) ? 'pdf'
      : /(\/compress|\/convert|\/watermark|favicon|heic-to-jpg|color-picker|color-converter|gradient-generator|palette-extractor|qr-code|svg-optimizer|jpg-to-|png-to-|webp-to-)/.test(p) ? 'image'
      : 'home';
    var on = document.querySelector('.appbar-i[data-nav="' + cat + '"]');
    if (on) on.classList.add('on');

    /* Center "Scan" → premium SnapJar scan sheet → route each mode. */
    var scanBtn = document.getElementById('navScan');
    var Cap = window.Capacitor;
    var Plug = function (n) { return window.SnapJarKit ? window.SnapJarKit.plugin(n) : null; };
    var DocumentScanner = Plug('DocumentScanner');
    var sheet = document.getElementById('scanSheet');
    function toast(m, t){ if (window.SnapJarKit && window.SnapJarKit.toast) window.SnapJarKit.toast(m, t || 'info'); }
    function adPause(){ if (window.SnapJarKit && window.SnapJarKit.adPause) window.SnapJarKit.adPause(); }
    function adResume(){ if (window.SnapJarKit && window.SnapJarKit.adResume) window.SnapJarKit.adResume(); }
    function openScan(){ if (sheet) sheet.hidden = false; adPause(); }
    function closeScan(){ if (sheet) sheet.hidden = true; adResume(); }
    if (scanBtn) scanBtn.addEventListener('click', openScan);
    var scanCancel = document.getElementById('scanCancel'); if (scanCancel) scanCancel.addEventListener('click', closeScan);
    if (sheet) sheet.addEventListener('click', function (e){ if (e.target === sheet) closeScan(); });

    var NAMES = { document: 'Scan', id: 'ID card', book: 'Book scan', signature: 'Signature' };
    /* Native ML Kit document scanner = the premium flow: opens the camera, detects
       edges live, auto-crops, supports retake + multi-page, returns a clean PDF.
       Re-resolve the plugin each time in case it registered after this script ran. */
    async function doScan(mode){
      closeScan();
      var DS = DocumentScanner || Plug('DocumentScanner');
      if (!DS) { location.href = '/tools/pdf-studio.html?filterscan=1'; return; } // fallback: in-page camera + filter
      try {
        toast('Opening scanner…', 'work');
        var res = await DS.scanDocument({ resultFormats: 'PDF', pageLimit: mode === 'id' ? 2 : 30 });
        var uri = res && res.pdf && res.pdf.uri;
        if (!uri) { toast('Scan cancelled'); return; }
        var src = Cap && Cap.convertFileSrc ? Cap.convertFileSrc(uri) : uri;
        var blob = await (await fetch(src)).blob();
        if (window.SJRecents) {
          var id = await window.SJRecents.add({ name: (NAMES[mode] || 'Scan') + '.pdf', kind: 'pdf', blob: blob });
          if (id) { location.href = '/tools/pdf-studio.html?recent=' + id; return; }
        }
        location.href = '/tools/pdf-studio.html';
      } catch (e) { toast('Scan cancelled'); }
    }
    if (sheet) sheet.addEventListener('click', function (e){
      var b = e.target && e.target.closest && e.target.closest('.scan-opt'); if (!b) return;
      var mode = b.getAttribute('data-scan');
      if (mode === 'qr') { closeScan(); location.href = '/tools/pdf-studio.html?scanqr=1'; return; }
      if (mode === 'text') { closeScan(); location.href = '/tools/pdf-studio.html?ocr=1'; return; }
      if (mode === 'photo') { closeScan(); location.href = '/tools/pdf-studio.html?filterscan=1'; return; }
      /* Document / ID card / Book / Signature → native camera scanner (auto-crop). */
      doScan(mode);
    });

    /* Leaving message — intercept hardware Back: navigate back in-page if possible,
       otherwise (about to exit) show the rate prompt before quitting. */
    var rate = document.getElementById('appRate');
    function showRate(){ if (rate) rate.hidden = false; adPause(); }
    var App = Plug('App');
    if (App) {
      try {
        App.addListener('backButton', function (info) {
          if (rate && !rate.hidden) { rate.hidden = true; try { App.exitApp(); } catch (e) {} return; }
          if (info && info.canGoBack) { window.history.back(); }
          else { showRate(); }
        });
      } catch (e) {}
      var go = document.getElementById('appRateGo'), ex = document.getElementById('appRateExit');
      if (go) go.addEventListener('click', function () {
        try { window.open('market://details?id=com.snapjar.app', '_system'); }
        catch (e) { try { window.open('https://play.google.com/store/apps/details?id=com.snapjar.app', '_system'); } catch (_) {} }
        if (rate) rate.hidden = true;
      });
      if (ex) ex.addEventListener('click', function () { try { App.exitApp(); } catch (e) { if (rate) rate.hidden = true; } });
      if (rate) rate.addEventListener('click', function (e) { if (e.target === rate) { rate.hidden = true; adResume(); } });
    }
  })();
</script>
