---
import Base from '../layouts/Base.astro';
const title = 'Thor Tools — Free Online Calculators & Image Tools (No Signup, No Upload)';
const description = 'Free, fast, private online calculators and image tools. EMI, mortgage, SIP, income tax, compound interest, watermark and more — all run in your browser. Nothing is uploaded.';

// Every tool is its own indexable page. This ItemList tells Google + AI
// engines the full catalogue and each tool's URL (SEO + GEO).
const tools = [
  { name: 'EMI Calculator', url: '/calculators/emi' },
  { name: 'Mortgage Calculator', url: '/calculators/mortgage' },
  { name: 'SIP Calculator', url: '/calculators/sip' },
  { name: 'Compound Interest Calculator', url: '/calculators/compound-interest' },
  { name: 'Loan Payoff Calculator', url: '/calculators/loan-payoff' },
  { name: 'Income Tax Calculator', url: '/calculators/income-tax' },
  { name: 'Percentage Calculator', url: '/calculators/percentage' },
  { name: 'BMI Calculator', url: '/calculators/bmi' },
  { name: 'Watermark Studio', url: '/tools/watermark' },
];
const itemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Free Online Tools — Thor Tools',
  itemListElement: tools.map((t, i) => ({
    '@type': 'ListItem', position: i + 1, name: t.name,
    url: new URL(t.url, Astro.site).href,
  })),
};
---
<Base title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(itemList)} />
  </Fragment>
  <header class="head">
    <div class="wrap">
      <p class="kicker">Free · Private · Instant</p>
      <h1>Simple tools that just work</h1>
      <p>Calculators and image utilities that run <b>entirely in your browser</b>. No signup, no upload, no waiting — your data never leaves your device.</p>
    </div>
  </header>

  <div class="wrap cats">
    <section class="cat" id="calculators">
      <h2>💰 Finance Calculators</h2>
      <p class="csub">Plan loans, savings and investments. Pure math, instant results, nothing stored.</p>
      <div class="tgrid">
        <a class="tcard" href="/calculators/emi">
          <div class="ti">🏦</div><h3>EMI Calculator</h3><p>Monthly payment for any loan, with full breakdown.</p>
        </a>
        <a class="tcard" href="/calculators/mortgage">
          <div class="ti">🏠</div><h3>Mortgage Calculator</h3><p>Home-loan payment incl. tax &amp; insurance.</p>
        </a>
        <a class="tcard" href="/calculators/sip">
          <div class="ti">📊</div><h3>SIP Calculator</h3><p>Mutual-fund SIP returns over time.</p>
        </a>
        <a class="tcard" href="/calculators/compound-interest">
          <div class="ti">📈</div><h3>Compound Interest</h3><p>See how savings grow over time, any frequency.</p>
        </a>
        <a class="tcard" href="/calculators/loan-payoff">
          <div class="ti">💳</div><h3>Loan Payoff</h3><p>How long to be debt-free + extra-payment impact.</p>
        </a>
        <a class="tcard" href="/calculators/income-tax"><div class="ti">🧾</div><h3>Income Tax</h3><p>India new vs old regime, FY 2025-26.</p></a>
      </div>
    </section>

    <section class="cat" id="everyday">
      <h2>📐 Everyday Calculators</h2>
      <p class="csub">Quick answers for daily math.</p>
      <div class="tgrid">
        <a class="tcard" href="/calculators/percentage"><div class="ti">％</div><h3>Percentage</h3><p>X% of Y, % of total, % change.</p></a>
        <a class="tcard" href="/calculators/bmi"><div class="ti">⚖️</div><h3>BMI Calculator</h3><p>Body Mass Index, metric or imperial.</p></a>
        <span class="tcard soon"><div class="ti">🎂</div><h3>Age Calculator</h3><p>Exact age from a date.</p><span class="badge">Soon</span></span>
        <span class="tcard soon"><div class="ti">🏷️</div><h3>Discount &amp; GST</h3><p>Sale price, tax, tips.</p><span class="badge">Soon</span></span>
      </div>
    </section>

    <section class="cat" id="image-tools">
      <h2>🖼️ Image Tools</h2>
      <p class="csub">Compress, convert and watermark images — processed locally, never uploaded.</p>
      <div class="tgrid">
        <a class="tcard" href="/tools/watermark"><div class="ti">💧</div><h3>Watermark Studio</h3><p>Text/logo watermark, batch, tiling.</p></a>
        <span class="tcard soon"><div class="ti">🗜️</div><h3>Image Compressor</h3><p>Shrink to a target size (e.g. 100 KB).</p><span class="badge">Soon</span></span>
        <span class="tcard soon"><div class="ti">📱</div><h3>HEIC → JPG</h3><p>Convert iPhone photos to JPG.</p><span class="badge">Soon</span></span>
        <span class="tcard soon"><div class="ti">🔄</div><h3>Convert / Resize</h3><p>JPG ↔ PNG ↔ WebP, resize, crop.</p><span class="badge">Soon</span></span>
      </div>
    </section>

    <section class="cat" id="utilities">
      <h2>⚡ Quick Utilities</h2>
      <p class="csub">Little tools worth bookmarking.</p>
      <div class="tgrid">
        <span class="tcard soon"><div class="ti">🔳</div><h3>QR Code Generator</h3><p>URL, WiFi, vCard — with logo &amp; color.</p><span class="badge">Soon</span></span>
        <span class="tcard soon"><div class="ti">⭐</div><h3>Favicon Generator</h3><p>All icon sizes from one image.</p><span class="badge">Soon</span></span>
        <span class="tcard soon"><div class="ti">📄</div><h3>PDF Tools</h3><p>Merge, split, rotate PDFs.</p><span class="badge">Soon</span></span>
        <span class="tcard soon"><div class="ti">✂️</div><h3>SVG Optimizer</h3><p>Minify &amp; clean up SVG files.</p><span class="badge">Soon</span></span>
      </div>
    </section>
  </div>
</Base>
