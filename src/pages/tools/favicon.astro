---
import Base from '../../layouts/Base.astro';
const title = 'Favicon Generator — Make a Favicon From Any Image (Free)';
const description = 'Free favicon generator. Turn any image into favicon PNGs in all the sizes you need (16, 32, 48, 180, 512) right in your browser, with the HTML to paste. Nothing uploaded.';
---
<Base title={title} description={description}>
  <header class="head"><div class="wrap">
    <p class="kicker">Image Tool</p><h1>Favicon Generator</h1>
    <p>Turn any image into favicons in every size you need — generated in your browser.</p>
  </div></header>
  <div class="wrap"><div class="tool wm">
    <div id="drop" class="drop"><input id="file" type="file" accept="image/*" hidden />
      <div class="drop-ic">⭐</div><p class="drop-t">Drop a square image, or <button id="browse" type="button" class="linklike">browse</button></p>
      <p class="drop-s">PNG · JPG · 🔒 nothing leaves your device</p></div>
    <div id="editor" hidden>
      <div class="fav-grid" id="grid"></div>
      <div class="wm-actions"><button id="dlall" type="button" class="wm-btn">⬇ Download all sizes</button>
        <button id="reset" type="button" class="wm-btn ghost">Start over</button></div>
      <div class="snippet"><div class="snip-h">Paste into your site's &lt;head&gt;:</div>
        <pre id="code">&lt;link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png"&gt;
&lt;link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png"&gt;
&lt;link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png"&gt;</pre></div>
    </div>
  </div></div>
  <div class="ad">Ad space</div>
  <div class="content">
    <h2>How to add a favicon</h2>
    <p>Drop in a square image (a logo or icon works best). The generator renders it at every common favicon size — 16, 32, 48, 180 and 512 pixels — which you can download individually or all at once. Then paste the snippet above into your site's <code>&lt;head&gt;</code> and put the files in your site root.</p>
    <p>Everything runs locally; your image is never uploaded.</p>
    <div class="xlinks"><a href="/tools/convert">Convert &amp; Resize →</a><a href="/#image-tools">All image tools →</a></div>
  </div>
  <style>
    .drop{border:2px dashed var(--line);border-radius:16px;background:var(--surface2);padding:48px 24px;text-align:center;cursor:pointer}
    .drop.drag{border-color:var(--brand)}.drop-ic{font-size:44px;margin-bottom:10px}.drop-t{font-size:17px;font-weight:600}.drop-s{font-size:13px;color:var(--dim);margin-top:8px}
    .linklike{background:none;border:0;color:var(--brand);font:inherit;font-weight:700;cursor:pointer;text-decoration:underline}
    .wm{padding:20px}.fav-grid{display:flex;flex-wrap:wrap;gap:18px;align-items:flex-end;justify-content:center;margin-bottom:18px}
    .fav{text-align:center}.fav canvas{border:1px solid var(--line);border-radius:8px;background:var(--surface2);display:block}
    .fav .fl{font-size:12px;color:var(--dim);margin-top:6px}.fav button{margin-top:6px;font-size:11px;font-weight:700;color:var(--brand);background:none;border:0;cursor:pointer}
    .wm-actions{display:flex;gap:10px;justify-content:center}.wm-btn{padding:12px 18px;border-radius:10px;font-weight:700;color:#fff;border:0;cursor:pointer;background:linear-gradient(135deg,var(--brand2),var(--brand))}
    .wm-btn.ghost{background:var(--surface2);color:var(--dim);border:1px solid var(--line)}
    .snippet{margin-top:18px}.snip-h{font-size:13px;color:var(--dim);font-weight:600;margin-bottom:6px}
    pre{background:var(--surface2);border:1px solid var(--line);border-radius:10px;padding:13px;font-size:12.5px;overflow-x:auto;color:var(--txt)}
  </style>
  <script is:inline>
    (function(){
      var SIZES=[16,32,48,180,512], img=null;
      function $(i){return document.getElementById(i);}
      function draw(c,s){c.width=s;c.height=s;var x=c.getContext('2d');x.clearRect(0,0,s,s);x.drawImage(img,0,0,s,s);}
      function dl(c,s){c.toBlob(function(b){var a=document.createElement('a');a.href=URL.createObjectURL(b);a.download='favicon-'+s+'.png';a.click();setTimeout(function(){URL.revokeObjectURL(a.href);},1500);},'image/png');}
      function build(){
        var g=$('grid');g.innerHTML='';
        SIZES.forEach(function(s){
          var wrap=document.createElement('div');wrap.className='fav';
          var c=document.createElement('canvas');var disp=Math.min(s,72);c.style.width=disp+'px';c.style.height=disp+'px';
          draw(c,s);
          var lbl=document.createElement('div');lbl.className='fl';lbl.textContent=s+'×'+s;
          var btn=document.createElement('button');btn.textContent='Download';btn.onclick=function(){dl(c,s);};
          wrap.appendChild(c);wrap.appendChild(lbl);wrap.appendChild(btn);g.appendChild(wrap);
        });
      }
      function load(f){var im=new Image();im.onload=function(){img=im;$('drop').hidden=true;$('editor').hidden=false;build();};im.src=URL.createObjectURL(f);}
      $('browse').onclick=function(){$('file').click();};
      $('drop').onclick=function(e){if(e.target.id==='drop'||e.target.className.indexOf('drop-')===0)$('file').click();};
      $('file').onchange=function(e){if(e.target.files[0])load(e.target.files[0]);};
      ['dragover','dragenter'].forEach(function(ev){$('drop').addEventListener(ev,function(e){e.preventDefault();$('drop').classList.add('drag');});});
      ['dragleave','drop'].forEach(function(ev){$('drop').addEventListener(ev,function(e){e.preventDefault();$('drop').classList.remove('drag');});});
      $('drop').addEventListener('drop',function(e){if(e.dataTransfer.files[0])load(e.dataTransfer.files[0]);});
      $('dlall').onclick=function(){SIZES.forEach(function(s,i){setTimeout(function(){var c=document.createElement('canvas');draw(c,s);dl(c,s);},i*350);});};
      $('reset').onclick=function(){img=null;$('file').value='';$('editor').hidden=true;$('drop').hidden=false;};
    })();
  </script>
</Base>
