---
import Base from '../../layouts/Base.astro';
import Faq from '../../components/Faq.astro';
import HowTo from '../../components/HowTo.astro';
import AppLd from '../../components/AppLd.astro';

// One template → a dedicated, individually-rankable page per conversion.
const CONVERSIONS = [
  { slug: 'jpg-to-png',  from: 'JPG',  to: 'PNG',  mime: 'image/png',  lossy: false },
  { slug: 'png-to-jpg',  from: 'PNG',  to: 'JPG',  mime: 'image/jpeg', lossy: true  },
  { slug: 'webp-to-png', from: 'WebP', to: 'PNG',  mime: 'image/png',  lossy: false },
  { slug: 'png-to-webp', from: 'PNG',  to: 'WebP', mime: 'image/webp', lossy: true  },
  { slug: 'jpg-to-webp', from: 'JPG',  to: 'WebP', mime: 'image/webp', lossy: true  },
  { slug: 'webp-to-jpg', from: 'WebP', to: 'JPG',  mime: 'image/jpeg', lossy: true  },
];

export function getStaticPaths() {
  const list = [
    { slug: 'jpg-to-png',  from: 'JPG',  to: 'PNG',  mime: 'image/png',  lossy: false },
    { slug: 'png-to-jpg',  from: 'PNG',  to: 'JPG',  mime: 'image/jpeg', lossy: true  },
    { slug: 'webp-to-png', from: 'WebP', to: 'PNG',  mime: 'image/png',  lossy: false },
    { slug: 'png-to-webp', from: 'PNG',  to: 'WebP', mime: 'image/webp', lossy: true  },
    { slug: 'jpg-to-webp', from: 'JPG',  to: 'WebP', mime: 'image/webp', lossy: true  },
    { slug: 'webp-to-jpg', from: 'WebP', to: 'JPG',  mime: 'image/jpeg', lossy: true  },
  ];
  return list.map((c) => ({ params: { convert: c.slug }, props: c }));
}

const c = Astro.props;
const title = `${c.from} to ${c.to} Converter — Free & Private (In Your Browser)`;
const description = `Free ${c.from} to ${c.to} converter. Convert ${c.from} images to ${c.to} instantly in your browser — batch, high quality, no signup, and nothing is uploaded.`;
const ext = c.to.toLowerCase() === 'jpg' ? 'jpg' : c.to.toLowerCase();

const faqItems = [
  {
    q: `Is my image uploaded or stored anywhere?`,
    a: `No. The entire ${c.from} to ${c.to} conversion happens locally in your browser using the canvas API — your files are never uploaded, stored, or shared, and they never leave your device.`,
  },
  {
    q: `Will converting reduce the image quality?`,
    a: `Converting to ${c.to} ${c.lossy ? `re-encodes the image with lossy compression, so use the Quality slider to balance file size against sharpness — 90% and above usually looks identical to the original.` : `is lossless, so every pixel is preserved exactly and there is no visible quality loss.`}`,
  },
  {
    q: `Does it keep transparency (the alpha channel)?`,
    a: `${c.mime === 'image/jpeg' ? `No. JPG does not support transparency, so any transparent areas are filled with a solid white background during conversion.` : `Yes. ${c.to} supports an alpha channel, so transparent regions in your image are preserved in the converted file.`}`,
  },
  {
    q: `Can I convert multiple images at once?`,
    a: `Yes. Drop or select several ${c.from} files together and the tool converts them in a batch; you can then download each ${c.to} file individually or click Download all (.zip) to save the whole set as a single ZIP archive.`,
  },
  {
    q: `Do I need to install software or create an account?`,
    a: `No. The converter runs entirely in your web browser with no signup, no plugins, and no installs — just open the page, add your ${c.from} images, and download the ${c.to} results.`,
  },
];

const howSteps = [
  { name: `Add your ${c.from} images`, text: `Drop your ${c.from} files onto the upload area or click browse to select one or more images from your device.` },
  ...(c.lossy ? [{ name: 'Adjust quality', text: 'Use the Quality slider to balance file size against sharpness, watching the new size update live.' }] : []),
  { name: 'Preview the result', text: `Check the converted ${c.to} preview and use the thumbnails to switch between images in the batch.` },
  { name: `Download your ${c.to} files`, text: `Click Download ${c.to} to save the selected image, or Download all (.zip) to save the whole batch as a single ZIP archive.` },
];
---
<Base title={title} description={description}>
  <header class="head"><div class="wrap">
    <p class="kicker">Image Converter</p><h1>{c.from} to {c.to} Converter</h1>
    <p>Drop your {c.from} images and watch them convert to {c.to} live — right here in your browser.</p>
  </div></header>
  <div class="wrap"><div class="tool wm">
    <div id="cfg" data-mime={c.mime} data-ext={ext} data-lossy={c.lossy ? '1' : '0'} hidden></div>
    <div id="drop" class="drop"><input id="file" type="file" accept="image/*" multiple hidden />
      <div class="drop-ic">🔄</div><p class="drop-t">Drop {c.from} images, or <button id="browse" type="button" class="linklike">browse</button></p>
      <p class="drop-s">Batch supported · 🔒 nothing leaves your device</p></div>
    <div id="editor" hidden>
      <div class="wm-grid">
        <div class="wm-preview"><canvas id="canvas" aria-label="Preview"></canvas><div class="thumbs" id="thumbs"></div></div>
        <div class="wm-controls">
          {c.lossy && (
            <label class="ctl">Quality <span class="cv" id="qV">92%</span><input id="q" type="range" min="40" max="100" step="2" value="92" /></label>
          )}
          <div class="sizes"><span>New: <b id="nSize" class="hl">—</b></span></div>
          <div class="wm-actions">
            <button id="dl" type="button" class="wm-btn">⬇ Download {c.to}</button>
            <button id="dlall" type="button" class="wm-btn ghost" hidden>⬇ Download all (.zip)</button>
            <button id="reset" type="button" class="wm-btn ghost">Start over</button>
          </div>
          <p id="status" class="status" role="status" aria-live="polite"></p>
        </div>
      </div>
    </div>
  </div></div>
  <div class="ad">Advertisement</div>
  <div class="content">
    <h2>How to convert {c.from} to {c.to}</h2>
    <p>Drop one or more {c.from} images above and they're converted to {c.to} right away — then download a single file or the whole batch. {c.to === 'PNG' ? 'PNG is lossless and supports transparency, ideal for logos, icons and graphics.' : c.to === 'WebP' ? 'WebP gives noticeably smaller files than JPG or PNG at the same quality, great for the web.' : 'JPG is the most universal format and keeps file sizes small for photos.'}</p>
    <p><b>Everything runs in your browser</b> — your {c.from} files are never uploaded, so the conversion is instant and completely private.</p>
    <div class="xlinks">
      <a href="/tools/jpg-to-png">JPG→PNG</a><a href="/tools/png-to-jpg">PNG→JPG</a>
      <a href="/tools/webp-to-png">WebP→PNG</a><a href="/tools/png-to-webp">PNG→WebP</a>
      <a href="/tools/compress">Compressor →</a>
    </div>
  </div>
  <style>
    .drop{border:2px dashed var(--line);border-radius:16px;background:var(--surface2);padding:48px 24px;text-align:center;cursor:pointer}
    .drop.drag{border-color:var(--brand)}.drop-ic{font-size:44px;margin-bottom:10px}.drop-t{font-size:17px;font-weight:600}.drop-s{font-size:13px;color:var(--dim);margin-top:8px}
    .linklike{background:none;border:0;color:var(--brand);font:inherit;font-weight:700;cursor:pointer;text-decoration:underline}
    .wm{padding:20px}.wm-grid{display:grid;grid-template-columns:1fr 290px;gap:22px}.wm-preview{min-width:0}
    #canvas{width:100%;height:auto;max-height:54vh;object-fit:contain;border:1px solid var(--line);border-radius:12px;background:var(--surface2)}
    .thumbs{display:flex;gap:8px;flex-wrap:wrap;margin-top:12px}.thumb{width:50px;height:50px;border-radius:8px;object-fit:cover;border:2px solid var(--line);cursor:pointer}.thumb.sel{border-color:var(--brand)}
    .wm-controls{display:flex;flex-direction:column;gap:14px}.ctl{display:flex;flex-direction:column;gap:6px;font-size:13px;font-weight:600;color:var(--dim)}.cv{float:right;color:var(--brand);font-weight:700}
    .sizes{font-size:13.5px;color:var(--dim);background:var(--surface2);border:1px solid var(--line);border-radius:10px;padding:12px}.sizes .hl{color:var(--brand);font-weight:700}
    .wm-actions{display:flex;gap:10px;flex-wrap:wrap}.wm-btn{flex:1;padding:12px;border-radius:10px;font-weight:700;color:#fff;border:0;cursor:pointer;background:linear-gradient(135deg,var(--brand2),var(--brand))}
    .wm-btn.ghost{background:var(--surface2);color:var(--dim);border:1px solid var(--line);flex:0 0 auto}
    .status{font-size:13px;color:var(--dim);margin:2px 0 0}.status.err{color:#e5484d;font-weight:600}
    @media(max-width:680px){.wm-grid{grid-template-columns:1fr}}
  </style>
  <HowTo task="convert an image to another format" steps={howSteps} />
  <AppLd name={`${c.from} to ${c.to} Converter`} description={`Drop or browse ${c.from} images and convert them to ${c.to} live in your browser${c.lossy ? ', dragging the Quality slider to watch the output size update' : ''} — batch-convert and download each file or the whole set, nothing uploaded.`} category="MultimediaApplication" features={["Drag-and-drop batch image conversion", ...(c.lossy ? ["Live Quality slider with instant size preview"] : ["Lossless conversion preserving every pixel"]), "Thumbnail strip to switch between batched images", "Download individual files or the whole batch as a .zip", "100% in-browser — nothing is uploaded"]} />
  <Faq items={faqItems} />
  <script>
    import JSZip from 'jszip';
    (function(){
      var cfg=document.getElementById('cfg'), MIME=cfg.dataset.mime, EXT=cfg.dataset.ext, LOSSY=cfg.dataset.lossy==='1';
      var images=[], sel=0, clampNoticeShown=false, webpSupported=null;
      function $(i){return document.getElementById(i);}
      function fmtKB(b){return b>1048576?(b/1048576).toFixed(2)+' MB':Math.round(b/1024)+' KB';}
      function quality(){var q=$('q');return q?parseInt(q.value,10)/100:0.92;}
      function webpOk(){ if(webpSupported===null){ try{ var t=document.createElement('canvas'); t.width=t.height=1; webpSupported=t.toDataURL('image/webp').indexOf('data:image/webp')===0; }catch(e){ webpSupported=false; } } return webpSupported; }
      function render(c, item){
        var fit=window.SnapJarKit.fitDims(item.img.naturalWidth,item.img.naturalHeight);
        if(fit.clamped && !clampNoticeShown){ clampNoticeShown=true; status('Large image downscaled to fit your device.',false); }
        var w=fit.w,h=fit.h;c.width=w;c.height=h;var x=c.getContext('2d');
        if(MIME==='image/jpeg'){x.fillStyle='#fff';x.fillRect(0,0,w,h);} x.drawImage(item.img,0,0,w,h);
      }
      function preview(){ if(!images[sel])return;
        if(MIME==='image/webp' && !webpOk()){ status('WebP encoding is not supported on this device — your browser is too old to create '+EXT.toUpperCase()+' files.',true); return; }
        render($('canvas'),images[sel]);
        $('canvas').toBlob(function(b){if(b){$('nSize').textContent=fmtKB(b.size);}else{$('nSize').textContent='—';status('Could not create the image (your device may not support this format).',true);}},MIME,quality()); }
      function thumbs(){var t=$('thumbs');t.innerHTML='';images.forEach(function(it,i){var im=document.createElement('img');im.src=it.url;im.className='thumb'+(i===sel?' sel':'');im.onclick=function(){sel=i;preview();thumbs();};t.appendChild(im);});$('dlall').hidden=images.length<2;}
      function add(files){Array.prototype.slice.call(files).filter(function(f){return f.type.indexOf('image/')===0;}).forEach(function(f){var url=window.SnapJarKit.track(f);var im=new Image();im.onload=function(){images.push({img:im,name:f.name.replace(/\.[^.]+$/,''),url:url});$('drop').hidden=true;$('editor').hidden=false;sel=images.length-1;preview();thumbs();};im.onerror=function(){status('Could not open "'+f.name+'" — it may be corrupt or unsupported.',true);};im.src=url;});}
      function status(msg,isErr){var s=$('status');if(!s)return;s.textContent=msg||'';s.className='status'+(isErr?' err':'');}
      function blobFor(item){return new Promise(function(res){var c=document.createElement('canvas');render(c,item);c.toBlob(function(b){res(b);},MIME,quality());});}
      function download(item){blobFor(item).then(function(b){if(!b){status('Could not create the image (your device may not support this format).',true);return;}var a=document.createElement('a');a.href=URL.createObjectURL(b);a.download=item.name+'.'+EXT;a.click();setTimeout(function(){URL.revokeObjectURL(a.href);},1500);});}
      function uniqueName(used,base){var n=base+'.'+EXT,i=2;while(used[n]){n=base+'-'+i+'.'+EXT;i++;}used[n]=true;return n;}
      function downloadAll(){
        if(!images.length)return;
        if(typeof JSZip==='undefined'){status('Could not load the .zip library — please check your connection and reload, or use Download '+EXT.toUpperCase()+' to save each image individually.',true);return;}
        status('Building .zip…',false);
        var zip=new JSZip(),used={};
        return Promise.all(images.map(function(it){return blobFor(it).then(function(b){if(b)zip.file(uniqueName(used,it.name),b);});})).then(function(){
          return zip.generateAsync({type:'blob'});
        }).then(function(blob){
          var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='converted-'+EXT+'.zip';a.click();setTimeout(function(){URL.revokeObjectURL(a.href);},1500);
          status('Done — '+images.length+' '+EXT.toUpperCase()+' file(s) saved in your .zip.',false);
        }).catch(function(){status('Something went wrong building the .zip. Try Download '+EXT.toUpperCase()+' to save images individually.',true);});
      }
      $('browse').onclick=function(){$('file').click();};
      $('drop').onclick=function(e){if(e.target.id==='drop'||e.target.className.indexOf('drop-')===0)$('file').click();};
      $('file').onchange=function(e){add(e.target.files);};
      ['dragover','dragenter'].forEach(function(ev){$('drop').addEventListener(ev,function(e){e.preventDefault();$('drop').classList.add('drag');});});
      ['dragleave','drop'].forEach(function(ev){$('drop').addEventListener(ev,function(e){e.preventDefault();$('drop').classList.remove('drag');});});
      $('drop').addEventListener('drop',function(e){add(e.dataTransfer.files);});
      if($('q'))$('q').addEventListener('input',function(){$('qV').textContent=$('q').value+'%';preview();});
      $('dl').onclick=window.SnapJarKit.guard('dl', function(){if(images[sel])return download(images[sel]);});
      $('dlall').onclick=window.SnapJarKit.guard('dlall', function(){return downloadAll();});
      $('reset').onclick=function(){images=[];sel=0;window.SnapJarKit.clear();$('thumbs').innerHTML='';$('file').value='';status('',false);clampNoticeShown=false;$('editor').hidden=true;$('drop').hidden=false;};
    })();
  </script>
</Base>
