---
import Base from '../../layouts/Base.astro';
import Faq from '../../components/Faq.astro';
import HowTo from '../../components/HowTo.astro';
import AppLd from '../../components/AppLd.astro';
const title = 'HEIC to JPG Converter — Free, Private, In Your Browser';
const description = 'Free HEIC to JPG converter. Turn iPhone HEIC/HEIF photos into JPG right in your browser — batch supported, adjustable quality, and nothing is ever uploaded.';
const faqItems = [
  { q: 'What is a HEIC file and why convert it to JPG?', a: 'HEIC (High Efficiency Image Container) is the format modern iPhones use to save photos at smaller file sizes. It often won’t open on Windows, older Android devices or many websites, so converting to JPG makes your photos work almost everywhere.' },
  { q: 'Can I convert several HEIC photos at once?', a: 'Yes. You can drop or select multiple HEIC/HEIF files at the same time and they are converted one after another, with a "converting 3 of 8" style progress message. When you have more than one result, a Download all (.zip) button packages every JPG into a single zip.' },
  { q: 'Can I control the JPG quality?', a: 'Yes. There is a quality slider that ranges from 40% to 100%, defaulting to 85%. Higher quality keeps more detail but produces larger files, while lower quality makes smaller files.' },
  { q: 'Are my photos uploaded or stored anywhere?', a: 'No. Every conversion happens entirely in your browser on your own device. Your HEIC photos are never uploaded, stored or shared, so even private images stay private.' },
  { q: 'Why did one of my files fail to convert?', a: 'The converter only handles HEIC and HEIF images. If a file is in another format or is corrupted, that file is skipped and you’ll see a short message, while your other photos still convert normally.' },
];
const howSteps = [
  { name: 'Add your HEIC photos', text: 'Drop your HEIC or HEIF files onto the upload area, or click browse to select one or more from your device.' },
  { name: 'Set the quality', text: 'Adjust the quality slider (40% to 100%, default 85%) to balance image detail against file size.' },
  { name: 'Let it convert', text: 'Each photo is converted to JPG right in your browser and shown as a preview thumbnail, with nothing uploaded anywhere.' },
  { name: 'Download your JPGs', text: 'Click Download under a single result, or use Download all (.zip) to save every converted JPG together in one zip archive.' },
];
---
<Base title={title} description={description}>
  <header class="head"><div class="wrap">
    <p class="kicker">Image Tool</p><h1>HEIC to JPG Converter</h1>
    <p>Drop your iPhone HEIC photos here to batch-convert them to JPG live in your browser.</p>
  </div></header>
  <div class="wrap"><div class="tool wm">
    <div id="drop" class="drop"><input id="file" type="file" accept=".heic,.heif,image/heic,image/heif" multiple hidden />
      <div class="drop-ic">📱</div><p class="drop-t">Drop HEIC photos, or <button id="browse" type="button" class="linklike">browse</button></p>
      <p class="drop-s">Batch supported · 🔒 nothing leaves your device</p></div>
    <div id="editor" hidden>
      <label class="ctl wq">Quality <span class="cv" id="qV">85%</span><input id="q" type="range" min="40" max="100" step="5" value="85" /></label>
      <div class="grid" id="grid"></div>
      <div class="wm-actions"><button id="dlall" type="button" class="wm-btn" hidden>⬇ Download all (.zip)</button>
        <button id="reset" type="button" class="wm-btn ghost">Start over</button></div>
      <p id="status" class="status"></p>
    </div>
  </div></div>
  <div class="ad">Ad space</div>
  <div class="content">
    <h2>Why HEIC photos won't open</h2>
    <p>Modern iPhones save photos as <b>HEIC</b> (High Efficiency Image Container) to save space. It's great on Apple devices but often won't open on Windows, older Androids or many websites. Converting to <b>JPG</b> makes the photo work everywhere.</p>
    <p>Drop your HEIC files above, pick a quality, and download the JPGs. It all happens locally — your photos are never uploaded, so even private images stay private.</p>
    <div class="xlinks"><a href="/tools/compress">Image Compressor →</a><a href="/#image-tools">All image tools →</a></div>
  </div>
  <style>
    .drop{border:2px dashed var(--line);border-radius:16px;background:var(--surface2);padding:48px 24px;text-align:center;cursor:pointer}
    .drop.drag{border-color:var(--brand)}.drop-ic{font-size:44px;margin-bottom:10px}.drop-t{font-size:17px;font-weight:600}.drop-s{font-size:13px;color:var(--dim);margin-top:8px}
    .linklike{background:none;border:0;color:var(--brand);font:inherit;font-weight:700;cursor:pointer;text-decoration:underline}
    .wm{padding:20px}.wq{margin-bottom:16px}.ctl{display:flex;flex-direction:column;gap:6px;font-size:13px;font-weight:600;color:var(--dim)}.cv{float:right;color:var(--brand);font-weight:700}
    .grid{display:flex;flex-wrap:wrap;gap:14px;margin-bottom:16px}
    .cv-item{width:140px;text-align:center}.cv-item img{width:140px;height:110px;object-fit:cover;border:1px solid var(--line);border-radius:10px;background:var(--surface2)}
    .cv-item .nm{font-size:11.5px;color:var(--dim);margin-top:6px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.cv-item button{margin-top:5px;font-size:11px;font-weight:700;color:var(--brand);background:none;border:0;cursor:pointer}
    .wm-actions{display:flex;gap:10px}.wm-btn{padding:12px 18px;border-radius:10px;font-weight:700;color:#fff;border:0;cursor:pointer;background:linear-gradient(135deg,var(--brand2),var(--brand))}
    .wm-btn.ghost{background:var(--surface2);color:var(--dim);border:1px solid var(--line)}.status{margin-top:10px;font-size:13px;color:var(--dim)}
  </style>
  <HowTo task="convert HEIC to JPG" steps={howSteps} />
  <AppLd name="HEIC to JPG Converter" description="Drop or browse to one or many iPhone HEIC/HEIF photos, drag the quality slider, and batch-convert them to JPG live in your browser with instant previews." category="MultimediaApplication" features={["Batch convert multiple HEIC/HEIF files at once", "Drag-and-drop or browse upload", "Adjustable JPG quality slider (40-100%)", "Instant preview thumbnails", "Download all converted JPGs as a single zip"]} />
  <Faq items={faqItems} />
  <script>
    import heic2any from 'heic2any';
    import JSZip from 'jszip';
    (function(){
      var results=[];
      function $(i){return document.getElementById(i);}
      function dl(blob,name){var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=name;a.click();setTimeout(function(){URL.revokeObjectURL(a.href);},1500);}
      function add(blob,name){
        var item={blob:blob,name:name.replace(/\.(heic|heif)$/i,'')+'.jpg'};results.push(item);
        var w=document.createElement('div');w.className='cv-item';
        var im=document.createElement('img');im.src=URL.createObjectURL(blob);
        var nm=document.createElement('div');nm.className='nm';nm.textContent=item.name;
        var b=document.createElement('button');b.textContent='Download';b.onclick=function(){dl(item.blob,item.name);};
        w.appendChild(im);w.appendChild(nm);w.appendChild(b);$('grid').appendChild(w);
        $('dlall').hidden=results.length<2;
      }
      async function convert(files){
        if(typeof heic2any==='undefined'){$('status').textContent='HEIC engine still loading — please wait a second and try again.';return;}
        $('drop').hidden=true;$('editor').hidden=false;
        var q=parseInt($('q').value,10)/100, arr=Array.prototype.slice.call(files), failed=0;
        for(var i=0;i<arr.length;i++){
          $('status').textContent='Converting '+(i+1)+' of '+arr.length+'…';
          try{ var out=await heic2any({blob:arr[i],toType:'image/jpeg',quality:q}); add(Array.isArray(out)?out[0]:out, arr[i].name); }
          catch(e){ failed++; }
        }
        var msg='Done — '+results.length+' converted.';
        if(failed) msg+=' '+failed+' file(s) skipped (not a HEIC?).';
        $('status').textContent=msg;
      }
      $('browse').onclick=function(){$('file').click();};
      $('drop').onclick=function(e){if(e.target.id==='drop'||e.target.className.indexOf('drop-')===0)$('file').click();};
      $('file').onchange=function(e){if(e.target.files.length)convert(e.target.files);};
      ['dragover','dragenter'].forEach(function(ev){$('drop').addEventListener(ev,function(e){e.preventDefault();$('drop').classList.add('drag');});});
      ['dragleave','drop'].forEach(function(ev){$('drop').addEventListener(ev,function(e){e.preventDefault();$('drop').classList.remove('drag');});});
      $('drop').addEventListener('drop',function(e){if(e.dataTransfer.files.length)convert(e.dataTransfer.files);});
      $('q').addEventListener('input',function(){$('qV').textContent=$('q').value+'%';});
      $('dlall').onclick=async function(){
        if(typeof JSZip==='undefined'){$('status').textContent='Zip engine still loading — please try again in a second.';return;}
        $('status').textContent='Building zip…';
        var z=new JSZip(), seen={};
        results.forEach(function(it){var n=it.name;if(seen[n]){var c=++seen[n];n=n.replace(/\.jpg$/i,'')+'-'+c+'.jpg';}else{seen[n]=1;}z.file(n,it.blob);});
        var b=await z.generateAsync({type:'blob'});dl(b,'heic-to-jpg.zip');
        $('status').textContent='Done — '+results.length+' converted.';
      };
      $('reset').onclick=function(){results=[];$('grid').innerHTML='';$('file').value='';$('status').textContent='';$('editor').hidden=true;$('drop').hidden=false;};
    })();
  </script>
</Base>
