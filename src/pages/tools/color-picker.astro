---
import Base from '../../layouts/Base.astro';
import Faq from '../../components/Faq.astro';
import HowTo from '../../components/HowTo.astro';
import AppLd from '../../components/AppLd.astro';
const title = 'Color Picker from Image — Eyedropper Tool (Free)';
const description = 'Free color picker: upload an image and click to grab any color as HEX, RGB and HSL with one-click copy. Runs in your browser — nothing is uploaded.';
const faqItems = [
  { q: 'How do I pick a color from an image?', a: 'Drop in or browse for an image, then click anywhere on it. The tool reads the exact pixel under your cursor and shows it as HEX, RGB and HSL. You can also drag with the mouse button held down to sample colors as you move.' },
  { q: 'What color formats does it give me?', a: 'Every pick is shown as a HEX code, an RGB value and an HSL value at the same time. Each one has its own Copy button so you can grab the format you need.' },
  { q: 'Can I pick a color from anywhere on my screen?', a: 'Yes, on supported browsers. If your browser includes the EyeDropper API, a "pick from screen" option appears that lets you sample any color on your display, not just the loaded image.' },
  { q: 'Is my image uploaded or stored anywhere?', a: 'No. Your image is processed entirely in your browser using a local canvas — it is never uploaded, stored or shared. Nothing leaves your device.' },
  { q: 'What image formats can I use?', a: 'Any image format your browser can display works, including JPG, PNG, WebP and GIF. The picker reads pixels from the image after it loads.' },
];
const howSteps = [
  { name: 'Load your image', text: 'Drop an image onto the box or click browse to select a file from your device.' },
  { name: 'Click to pick', text: 'Click anywhere on the image, or drag with the mouse held down, to sample the exact pixel under your cursor.' },
  { name: 'Read the values', text: 'See the picked colour shown at once as HEX, RGB and HSL next to a live swatch preview.' },
  { name: 'Copy the format', text: 'Press the Copy button beside the HEX, RGB or HSL value to copy that code to your clipboard.' },
];
---
<Base title={title} description={description}>
  <header class="head"><div class="wrap">
    <p class="kicker">Color Tool</p><h1>Color Picker from Image</h1>
    <p>Drop in an image and click any pixel to grab its exact HEX, RGB and HSL — right here.</p>
  </div></header>
  <div class="wrap"><div class="tool">
    <div id="drop" class="drop"><input id="file" type="file" accept="image/*" hidden />
      <div class="drop-ic">🎨</div><p class="drop-t">Drop an image, or <button id="browse" type="button" class="linklike">browse</button></p>
      <p class="drop-s">🔒 nothing leaves your device · <button id="screen" type="button" class="linklike" hidden>or pick from screen</button></p></div>
    <div id="editor" hidden>
      <div class="cp-grid">
        <canvas id="canvas" aria-label="Click to pick a color"></canvas>
        <div class="cp-side">
          <div class="cp-sw" id="sw"></div>
          <div class="cin"><input id="hex" type="text" readonly /><button class="cpy" data-c="hex">Copy</button></div>
          <div class="cin"><input id="rgb" type="text" readonly /><button class="cpy" data-c="rgb">Copy</button></div>
          <div class="cin"><input id="hsl" type="text" readonly /><button class="cpy" data-c="hsl">Copy</button></div>
          <button id="reset" type="button" class="randbtn">↩ New image</button>
        </div>
      </div>
    </div>
  </div></div>
  <div class="ad">Advertisement</div>
  <div class="content">
    <h2>How to pick a colour from an image</h2>
    <p>Drop in any image and click on it — the picker reads the exact pixel colour under your cursor and shows it as HEX, RGB and HSL, ready to copy. Great for matching a brand colour from a logo or sampling a shade from a photo. On supported browsers you can also use <b>pick from screen</b> to grab a colour from anywhere on your display. Everything runs locally — your image is never uploaded.</p>
    <div class="xlinks"><a href="/tools/palette-extractor">Palette Extractor →</a><a href="/tools/color-converter">Color Converter →</a></div>
  </div>
  <style>
    .drop{border:2px dashed var(--line);border-radius:14px;background:var(--surface2);padding:40px 20px;text-align:center;cursor:pointer}
    .drop.drag{border-color:var(--brand)}.drop-ic{font-size:40px;margin-bottom:8px}.drop-t{font-size:16px;font-weight:600}.drop-s{font-size:13px;color:var(--dim);margin-top:6px}
    .linklike{background:none;border:0;color:var(--brand);font:inherit;font-weight:700;cursor:pointer;text-decoration:underline}
    .cp-grid{display:grid;grid-template-columns:1fr 220px;gap:18px}@media(max-width:640px){.cp-grid{grid-template-columns:1fr}}
    #canvas{width:100%;height:auto;max-height:60vh;object-fit:contain;border:1px solid var(--line);border-radius:12px;cursor:crosshair;background:var(--surface2)}
    .cp-side{display:flex;flex-direction:column;gap:10px}
    .cp-sw{height:80px;border-radius:12px;border:1px solid var(--line);background:var(--surface2)}
    .cin{display:flex;gap:8px}.cin input{flex:1;min-width:0;background:var(--surface2);border:1px solid var(--line);border-radius:9px;color:var(--txt);font:inherit;font-weight:600;padding:9px 10px;outline:none;font-family:ui-monospace,monospace;font-size:13px}
    .cpy{padding:0 12px;border-radius:9px;border:1px solid var(--line);background:var(--surface2);color:var(--dim);font:inherit;font-weight:700;font-size:12px;cursor:pointer}.cpy:hover{color:var(--brand);border-color:var(--brand)}
    .randbtn{margin-top:6px;padding:10px;border-radius:9px;border:1px solid var(--line);background:var(--surface2);color:var(--txt);font:inherit;font-weight:700;cursor:pointer}
  </style>
  <HowTo task="pick a color from an image" steps={howSteps} />
  <AppLd name="Color Picker from Image" description="Drop in an image and click or drag across any pixel to sample its exact colour as HEX, RGB and HSL, with one-click copy and an optional pick-from-screen eyedropper." category="DesignApplication" features={["Click or drag on the image to sample any pixel", "Instant HEX, RGB and HSL output with live swatch", "One-click copy for each colour format", "EyeDropper screen picker on supported browsers", "Runs fully in-browser — no image upload"]} />
  <Faq items={faqItems} />
  <script is:inline>
    (function(){
      function $(i){return document.getElementById(i);}
      function hsl(r,g,b){r/=255;g/=255;b/=255;var mx=Math.max(r,g,b),mn=Math.min(r,g,b),h,s,l=(mx+mn)/2;if(mx===mn){h=s=0;}else{var d=mx-mn;s=l>.5?d/(2-mx-mn):d/(mx+mn);if(mx===r)h=(g-b)/d+(g<b?6:0);else if(mx===g)h=(b-r)/d+2;else h=(r-g)/d+4;h/=6;}return[Math.round(h*360),Math.round(s*100),Math.round(l*100)];}
      function hex(r,g,b){return '#'+[r,g,b].map(function(x){return ('0'+x.toString(16)).slice(-2);}).join('').toUpperCase();}
      function setColor(r,g,b){var hx=hex(r,g,b),hl=hsl(r,g,b);$('sw').style.background=hx;$('hex').value=hx;$('rgb').value='rgb('+r+', '+g+', '+b+')';$('hsl').value='hsl('+hl[0]+', '+hl[1]+'%, '+hl[2]+'%)';}
      var ctx;
      function load(f){var im=new Image();im.onload=function(){var c=$('canvas');c.width=im.naturalWidth;c.height=im.naturalHeight;ctx=c.getContext('2d');ctx.drawImage(im,0,0);$('drop').hidden=true;$('editor').hidden=false;};im.src=URL.createObjectURL(f);}
      function pick(e){var c=$('canvas'),rect=c.getBoundingClientRect();var x=Math.floor((e.clientX-rect.left)*c.width/rect.width),y=Math.floor((e.clientY-rect.top)*c.height/rect.height);if(x<0||y<0||x>=c.width||y>=c.height)return;var d=ctx.getImageData(x,y,1,1).data;setColor(d[0],d[1],d[2]);}
      $('canvas').addEventListener('click',pick);
      $('canvas').addEventListener('mousemove',function(e){if(e.buttons)pick(e);});
      $('browse').onclick=function(e){e.stopPropagation();$('file').click();};
      $('drop').onclick=function(e){if(e.target.id==='drop'||e.target.className.indexOf('drop-')===0)$('file').click();};
      $('file').onchange=function(e){if(e.target.files[0])load(e.target.files[0]);};
      ['dragover','dragenter'].forEach(function(ev){$('drop').addEventListener(ev,function(e){e.preventDefault();$('drop').classList.add('drag');});});
      ['dragleave','drop'].forEach(function(ev){$('drop').addEventListener(ev,function(e){e.preventDefault();$('drop').classList.remove('drag');});});
      $('drop').addEventListener('drop',function(e){if(e.dataTransfer.files[0])load(e.dataTransfer.files[0]);});
      $('reset').onclick=function(){$('file').value='';$('editor').hidden=true;$('drop').hidden=false;};
      document.querySelectorAll('.cpy').forEach(function(b){b.onclick=function(){navigator.clipboard&&navigator.clipboard.writeText($(b.dataset.c).value);b.textContent='✓';setTimeout(function(){b.textContent='Copy';},900);};});
      if(window.EyeDropper){var sb=$('screen');sb.hidden=false;sb.onclick=async function(e){e.stopPropagation();try{var r=await new EyeDropper().open();var n=parseInt(r.sRGBHex.slice(1),16);setColor((n>>16)&255,(n>>8)&255,n&255);$('drop').hidden=true;$('editor').hidden=false;}catch(_){}}; }
    })();
  </script>
</Base>
