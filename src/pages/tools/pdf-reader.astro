---
import Base from '../../layouts/Base.astro';
import Faq from '../../components/Faq.astro';
import AppLd from '../../components/AppLd.astro';
const title = 'PDF Reader — Read, Search & Copy PDFs (Free, Private)';
const description = 'Open any PDF and read it beautifully in your browser: pinch-zoom, select and copy text, search inside the document, and switch reading modes. Nothing is uploaded — your file stays on your device.';
const faqItems = [
  { q: 'Can I copy text from a PDF here?', a: 'Yes. The reader builds a real text layer over every page, so you can select text with your finger or mouse and copy it like any web page — exactly what you copied, nothing re-typed.' },
  { q: 'Does it search inside the PDF?', a: 'Yes. Type in the search box and the reader finds every page containing your text, jumps you to each match, and highlights it. It reads the document’s text, so it works on text-based PDFs (not flat scans).' },
  { q: 'Is my PDF uploaded anywhere?', a: 'No. The PDF is opened and rendered entirely on your device using JavaScript. It is never uploaded, stored, or shared.' },
  { q: 'What are the reading modes?', a: 'Day (white), Sepia (easy on the eyes), and Night (inverted dark) — so you can read comfortably in any light, which is especially helpful for long documents and accessibility.' },
];
---
<Base title={title} description={description}>
  <div class="pr" id="pr">
    <!-- OPEN SCREEN -->
    <div class="pr-open" id="prOpen">
      <header class="head"><div class="wrap">
        <p class="kicker">PDF Tool</p><h1>PDF Reader</h1>
        <p>Open a PDF to read it beautifully — zoom, select &amp; copy text, search inside, and pick a reading mode. Your file never leaves your device.</p>
      </div></header>
      <div class="wrap"><div class="tool">
        <div id="prDrop" class="drop"><input id="prFile" type="file" accept="application/pdf,.pdf" hidden />
          <div class="drop-ic">📖</div><p class="drop-t">Drop a PDF, or <button id="prBrowse" type="button" class="linklike">browse</button></p>
          <p class="drop-s">🔒 opens on your device · nothing uploaded</p></div>
        <p id="prStatus" class="status" role="status" aria-live="polite"></p>
      </div></div>
    </div>

    <!-- READER -->
    <div class="pr-main" id="prMain" hidden>
      <div class="pr-bar">
        <button id="prOpenNew" class="pr-btn" type="button" title="Open another PDF" aria-label="Open another PDF">📂</button>
        <button id="prJump" class="pr-page-ind" type="button" aria-label="Page"><span id="prCur">1</span> / <span id="prTot">1</span></button>
        <span class="pr-spacer"></span>
        <button id="prFindBtn" class="pr-btn" type="button" title="Search" aria-label="Search in document">🔍</button>
        <button id="prOut" class="pr-btn" type="button" title="Zoom out" aria-label="Zoom out">－</button>
        <button id="prFit" class="pr-btn pr-zoom" type="button" title="Fit width" aria-label="Fit width"><span id="prZoom">100%</span></button>
        <button id="prIn" class="pr-btn" type="button" title="Zoom in" aria-label="Zoom in">＋</button>
        <button id="prMode" class="pr-btn" type="button" title="Reading mode" aria-label="Reading mode">🌗</button>
      </div>
      <div class="pr-find" id="prFind" hidden>
        <input id="prQuery" type="search" placeholder="Search in document…" aria-label="Search text" autocomplete="off" />
        <span id="prMatch" class="pr-match"></span>
        <button id="prPrev" class="pr-btn" type="button" aria-label="Previous match">↑</button>
        <button id="prNext" class="pr-btn" type="button" aria-label="Next match">↓</button>
        <button id="prFindClose" class="pr-btn" type="button" aria-label="Close search">✕</button>
      </div>
      <div class="pr-doc" id="prDoc"></div>
    </div>
  </div>

  <div class="content" id="prSeo">
    <h2>A clean, private PDF reader</h2>
    <p>Open any PDF and read it the way it was meant to look — sharp pages, smooth scrolling, and pinch-zoom. Because the reader builds a real <b>text layer</b>, you can <b>select and copy</b> any passage, and <b>search inside</b> the document to jump straight to what you need. Three reading modes (Day, Sepia, Night) make long reading and low light comfortable. Everything happens on your device — the file is never uploaded.</p>
    <div class="xlinks"><a href="/tools/compress-pdf">Compress PDF →</a><a href="/tools/pdf-tools">Merge PDF →</a><a href="/tools/pdf-to-jpg">PDF to JPG →</a></div>
  </div>

  <AppLd name="PDF Reader" description="Open a PDF and read it in your browser with zoom, text selection and copy, in-document search, and Day/Sepia/Night reading modes — fully on-device, nothing uploaded." category="UtilitiesApplication" features={["Open and read any PDF on your device","Pinch-zoom and fit-to-width","Select and copy real text from the PDF","Search inside the document with match highlighting","Day, Sepia and Night reading modes","100% private — nothing is uploaded"]} />
  <Faq items={faqItems} />

  <style is:global>
    /* reader fills the screen below the nav; SEO copy hides once a PDF is open */
    .pr-open .head{padding:var(--s6) 0 var(--s4)}
    .drop{border:2px dashed var(--line);border-radius:14px;background:var(--surface2);padding:44px 20px;text-align:center;cursor:pointer}
    .drop.drag{border-color:var(--brand)}.drop-ic{font-size:42px;margin-bottom:8px}.drop-t{font-size:16px;font-weight:600}.drop-s{font-size:13px;color:var(--dim);margin-top:6px}
    .linklike{background:none;border:0;color:var(--brand);font:inherit;font-weight:700;cursor:pointer;text-decoration:underline}
    .status{max-width:var(--read);margin:14px auto 0;text-align:center;font-size:13px;color:var(--dim)}

    .pr-bar{position:sticky;top:0;z-index:20;display:flex;align-items:center;gap:6px;padding:8px 10px;
      background:var(--nav-bg);backdrop-filter:blur(12px);border-bottom:1px solid var(--line)}
    .pr-spacer{flex:1}
    .pr-btn{min-width:38px;height:38px;padding:0 9px;border-radius:10px;border:1px solid var(--line);background:var(--surface);
      color:var(--txt);font:inherit;font-size:16px;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;justify-content:center}
    .pr-btn:hover{border-color:var(--brand)}
    .pr-zoom{font-size:12px;min-width:54px}
    .pr-page-ind{height:38px;padding:0 12px;border-radius:10px;border:1px solid var(--line);background:var(--surface);color:var(--txt);font:inherit;font-size:13px;font-weight:700;cursor:pointer}
    .pr-find{position:sticky;top:54px;z-index:20;display:flex;align-items:center;gap:6px;padding:8px 10px;background:var(--surface2);border-bottom:1px solid var(--line)}
    .pr-find input{flex:1;min-width:0;height:38px;padding:0 12px;border-radius:10px;border:1px solid var(--line);background:var(--surface);color:var(--txt);font:inherit;font-size:14px;outline:none}
    .pr-find input:focus{border-color:var(--brand)}
    .pr-match{font-size:12px;color:var(--dim);font-weight:700;white-space:nowrap}

    .pr-doc{height:calc(100vh - 54px - 60px);overflow:auto;background:#535365;padding:14px 0;display:flex;flex-direction:column;align-items:center;gap:14px;scroll-behavior:smooth;-webkit-overflow-scrolling:touch}
    body.is-app .pr-doc{height:calc(100vh - 54px - 62px - env(safe-area-inset-bottom))}
    .pr-doc.sepia{background:#c9c2a8}
    .pr-doc.night{background:#0b0b10}
    .pr-page{position:relative;background:#fff;box-shadow:0 6px 22px -8px rgba(0,0,0,.5);flex:0 0 auto}
    .pr-canvas{display:block}
    .pr-doc.sepia .pr-canvas{filter:sepia(.18) saturate(.92) brightness(.98)}
    .pr-doc.night .pr-page{background:#15151c}
    .pr-doc.night .pr-canvas{filter:invert(1) hue-rotate(180deg) brightness(.95) contrast(.95)}

    /* pdf.js text layer (selection + copy) */
    .textLayer{position:absolute;inset:0;overflow:hidden;line-height:1;text-size-adjust:none;forced-color-adjust:none;transform-origin:0 0;opacity:1}
    .textLayer span,.textLayer br{color:transparent;position:absolute;white-space:pre;cursor:text;transform-origin:0% 0%}
    .textLayer span.pr-hit{background:rgba(255,210,0,.45);border-radius:2px;color:transparent}
    .textLayer ::selection{background:rgba(124,92,255,.35)}
    body.is-app .pr-open .head,body.is-app #prSeo,body.is-app .faq{/* keep, but reader is the focus */}
    @media(max-width:560px){.pr-zoom{min-width:46px}.pr-btn{min-width:36px;height:36px}}
  </style>

  <script>
    import * as pdfjsLib from 'pdfjs-dist';
    import pdfWorkerUrl from 'pdfjs-dist/build/pdf.worker.min.js?url';
    pdfjsLib.GlobalWorkerOptions.workerSrc = pdfWorkerUrl;

    (function () {
      function $(i){ return document.getElementById(i); }
      var doc = null, scale = 1, baseScale = 1, fitMode = true, pageEls = [], state = {}, io = null;
      var curPage = 1, query = '', matches = [], matchIdx = -1, indexBuilt = false, textIndex = {};
      var PAD = 14;

      function status(m){ $('prStatus').textContent = m || ''; }

      async function openFile(file){
        if (!file) return;
        status('Opening…');
        try {
          var buf = await file.arrayBuffer();
          doc = await pdfjsLib.getDocument({ data: buf }).promise;
        } catch (e) {
          status('Could not open this PDF — it may be corrupt or password-protected.');
          return;
        }
        indexBuilt = false; textIndex = {}; matches = []; matchIdx = -1; query = '';
        $('prTot').textContent = doc.numPages;
        $('prOpen').hidden = true; $('prSeo').style.display = 'none';
        var faq = document.querySelector('.faq'); if (faq) faq.style.display = 'none';
        $('prMain').hidden = false;
        await layout(false);
      }

      async function layout(keepPage){
        var want = keepPage ? curPage : 1;
        var first = await doc.getPage(1);
        var vp1 = first.getViewport({ scale: 1 });
        var contW = $('prDoc').clientWidth - PAD * 2;
        baseScale = contW / vp1.width;
        if (fitMode) scale = baseScale;
        var phW = Math.round(vp1.width * scale), phH = Math.round(vp1.height * scale);
        var host = $('prDoc'); host.innerHTML = ''; pageEls = []; state = {};
        for (var n = 1; n <= doc.numPages; n++){
          var el = document.createElement('div');
          el.className = 'pr-page'; el.dataset.n = String(n);
          el.style.width = phW + 'px'; el.style.height = phH + 'px';
          host.appendChild(el); pageEls.push(el);
        }
        observe();
        $('prZoom').textContent = Math.round(scale / baseScale * 100) + '%';
        if (keepPage && pageEls[want - 1]) pageEls[want - 1].scrollIntoView();
        updateInd();
      }

      function observe(){
        if (io) io.disconnect();
        io = new IntersectionObserver(function (entries){
          entries.forEach(function (e){
            var n = +e.target.dataset.n;
            if (e.isIntersecting){ renderPage(n); if (e.intersectionRatio > 0.5){ curPage = n; updateInd(); } }
          });
        }, { root: $('prDoc'), rootMargin: '300px 0px', threshold: [0, 0.5] });
        pageEls.forEach(function (el){ io.observe(el); });
      }

      function updateInd(){ $('prCur').textContent = curPage; }

      async function renderPage(n){
        var el = pageEls[n - 1];
        if (!el || state[n] === 'busy' || state[n] === 'done') return;
        state[n] = 'busy';
        try {
          var page = await doc.getPage(n);
          var vp = page.getViewport({ scale: scale });
          var fit = window.SnapJarKit ? window.SnapJarKit.fitDims(vp.width, vp.height) : { scale: 1, clamped: false };
          if (fit.clamped) vp = page.getViewport({ scale: scale * fit.scale });
          el.style.width = Math.round(vp.width) + 'px';
          el.style.height = Math.round(vp.height) + 'px';
          var canvas = document.createElement('canvas');
          canvas.className = 'pr-canvas';
          canvas.width = Math.round(vp.width); canvas.height = Math.round(vp.height);
          var ctx = canvas.getContext('2d');
          el.innerHTML = ''; el.appendChild(canvas);
          await page.render({ canvasContext: ctx, viewport: vp }).promise;
          // text layer (selection + copy) — isolated so a failure never breaks rendering
          try {
            var tl = document.createElement('div');
            tl.className = 'textLayer';
            tl.style.width = Math.round(vp.width) + 'px'; tl.style.height = Math.round(vp.height) + 'px';
            el.appendChild(tl);
            var tc = await page.getTextContent();
            await pdfjsLib.renderTextLayer({ textContentSource: tc, container: tl, viewport: vp, textDivs: [] }).promise;
            if (query) highlight(tl);
          } catch (te) { /* selection unavailable on this page */ }
          state[n] = 'done';
        } catch (e) { state[n] = null; }
      }

      function relayout(){ var keep = curPage; layout(true).then(function (){ curPage = keep; }); }

      function zoom(f){
        fitMode = false;
        scale = Math.min(Math.max(scale * f, baseScale * 0.5), baseScale * 4);
        relayout();
      }

      /* ---- search ---- */
      async function buildIndex(){
        if (indexBuilt) return;
        status('');
        for (var n = 1; n <= doc.numPages; n++){
          try { var p = await doc.getPage(n); var tc = await p.getTextContent();
            textIndex[n] = tc.items.map(function (i){ return i.str; }).join(' ').toLowerCase();
          } catch (e) { textIndex[n] = ''; }
        }
        indexBuilt = true;
      }
      async function runSearch(){
        query = ($('prQuery').value || '').trim().toLowerCase();
        clearHighlights();
        if (!query){ $('prMatch').textContent = ''; matches = []; matchIdx = -1; return; }
        await buildIndex();
        matches = [];
        for (var n = 1; n <= doc.numPages; n++){ if (textIndex[n] && textIndex[n].indexOf(query) >= 0) matches.push(n); }
        matchIdx = matches.length ? 0 : -1;
        $('prMatch').textContent = matches.length ? ('1 / ' + matches.length + ' pages') : 'No matches';
        if (matchIdx >= 0) gotoMatch(0);
      }
      function gotoMatch(i){
        if (!matches.length) return;
        matchIdx = (i + matches.length) % matches.length;
        var n = matches[matchIdx];
        $('prMatch').textContent = (matchIdx + 1) + ' / ' + matches.length + ' pages';
        var el = pageEls[n - 1]; if (el){ el.scrollIntoView({ block: 'start' }); renderPage(n).then(function (){ var tl = el.querySelector('.textLayer'); if (tl) highlight(tl); }); }
      }
      function highlight(tl){
        if (!query) return;
        tl.querySelectorAll('span').forEach(function (s){
          if ((s.textContent || '').toLowerCase().indexOf(query) >= 0) s.classList.add('pr-hit');
        });
      }
      function clearHighlights(){ document.querySelectorAll('.textLayer span.pr-hit').forEach(function (s){ s.classList.remove('pr-hit'); }); }

      /* ---- reading mode ---- */
      var modes = ['', 'sepia', 'night'], modeI = 0;
      function cycleMode(){ modeI = (modeI + 1) % modes.length; var d = $('prDoc'); d.classList.remove('sepia', 'night'); if (modes[modeI]) d.classList.add(modes[modeI]); }

      /* ---- wiring ---- */
      var drop = $('prDrop'), file = $('prFile');
      $('prBrowse').onclick = function (e){ e.stopPropagation(); file.click(); };
      drop.onclick = function (e){ if (e.target === drop || (e.target.className || '').indexOf('drop-') === 0) file.click(); };
      file.onchange = function (e){ if (e.target.files[0]) openFile(e.target.files[0]); };
      ['dragover', 'dragenter'].forEach(function (ev){ drop.addEventListener(ev, function (e){ e.preventDefault(); drop.classList.add('drag'); }); });
      ['dragleave', 'drop'].forEach(function (ev){ drop.addEventListener(ev, function (e){ e.preventDefault(); drop.classList.remove('drag'); }); });
      drop.addEventListener('drop', function (e){ if (e.dataTransfer.files[0]) openFile(e.dataTransfer.files[0]); });

      $('prIn').onclick = function (){ zoom(1.25); };
      $('prOut').onclick = function (){ zoom(0.8); };
      $('prFit').onclick = function (){ fitMode = true; relayout(); };
      $('prMode').onclick = cycleMode;
      $('prOpenNew').onclick = function (){ $('prMain').hidden = true; $('prOpen').hidden = false; $('prSeo').style.display = ''; var f = document.querySelector('.faq'); if (f) f.style.display = ''; file.value = ''; status(''); };
      $('prJump').onclick = function (){ var n = parseInt(prompt('Go to page (1–' + doc.numPages + '):', String(curPage)), 10); if (n >= 1 && n <= doc.numPages && pageEls[n - 1]){ pageEls[n - 1].scrollIntoView(); curPage = n; updateInd(); } };

      $('prFindBtn').onclick = function (){ var f = $('prFind'); f.hidden = !f.hidden; if (!f.hidden) $('prQuery').focus(); };
      $('prFindClose').onclick = function (){ $('prFind').hidden = true; $('prQuery').value = ''; query = ''; clearHighlights(); $('prMatch').textContent = ''; };
      var t; $('prQuery').addEventListener('input', function (){ clearTimeout(t); t = setTimeout(runSearch, 250); });
      $('prPrev').onclick = function (){ gotoMatch(matchIdx - 1); };
      $('prNext').onclick = function (){ gotoMatch(matchIdx + 1); };

      var rt; window.addEventListener('resize', function (){ if (!doc || !fitMode) return; clearTimeout(rt); rt = setTimeout(function (){ relayout(); }, 200); });
    })();
  </script>
</Base>
