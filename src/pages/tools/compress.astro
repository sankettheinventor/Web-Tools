---
import Base from '../../layouts/Base.astro';
const title = 'Image Compressor — Reduce Photo Size Online (Free, Private)';
const description = 'Free image compressor. Shrink JPG, PNG and WebP photos to a smaller size right in your browser — adjust quality, see the new size live, and download. Nothing is uploaded.';
---
<Base title={title} description={description}>
  <header class="head"><div class="wrap">
    <p class="kicker">Image Tool</p><h1>Image Compressor</h1>
    <p>Make photos smaller without uploading them anywhere. Adjust quality and watch the size drop.</p>
  </div></header>
  <div class="wrap"><div class="tool wm">
    <div id="drop" class="drop"><input id="file" type="file" accept="image/*" hidden />
      <div class="drop-ic">🗜️</div><p class="drop-t">Drop an image, or <button id="browse" type="button" class="linklike">browse</button></p>
      <p class="drop-s">JPG · PNG · WebP · 🔒 nothing leaves your device</p></div>
    <div id="editor" hidden>
      <div class="wm-grid">
        <div class="wm-preview"><canvas id="canvas" aria-label="Preview"></canvas></div>
        <div class="wm-controls">
          <label class="ctl">Output format
            <select id="fmt"><option value="image/jpeg" selected>JPEG (smallest)</option><option value="image/webp">WebP (modern)</option><option value="image/png">PNG (lossless)</option></select></label>
          <label class="ctl">Quality <span class="cv" id="qV">75%</span>
            <input id="q" type="range" min="10" max="100" step="5" value="75" /></label>
          <label class="ctl">Max width <span class="cv" id="wV">original</span>
            <input id="w" type="range" min="200" max="4000" step="100" value="4000" /></label>
          <div class="sizes"><span>Original: <b id="oSize">—</b></span><span>New: <b id="nSize" class="hl">—</b></span><span id="saved" class="hl"></span></div>
          <div class="wm-actions">
            <button id="dl" type="button" class="wm-btn">⬇ Download</button>
            <button id="reset" type="button" class="wm-btn ghost">Start over</button>
          </div>
        </div>
      </div>
    </div>
  </div></div>
  <div class="ad">Ad space</div>
  <div class="content">
    <h2>How to compress an image</h2>
    <p>Drop in a photo, pick a format, and drag the quality slider until the size and look are right — the new file size updates instantly. <b>JPEG</b> gives the smallest files for photos; <b>WebP</b> is even smaller on modern browsers; <b>PNG</b> stays lossless for graphics. Lowering the max width shrinks big photos further.</p>
    <p><b>Your image never leaves your device</b> — compression happens entirely in your browser.</p>
    <div class="xlinks"><a href="/tools/convert">Convert &amp; Resize →</a><a href="/#image-tools">All image tools →</a></div>
  </div>
  <style>
    .drop{border:2px dashed var(--line);border-radius:16px;background:var(--surface2);padding:48px 24px;text-align:center;cursor:pointer}
    .drop.drag{border-color:var(--brand)}.drop-ic{font-size:44px;margin-bottom:10px}.drop-t{font-size:17px;font-weight:600}.drop-s{font-size:13px;color:var(--dim);margin-top:8px}
    .linklike{background:none;border:0;color:var(--brand);font:inherit;font-weight:700;cursor:pointer;text-decoration:underline}
    .wm{padding:20px}.wm-grid{display:grid;grid-template-columns:1fr 290px;gap:22px}.wm-preview{min-width:0}
    #canvas{width:100%;height:auto;max-height:58vh;object-fit:contain;border:1px solid var(--line);border-radius:12px;background:var(--surface2)}
    .wm-controls{display:flex;flex-direction:column;gap:14px}.ctl{display:flex;flex-direction:column;gap:6px;font-size:13px;font-weight:600;color:var(--dim)}
    .ctl select{background:var(--surface2);border:1px solid var(--line);border-radius:9px;color:var(--txt);font:inherit;font-weight:600;padding:10px 11px}
    .cv{float:right;color:var(--brand);font-weight:700}.sizes{display:flex;flex-direction:column;gap:5px;font-size:13.5px;color:var(--dim);background:var(--surface2);border:1px solid var(--line);border-radius:10px;padding:12px}
    .sizes .hl{color:var(--brand);font-weight:700}.wm-actions{display:flex;gap:10px}.wm-btn{flex:1;padding:12px;border-radius:10px;font-weight:700;color:#fff;border:0;cursor:pointer;background:linear-gradient(135deg,var(--brand2),var(--brand))}
    .wm-btn.ghost{background:var(--surface2);color:var(--dim);border:1px solid var(--line);flex:0 0 auto}
    @media(max-width:680px){.wm-grid{grid-template-columns:1fr}}
  </style>
  <script is:inline>
    (function(){
      var img=null, origSize=0, lastBlob=null, name='image';
      function $(i){return document.getElementById(i);}
      function fmtKB(b){return b>1048576?(b/1048576).toFixed(2)+' MB':Math.round(b/1024)+' KB';}
      function render(){
        if(!img)return;
        var maxW=parseInt($('w').value,10), scale=Math.min(1,maxW/img.naturalWidth);
        var w=Math.round(img.naturalWidth*scale), h=Math.round(img.naturalHeight*scale);
        var c=$('canvas'); c.width=w; c.height=h; c.getContext('2d').drawImage(img,0,0,w,h);
        $('wV').textContent = scale<1 ? w+'px' : 'original';
        var fmt=$('fmt').value, q=parseInt($('q').value,10)/100;
        c.toBlob(function(b){ lastBlob=b; $('nSize').textContent=fmtKB(b.size);
          var pct=origSize?Math.max(0,Math.round((1-b.size/origSize)*100)):0;
          $('saved').textContent = b.size<origSize ? ('▼ '+pct+'% smaller') : '';
        }, fmt, q);
      }
      function load(f){ name=f.name.replace(/\.[^.]+$/,''); origSize=f.size; $('oSize').textContent=fmtKB(f.size);
        var im=new Image(); im.onload=function(){img=im;$('drop').hidden=true;$('editor').hidden=false;render();}; im.src=URL.createObjectURL(f); }
      $('browse').onclick=function(){$('file').click();};
      $('drop').onclick=function(e){if(e.target.id==='drop'||e.target.className.indexOf('drop-')===0)$('file').click();};
      $('file').onchange=function(e){if(e.target.files[0])load(e.target.files[0]);};
      ['dragover','dragenter'].forEach(function(ev){$('drop').addEventListener(ev,function(e){e.preventDefault();$('drop').classList.add('drag');});});
      ['dragleave','drop'].forEach(function(ev){$('drop').addEventListener(ev,function(e){e.preventDefault();$('drop').classList.remove('drag');});});
      $('drop').addEventListener('drop',function(e){if(e.dataTransfer.files[0])load(e.dataTransfer.files[0]);});
      ['fmt','q','w'].forEach(function(i){$(i).addEventListener('input',function(){$('qV').textContent=$('q').value+'%';render();});});
      $('dl').onclick=function(){if(!lastBlob)return;var ext=$('fmt').value.split('/')[1].replace('jpeg','jpg');var a=document.createElement('a');a.href=URL.createObjectURL(lastBlob);a.download=name+'-compressed.'+ext;a.click();setTimeout(function(){URL.revokeObjectURL(a.href);},1500);};
      $('reset').onclick=function(){img=null;lastBlob=null;$('file').value='';$('editor').hidden=true;$('drop').hidden=false;};
    })();
  </script>
</Base>
