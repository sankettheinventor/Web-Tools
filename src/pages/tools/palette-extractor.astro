---
import Base from '../../layouts/Base.astro';
import Faq from '../../components/Faq.astro';
import HowTo from '../../components/HowTo.astro';
import AppLd from '../../components/AppLd.astro';
const title = 'Color Palette Extractor — Get Colors From a Photo (Free)';
const description = 'Free color palette extractor: pull dominant colors from any photo as copyable HEX swatches for moodboards and brands. Runs in your browser, nothing uploaded.';
const faqItems = [
  { q: 'How do I extract a color palette from an image?', a: 'Drop or browse to a photo and the tool instantly scans it, groups similar pixels, and shows the most common colors as a palette of HEX swatches.' },
  { q: 'How do I copy a color code?', a: 'Click any swatch and its HEX code is copied to your clipboard. The swatch briefly shows "Copied!" to confirm.' },
  { q: 'How many colors does it pull from a photo?', a: 'It surfaces up to 8 dominant colors, skipping near-duplicate shades so the palette stays varied and useful.' },
  { q: 'Is my photo uploaded or stored anywhere?', a: 'No. Your image is processed entirely in your browser using a canvas. Nothing is uploaded, stored, or shared, and the photo never leaves your device.' },
  { q: 'What image formats can I use?', a: 'Any standard image your browser can open works, including JPG, PNG, WebP, and GIF.' },
];
const howSteps = [
  { name: 'Add your photo', text: 'Drop an image onto the drop zone or click browse to pick a file from your device.' },
  { name: 'View the palette', text: 'The tool instantly scans the image and shows up to 8 dominant colors as HEX swatches.' },
  { name: 'Copy a color', text: 'Click any swatch to copy its HEX code to your clipboard, confirmed by a brief "Copied!" label.' },
  { name: 'Start over', text: 'Click "New image" to clear the palette and extract colors from another photo.' },
];
---
<Base title={title} description={description}>
  <header class="head"><div class="wrap">
    <p class="kicker">Color Tool</p><h1>Color Palette Extractor</h1>
    <p>Drop in a photo and click any swatch to copy its HEX — right here in your browser.</p>
  </div></header>
  <div class="wrap"><div class="tool">
    <div id="drop" class="drop"><input id="file" type="file" accept="image/*" hidden />
      <div class="drop-ic">🎨</div><p class="drop-t">Drop a photo, or <button id="browse" type="button" class="linklike">browse</button></p>
      <p class="drop-s">🔒 nothing leaves your device</p></div>
    <div id="editor" hidden>
      <img id="thumb" alt="Source" />
      <div class="pal" id="pal"></div>
      <div class="pal-actions">
        <button id="copyAll" type="button" class="randbtn primary">⧉ Copy all HEX</button>
        <button id="reset" type="button" class="randbtn">↩ New image</button>
      </div>
    </div>
  </div></div>
  <div class="ad">Advertisement</div>
  <div class="content">
    <h2>How the palette is extracted</h2>
    <p>The tool scans your photo, groups similar pixels into colour buckets, and surfaces the most common ones as a palette. Click any swatch to copy its HEX code. It's perfect for building a brand palette from a logo, a moodboard from a photo, or matching UI colours to an image. Everything runs in your browser — the photo is never uploaded.</p>
    <div class="xlinks"><a href="/tools/color-picker">Color Picker →</a><a href="/tools/gradient-generator">Gradient Generator →</a></div>
  </div>
  <style>
    .drop{border:2px dashed var(--line);border-radius:14px;background:var(--surface2);padding:40px 20px;text-align:center;cursor:pointer}
    .drop.drag{border-color:var(--brand)}.drop-ic{font-size:40px;margin-bottom:8px}.drop-t{font-size:16px;font-weight:600}.drop-s{font-size:13px;color:var(--dim);margin-top:6px}
    .linklike{background:none;border:0;color:var(--brand);font:inherit;font-weight:700;cursor:pointer;text-decoration:underline}
    #thumb{width:100%;max-height:46vh;object-fit:contain;border:1px solid var(--line);border-radius:12px;background:var(--surface2)}
    .pal{display:grid;grid-template-columns:repeat(auto-fill,minmax(104px,1fr));gap:12px;margin-top:18px}
    .sw{display:flex;flex-direction:column;border:1px solid var(--line);border-radius:14px;overflow:hidden;cursor:pointer;background:var(--surface);padding:0;font:inherit;text-align:left;box-shadow:0 1px 2px rgba(20,16,44,.05),0 8px 22px -16px rgba(20,16,44,.3);transition:transform .12s ease,box-shadow .2s ease,border-color .2s ease}
    .sw:hover{border-color:var(--brand);box-shadow:0 2px 4px rgba(20,16,44,.06),0 12px 26px -14px rgba(20,16,44,.4)}
    .sw:active{transform:scale(.97)}
    .sw-clr{height:88px;width:100%;display:block}
    .sw-meta{display:flex;align-items:center;justify-content:space-between;gap:6px;padding:9px 11px}
    .sw-hx{font-family:ui-monospace,Menlo,Consolas,monospace;font-size:12.5px;font-weight:800;letter-spacing:.3px;color:var(--txt)}
    .sw-cp{flex:0 0 auto;display:grid;place-items:center;color:var(--dim);transition:color .15s ease}
    .sw:hover .sw-cp{color:var(--brand)}
    .sw.copied{border-color:#1aa34a}.sw.copied .sw-hx{color:#1aa34a}.sw.copied .sw-cp{color:#1aa34a}
    .pal-actions{display:flex;gap:10px;margin-top:18px;flex-wrap:wrap}
    .randbtn{padding:12px 18px;border-radius:12px;border:1px solid var(--line);background:var(--surface2);color:var(--txt);font:inherit;font-weight:700;cursor:pointer;transition:transform .12s ease}
    .randbtn:active{transform:scale(.97)}
    .randbtn.primary{border-color:transparent;background:linear-gradient(135deg,var(--brand2),var(--brand));color:#fff}
  </style>
  <AppLd name="Color Palette Extractor" description="Drop or browse to a photo and the tool instantly extracts up to 8 dominant colors as clickable HEX swatches you copy with one tap." category="DesignApplication" features={["Drag-and-drop photo upload","Instant in-browser color extraction","Up to 8 dominant color swatches","One-click HEX copy to clipboard","Reset to extract from a new image"]} />
  <HowTo task="extract a color palette from an image" steps={howSteps} />
  <Faq items={faqItems} />
  <script is:inline>
    (function(){
      function $(i){return document.getElementById(i);}
      function hx(r,g,b){return '#'+[r,g,b].map(function(x){return ('0'+x.toString(16)).slice(-2);}).join('').toUpperCase();}
      function extract(im){
        var w=120,h=Math.max(1,Math.round(120*im.naturalHeight/im.naturalWidth));
        var c=document.createElement('canvas');c.width=w;c.height=h;var x=c.getContext('2d');x.drawImage(im,0,0,w,h);
        var d=x.getImageData(0,0,w,h).data,map={};
        for(var i=0;i<d.length;i+=4){
          if(d[i+3]<128)continue;
          var r=d[i]>>4,g=d[i+1]>>4,b=d[i+2]>>4,key=(r<<8)|(g<<4)|b;
          if(!map[key])map[key]={n:0,r:0,g:0,b:0};
          map[key].n++;map[key].r+=d[i];map[key].g+=d[i+1];map[key].b+=d[i+2];
        }
        var arr=Object.keys(map).map(function(k){var m=map[k];return{n:m.n,r:Math.round(m.r/m.n),g:Math.round(m.g/m.n),b:Math.round(m.b/m.n)};});
        arr.sort(function(a,b){return b.n-a.n;});
        var out=[];
        for(var j=0;j<arr.length && out.length<8;j++){
          var col=arr[j],dup=false;
          for(var k=0;k<out.length;k++){if(Math.abs(out[k].r-col.r)+Math.abs(out[k].g-col.g)+Math.abs(out[k].b-col.b)<48){dup=true;break;}}
          if(!dup)out.push(col);
        }
        return out;
      }
      var COPY_SVG='<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/></svg>';
      var CHECK_SVG='<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>';
      var lastPal=[];
      function copyText(t,msg){ if(window.SnapJarKit&&window.SnapJarKit.copy)window.SnapJarKit.copy(t,msg); else if(navigator.clipboard)navigator.clipboard.writeText(t); }
      function render(im){
        $('thumb').src=im.src;
        var pal=extract(im),p=$('pal');p.innerHTML='';lastPal=[];
        pal.forEach(function(c){
          var code=hx(c.r,c.g,c.b);lastPal.push(code);
          var d=document.createElement('button');d.type='button';d.className='sw';d.setAttribute('aria-label','Copy '+code);
          d.innerHTML='<span class="sw-clr" style="background:'+code+'"></span><span class="sw-meta"><span class="sw-hx">'+code+'</span><span class="sw-cp">'+COPY_SVG+'</span></span>';
          d.onclick=function(){
            copyText(code,'Copied '+code);
            var hxEl=d.querySelector('.sw-hx'),cpEl=d.querySelector('.sw-cp');
            d.classList.add('copied');hxEl.textContent='Copied';cpEl.innerHTML=CHECK_SVG;
            clearTimeout(d._t);d._t=setTimeout(function(){hxEl.textContent=code;cpEl.innerHTML=COPY_SVG;d.classList.remove('copied');},1100);
          };
          p.appendChild(d);
        });
      }
      function load(f){var im=new Image();im.onload=function(){$('drop').hidden=true;$('editor').hidden=false;render(im);};im.onerror=function(){$('drop').querySelector('.drop-t').textContent='Could not open this image — it may be corrupt or unsupported.';};im.src=window.SnapJarKit.track(f);}
      $('browse').onclick=function(e){e.stopPropagation();$('file').click();};
      $('drop').onclick=function(e){if(e.target.id==='drop'||e.target.className.indexOf('drop-')===0)$('file').click();};
      $('file').onchange=function(e){if(e.target.files[0])load(e.target.files[0]);};
      ['dragover','dragenter'].forEach(function(ev){$('drop').addEventListener(ev,function(e){e.preventDefault();$('drop').classList.add('drag');});});
      ['dragleave','drop'].forEach(function(ev){$('drop').addEventListener(ev,function(e){e.preventDefault();$('drop').classList.remove('drag');});});
      $('drop').addEventListener('drop',function(e){if(e.dataTransfer.files[0])load(e.dataTransfer.files[0]);});
      $('copyAll').onclick=function(){ if(!lastPal.length)return; copyText(lastPal.join('\n'),'Copied all '+lastPal.length+' colors'); };
      $('reset').onclick=function(){window.SnapJarKit.clear();$('file').value='';$('editor').hidden=true;$('drop').hidden=false;};
    })();
  </script>
</Base>
