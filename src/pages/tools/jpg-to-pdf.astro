---
import Base from '../../layouts/Base.astro';
import Faq from '../../components/Faq.astro';
const title = 'JPG to PDF — Convert Images to PDF (Free, Private)';
const description = 'Free JPG to PDF converter. Combine JPG, PNG or WebP images into a single PDF — one image per page, in order — right in your browser. Nothing is uploaded.';
const faqItems = [
  { q: 'How do I convert JPG images to a PDF?', a: 'Drop or browse to select one or more JPG, PNG or WebP images, then click Create PDF. The tool combines them into a single PDF with one image per page and downloads it instantly.' },
  { q: 'In what order are the images added to the PDF?', a: 'Images are placed in the order you add them, one image per page. Each page is sized to match the dimensions of its image.' },
  { q: 'What image formats can I convert?', a: 'You can convert JPG, PNG and WebP images. Each image is rendered onto a white background and embedded as a JPEG page in the final PDF.' },
  { q: 'Is there a limit on how many images I can combine?', a: 'There is no fixed limit set by the tool. Because everything runs in your browser, very large batches depend on your device memory, but typical sets of photos, scans or receipts work fine.' },
  { q: 'Are my images uploaded or stored anywhere?', a: 'No. Every image is processed locally in your browser and the PDF is generated on your device. Nothing is uploaded, stored or shared.' },
];
---
<Base title={title} description={description}>
  <Fragment slot="head">
    <script is:inline src="https://cdn.jsdelivr.net/npm/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>
  </Fragment>
  <header class="head"><div class="wrap">
    <p class="kicker">PDF Tool</p><h1>JPG to PDF</h1>
    <p>Combine images into one PDF — in your browser, never uploaded.</p>
  </div></header>
  <div class="wrap"><div class="tool wm">
    <div id="drop" class="drop"><input id="file" type="file" accept="image/*" multiple hidden />
      <div class="drop-ic">🖼️</div><p class="drop-t">Drop images, or <button id="browse" type="button" class="linklike">browse</button></p>
      <p class="drop-s">JPG · PNG · WebP · merged in the order added · 🔒 nothing leaves your device</p></div>
    <div id="editor" hidden>
      <div class="thumbs" id="thumbs"></div>
      <div class="wm-actions"><button id="make" type="button" class="wm-btn">⬇ Create PDF</button>
        <button id="reset" type="button" class="wm-btn ghost">Clear</button></div>
      <p id="status" class="status"></p>
    </div>
  </div></div>
  <div class="ad">Ad space</div>
  <div class="content">
    <h2>Turn images into a PDF</h2>
    <p>Drop in one or more photos or scans and they're combined into a single PDF — one image per page, sized to the image, in the order you added them. It's perfect for turning receipts, scanned documents or a set of pictures into one shareable file. Everything is generated locally; your images are never uploaded.</p>
    <div class="xlinks"><a href="/tools/pdf-to-jpg">PDF to JPG →</a><a href="/tools/pdf-tools">Merge PDF →</a></div>
  </div>
  <style>
    .drop{border:2px dashed var(--line);border-radius:14px;background:var(--surface2);padding:40px 20px;text-align:center;cursor:pointer}
    .drop.drag{border-color:var(--brand)}.drop-ic{font-size:40px;margin-bottom:8px}.drop-t{font-size:16px;font-weight:600}.drop-s{font-size:13px;color:var(--dim);margin-top:6px}
    .linklike{background:none;border:0;color:var(--brand);font:inherit;font-weight:700;cursor:pointer;text-decoration:underline}
    .wm{padding:20px}.thumbs{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:16px}
    .thumbs img{width:70px;height:70px;object-fit:cover;border-radius:8px;border:1px solid var(--line)}
    .wm-actions{display:flex;gap:10px}.wm-btn{padding:11px 18px;border-radius:10px;font-weight:700;color:#fff;border:0;cursor:pointer;background:linear-gradient(135deg,var(--brand2),var(--brand))}
    .wm-btn.ghost{background:var(--surface2);color:var(--dim);border:1px solid var(--line)}.status{margin-top:10px;font-size:13px;color:var(--dim)}
  </style>
  <Faq items={faqItems} />
  <script is:inline>
    (function(){
      var files=[];
      function $(i){return document.getElementById(i);}
      function add(list){
        Array.prototype.slice.call(list).filter(function(f){return f.type.indexOf('image/')===0;}).forEach(function(f){files.push(f);});
        if(files.length){$('drop').hidden=true;$('editor').hidden=false;thumbs();}
      }
      function thumbs(){$('thumbs').innerHTML='';files.forEach(function(f){var im=document.createElement('img');im.src=URL.createObjectURL(f);$('thumbs').appendChild(im);});}
      function toJpeg(f){return new Promise(function(res){var im=new Image();im.onload=function(){var c=document.createElement('canvas');c.width=im.naturalWidth;c.height=im.naturalHeight;var x=c.getContext('2d');x.fillStyle='#fff';x.fillRect(0,0,c.width,c.height);x.drawImage(im,0,0);c.toBlob(function(b){b.arrayBuffer().then(function(buf){res({buf:buf,w:c.width,h:c.height});});},'image/jpeg',0.92);};im.src=URL.createObjectURL(f);});}
      async function make(){
        if(!files.length||typeof PDFLib==='undefined')return;
        $('status').textContent='Building PDF…';
        var doc=await PDFLib.PDFDocument.create();
        for(var i=0;i<files.length;i++){var img=await toJpeg(files[i]);var emb=await doc.embedJpg(img.buf);var pg=doc.addPage([img.w,img.h]);pg.drawImage(emb,{x:0,y:0,width:img.w,height:img.h});}
        var bytes=await doc.save();var blob=new Blob([bytes],{type:'application/pdf'});
        var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='images.pdf';a.click();setTimeout(function(){URL.revokeObjectURL(a.href);},1500);
        $('status').textContent='Done — '+files.length+' image(s) in your PDF.';
      }
      $('browse').onclick=function(e){e.stopPropagation();$('file').click();};
      $('drop').onclick=function(e){if(e.target.id==='drop'||e.target.className.indexOf('drop-')===0)$('file').click();};
      $('file').onchange=function(e){add(e.target.files);};
      ['dragover','dragenter'].forEach(function(ev){$('drop').addEventListener(ev,function(e){e.preventDefault();$('drop').classList.add('drag');});});
      ['dragleave','drop'].forEach(function(ev){$('drop').addEventListener(ev,function(e){e.preventDefault();$('drop').classList.remove('drag');});});
      $('drop').addEventListener('drop',function(e){add(e.dataTransfer.files);});
      $('make').onclick=make;
      $('reset').onclick=function(){files=[];$('thumbs').innerHTML='';$('file').value='';$('status').textContent='';$('editor').hidden=true;$('drop').hidden=false;};
    })();
  </script>
</Base>
