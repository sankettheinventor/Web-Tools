---
import Base from '../../layouts/Base.astro';
import Faq from '../../components/Faq.astro';
import HowTo from '../../components/HowTo.astro';
import AppLd from '../../components/AppLd.astro';
const title = 'Add Watermark to Photos — Free Batch Watermark Studio';
const description = 'Add text, logo or signature watermarks to photos in your browser — batch mode, fonts, opacity, tiling. Free, no signup, nothing is ever uploaded.';
const faqItems = [
  { q: 'Are my photos uploaded or stored anywhere?', a: 'No. Every image is processed entirely in your browser using the HTML canvas. Nothing is uploaded, stored, or shared, and your photos never leave your device.' },
  { q: 'What kinds of watermarks can I add?', a: 'You can add a text watermark, a logo or image watermark, or a styled signature. Each supports its own font, color, size, opacity, position and rotation.' },
  { q: 'Can I watermark many photos at once?', a: 'Yes. Drop multiple images and they appear in the strip at the top. Your watermark settings apply to the selected photo, and Download all saves every image in the batch.' },
  { q: 'Can I tile the watermark across the whole image?', a: 'Yes, the Text mode has a Tile option that repeats the mark across the entire photo, which makes it much harder to crop out.' },
  { q: 'What file formats can I use and download?', a: 'You can load JPG, PNG and WebP images. Watermarked photos are downloaded as PNG files.' },
];
const howSteps = [
  { name: 'Add your photos', text: 'Drop one or more images onto the canvas or click browse, and they appear in the thumbnail strip at the top.' },
  { name: 'Choose a watermark type', text: 'Pick the Text, Logo or Signature tab in the side panel to set the kind of watermark you want.' },
  { name: 'Style the watermark', text: 'Adjust the font, color, size, opacity, rotation and position, and enable Tile to repeat a text mark across the whole photo.' },
  { name: 'Download the result', text: 'Click Download to save the current photo as a PNG, or Download all to export every image in the batch.' },
];
---
<Base title={title} description={description}>
  <div class="wmapp">
    <input id="file" type="file" accept="image/*" multiple hidden />
    <div class="wmapp-top">
      <h1>Watermark Studio</h1>
      <div class="wm-thumbs" id="thumbs"><span class="thint">Your images appear here →</span></div>
    </div>

    <div class="wmapp-main">
      <aside class="wm-side">
        <div class="wm-tabs">
          <button type="button" class="wt on" data-m="text"><span>T</span>Text</button>
          <button type="button" class="wt" data-m="logo"><span>🖼</span>Logo</button>
          <button type="button" class="wt" data-m="sign"><span>✒</span>Signature</button>
        </div>
        <div class="wm-scroll">
          <div class="wm-panel" data-panel="text">
            <label class="ctl">Watermark text<textarea id="t_text" rows="2">© Your Brand</textarea></label>
            <label class="ctl">Font<select id="t_font"><option>Arial</option><option>Georgia</option><option>Times New Roman</option><option>Courier New</option><option>Verdana</option><option>Trebuchet MS</option><option>Impact</option></select></label>
            <div class="btn-row">
              <button type="button" class="tg" id="t_bold" title="Bold"><b>B</b></button>
              <button type="button" class="tg" id="t_italic" title="Italic"><i>I</i></button>
              <span class="sep"></span>
              <button type="button" class="tg align on" data-a="left" title="Left">⬅</button>
              <button type="button" class="tg align" data-a="center" title="Center">⬌</button>
              <button type="button" class="tg align" data-a="right" title="Right">➡</button>
            </div>
            <div class="row2">
              <label class="ctl">Color<input id="t_color" type="color" value="#ffffff" /></label>
              <label class="ctl">Vertical<select id="t_v"><option value="top">Top</option><option value="middle">Middle</option><option value="bottom" selected>Bottom</option></select></label>
            </div>
            <label class="ctl">Size <span class="cv" id="t_sizeV">6%</span><input id="t_size" type="range" min="2" max="20" step="0.5" value="6" /></label>
            <div class="row2">
              <label class="ctl">Opacity <span class="cv" id="t_opV">60%</span><input id="t_op" type="range" min="5" max="100" step="5" value="60" /></label>
              <label class="ctl">Rotation <span class="cv" id="t_rotV">0°</span><input id="t_rot" type="range" min="-90" max="90" step="5" value="0" /></label>
            </div>
            <label class="chkrow"><input type="checkbox" id="t_shadow" /> Drop shadow</label>
            <label class="chkrow"><input type="checkbox" id="t_tile" /> Tile across image</label>
          </div>

          <div class="wm-panel" data-panel="logo" hidden>
            <label class="ctl">Logo image<input id="l_file" type="file" accept="image/*" /></label>
            <div class="row2">
              <label class="ctl">Horizontal<select id="l_a"><option value="left">Left</option><option value="center">Center</option><option value="right" selected>Right</option></select></label>
              <label class="ctl">Vertical<select id="l_v"><option value="top">Top</option><option value="middle">Middle</option><option value="bottom" selected>Bottom</option></select></label>
            </div>
            <label class="ctl">Size <span class="cv" id="l_sizeV">20%</span><input id="l_size" type="range" min="5" max="60" step="1" value="20" /></label>
            <div class="row2">
              <label class="ctl">Opacity <span class="cv" id="l_opV">80%</span><input id="l_op" type="range" min="5" max="100" step="5" value="80" /></label>
              <label class="ctl">Rotation <span class="cv" id="l_rotV">0°</span><input id="l_rot" type="range" min="-90" max="90" step="5" value="0" /></label>
            </div>
          </div>

          <div class="wm-panel" data-panel="sign" hidden>
            <label class="ctl">Your name<input id="s_text" type="text" value="Julee Jamison" /></label>
            <label class="ctl">Signature font<select id="s_font"><option>Brush Script MT</option><option>Segoe Script</option><option>Lucida Handwriting</option><option value="cursive">Cursive</option></select></label>
            <div class="row2">
              <label class="ctl">Color<input id="s_color" type="color" value="#3b6fff" /></label>
              <label class="ctl">Position<select id="s_v"><option value="top" selected>Top</option><option value="middle">Middle</option><option value="bottom">Bottom</option></select></label>
            </div>
            <div class="btn-row">
              <button type="button" class="tg align on" data-sa="left" title="Left">⬅</button>
              <button type="button" class="tg align" data-sa="center" title="Center">⬌</button>
              <button type="button" class="tg align" data-sa="right" title="Right">➡</button>
            </div>
            <label class="ctl">Size <span class="cv" id="s_sizeV">8%</span><input id="s_size" type="range" min="3" max="20" step="0.5" value="8" /></label>
            <label class="ctl">Opacity <span class="cv" id="s_opV">90%</span><input id="s_op" type="range" min="5" max="100" step="5" value="90" /></label>
          </div>
        </div>
      </aside>

      <div class="wm-canvas" id="dropzone">
        <canvas id="canvas" aria-label="Watermark preview" hidden></canvas>
        <div class="drop-prompt" id="prompt">
          <div class="drop-ic">🖼️</div>
          <p class="drop-t">Drop images here, or <button id="browse" type="button" class="linklike">browse</button></p>
          <p class="drop-s">Batch supported · JPG, PNG, WebP · 🔒 nothing leaves your device</p>
        </div>
      </div>
    </div>

    <div class="wm-bar">
      <button id="reset" type="button" class="wm-btn ghost">↩ Start over</button>
      <span class="wm-info" id="info">Drop a photo to begin</span>
      <div class="grow"></div>
      <button id="dlall" type="button" class="wm-btn ghost" hidden>Download all</button>
      <button id="dl" type="button" class="wm-btn">⬇ Download</button>
    </div>
  </div>

  <div class="content" style="margin-top:30px">
    <h2>How to watermark your photos</h2>
    <ol>
      <li>Drop one or many images — they appear in the strip at the top (batch mode).</li>
      <li>Pick <b>Text</b>, <b>Logo</b> or <b>Signature</b>, then style it — font, colour, opacity, rotation and position.</li>
      <li>Turn on <b>Tile</b> to repeat the mark across the whole image (the hardest to crop out).</li>
      <li>Click <b>Download</b> for the current photo, or <b>Download all</b> for the batch.</li>
    </ol>
    <p><b>Your images never leave your device</b> — everything is processed locally in your browser.</p>
    <div class="xlinks"><a href="/tools/compress">Image Compressor →</a><a href="/#image-tools">All image tools →</a></div>
  </div>

  <style>
    /* full-viewport app */
    .wmapp{display:flex;flex-direction:column;gap:10px;max-width:1200px;margin:0 auto;padding:12px 16px 0;
      height:calc(100vh - 112px);min-height:520px}
    .wmapp-top{display:flex;align-items:center;gap:16px;flex:0 0 auto}
    .wmapp-top h1{font-size:18px;font-weight:800;letter-spacing:-.4px;white-space:nowrap}
    .wm-thumbs{display:flex;gap:7px;overflow-x:auto;flex:1;align-items:center;min-width:0}
    .wm-thumbs .thint{font-size:12.5px;color:var(--dim)}
    .wm-thumbs img{width:58px;height:46px;object-fit:cover;border-radius:7px;border:2px solid var(--line);cursor:pointer;flex:0 0 auto}
    .wm-thumbs img.sel{border-color:var(--brand)}

    .wmapp-main{flex:1;display:grid;grid-template-columns:280px 1fr;gap:14px;min-height:0}
    .wm-side{background:var(--surface);border:1px solid var(--line);border-radius:13px;padding:14px;display:flex;flex-direction:column;min-height:0}
    .wm-tabs{display:flex;gap:6px;margin-bottom:12px;flex:0 0 auto}
    .wt{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;padding:8px 4px;background:var(--surface2);border:1px solid var(--line);border-radius:9px;font:inherit;font-size:11.5px;font-weight:700;color:var(--dim);cursor:pointer}
    .wt span{font-size:15px}.wt.on{color:#fff;background:linear-gradient(135deg,var(--brand2),var(--brand));border-color:transparent}
    .wm-scroll{overflow-y:auto;min-height:0;padding-right:2px}
    .wm-panel{display:flex;flex-direction:column;gap:11px}.wm-panel[hidden]{display:none}
    .ctl{display:flex;flex-direction:column;gap:5px;font-size:12.5px;font-weight:600;color:var(--dim)}
    .ctl input,.ctl select,.ctl textarea{background:var(--surface2);border:1px solid var(--line);border-radius:8px;color:var(--txt);font:inherit;font-weight:600;padding:8px 10px;outline:none;resize:vertical}
    .ctl input:focus,.ctl select:focus,.ctl textarea:focus{border-color:var(--brand)}
    .ctl input[type=color]{height:34px;padding:3px;cursor:pointer}.ctl input[type=file]{font-size:11.5px;font-weight:500}
    .row2{display:grid;grid-template-columns:1fr 1fr;gap:10px}.cv{float:right;color:var(--brand);font-weight:700}
    .btn-row{display:flex;gap:5px;align-items:center}.sep{width:1px;height:22px;background:var(--line);margin:0 3px}
    .tg{width:32px;height:32px;border-radius:8px;background:var(--surface2);border:1px solid var(--line);color:var(--txt);font:inherit;font-size:13px;cursor:pointer;display:grid;place-items:center}
    .tg.on{color:#fff;background:linear-gradient(135deg,var(--brand2),var(--brand));border-color:transparent}
    .chkrow{display:flex;align-items:center;gap:8px;font-size:13px;font-weight:600;color:var(--txt)}.chkrow input{width:16px;height:16px;accent-color:var(--brand)}

    .wm-canvas{background:var(--surface2);border:1px solid var(--line);border-radius:13px;display:flex;align-items:center;justify-content:center;
      min-height:0;overflow:hidden;cursor:pointer;transition:border-color .15s,background .15s}
    .wm-canvas.drag{border-color:var(--brand);background:var(--surface)}
    #canvas{max-width:100%;max-height:100%;height:auto;border-radius:8px;display:block}
    #canvas[hidden]{display:none}
    .drop-prompt{text-align:center;padding:24px}
    .drop-ic{font-size:42px;margin-bottom:8px}.drop-t{font-size:16px;font-weight:600;color:var(--txt)}.drop-s{font-size:12.5px;color:var(--dim);margin-top:6px}
    .linklike{background:none;border:0;color:var(--brand);font:inherit;font-weight:700;cursor:pointer;text-decoration:underline}

    .wm-bar{display:flex;align-items:center;gap:10px;flex:0 0 auto;padding:4px 0 0}
    .wm-info{font-size:12.5px;color:var(--dim)}.grow{flex:1}
    .wm-btn{padding:10px 18px;border-radius:10px;font-weight:700;color:#fff;border:0;cursor:pointer;background:linear-gradient(135deg,var(--brand2),var(--brand))}
    .wm-btn.ghost{background:var(--surface2);color:var(--dim);border:1px solid var(--line)}

    @media(max-width:760px){
      .wmapp{height:auto;min-height:0}
      .wmapp-main{grid-template-columns:1fr}
      .wm-scroll{overflow:visible}
      .wm-canvas{min-height:300px}
    }
  </style>

  <HowTo task="add a watermark to a photo" steps={howSteps} />
  <AppLd name="Watermark Studio" description="Drop your photos in, then drag sliders to style a text, logo or signature watermark with live opacity, rotation and tiling — right in your browser." category="MultimediaApplication" features={["Batch-watermark many photos at once", "Text, logo and signature watermark modes", "Live sliders for size, opacity and rotation", "Tile a watermark across the whole image", "Download single photos or the whole batch as PNG"]} />
  <Faq items={faqItems} />

  <script is:inline>
    (function () {
      var images = [], sel = 0, logoImg = null, mode = 'text', talign = 'left', salign = 'left';
      function $(i){return document.getElementById(i);}
      function v(i){var e=$(i);return e?e.value:'';}
      function n(i){var x=parseFloat(v(i));return isFinite(x)?x:0;}
      function on(i){return $(i).classList.contains('on');}

      function place(align, vpos, w, h, blockH, fs){
        var m = Math.min(w,h)*0.04 + fs*0.6;
        var x = align==='left' ? m : align==='right' ? w-m : w/2;
        var y = vpos==='top' ? m+blockH/2 : vpos==='bottom' ? h-m-blockH/2 : h/2;
        return { x:x, y:y };
      }
      function drawText(ctx,w,h,s){
        ctx.save(); ctx.globalAlpha = s.op;
        var fs = Math.max(8, s.size/100*Math.min(w,h));
        ctx.font = (s.italic?'italic ':'')+(s.bold?'700 ':'400 ')+fs+'px '+s.font;
        ctx.fillStyle = s.color; ctx.textBaseline = 'middle'; ctx.textAlign = s.align;
        if(s.shadow){ ctx.shadowColor='rgba(0,0,0,.5)'; ctx.shadowBlur=fs*0.14; ctx.shadowOffsetX=fs*0.05; ctx.shadowOffsetY=fs*0.05; }
        var lines = (s.text||'').split('\n'); var lh = fs*1.25; var blockH = lines.length*lh;
        function block(){ var sy=-(lines.length-1)*lh/2; lines.forEach(function(l,i){ctx.fillText(l,0,sy+i*lh);}); }
        if(s.tile){
          ctx.textAlign='center'; var mw=0; lines.forEach(function(l){mw=Math.max(mw,ctx.measureText(l).width);});
          var sx=mw+fs*1.5, syy=blockH+fs*1.4;
          for(var y=-h;y<h*2;y+=syy) for(var x=-w;x<w*2;x+=sx){ ctx.save();ctx.translate(x,y);ctx.rotate(s.rot*Math.PI/180);block();ctx.restore(); }
        } else {
          var p=place(s.align,s.vpos,w,h,blockH,fs);
          ctx.save();ctx.translate(p.x,p.y);ctx.rotate(s.rot*Math.PI/180);block();ctx.restore();
        }
        ctx.restore();
      }
      function drawLogo(ctx,w,h){
        if(!logoImg)return; ctx.save(); ctx.globalAlpha=n('l_op')/100;
        var lw=n('l_size')/100*w, lh=lw*(logoImg.naturalHeight/logoImg.naturalWidth);
        var p=place(v('l_a'),v('l_v'),w,h,lh,lw*0.2);
        var lx=v('l_a')==='left'?p.x : v('l_a')==='right'?p.x-lw : p.x-lw/2;
        ctx.save();ctx.translate(lx+lw/2,p.y);ctx.rotate(n('l_rot')*Math.PI/180);ctx.drawImage(logoImg,-lw/2,-lh/2,lw,lh);ctx.restore();
        ctx.restore();
      }
      function apply(ctx,w,h){
        if(mode==='text') drawText(ctx,w,h,{text:v('t_text'),font:v('t_font'),bold:on('t_bold'),italic:on('t_italic'),color:v('t_color'),size:n('t_size'),op:n('t_op')/100,rot:n('t_rot'),vpos:v('t_v'),align:talign,shadow:$('t_shadow').checked,tile:$('t_tile').checked});
        else if(mode==='sign') drawText(ctx,w,h,{text:v('s_text'),font:v('s_font'),bold:false,italic:false,color:v('s_color'),size:n('s_size'),op:n('s_op')/100,rot:0,vpos:v('s_v'),align:salign,shadow:false,tile:false});
        else if(mode==='logo') drawLogo(ctx,w,h);
      }
      var clampNoticeShown=false;
      function render(item){
        item = item || images[sel]; if(!item) return;
        ['t_size:t_sizeV:%','t_op:t_opV:%','t_rot:t_rotV:°','l_size:l_sizeV:%','l_op:l_opV:%','l_rot:l_rotV:°','s_size:s_sizeV:%','s_op:s_opV:%'].forEach(function(m){var p=m.split(':');if($(p[0]))$(p[1]).textContent=$(p[0]).value+p[2];});
        var fit=window.SnapJarKit.fitDims(item.img.naturalWidth,item.img.naturalHeight);
        if(fit.clamped && !clampNoticeShown){ clampNoticeShown=true; $('info').textContent='Large image downscaled to fit your device.'; }
        var w=fit.w,h=fit.h,c=$('canvas');
        c.width=w;c.height=h;var ctx=c.getContext('2d');ctx.clearRect(0,0,w,h);ctx.drawImage(item.img,0,0,w,h);apply(ctx,w,h);
        $('info').textContent=(sel+1)+' of '+images.length+' · '+w+'×'+h;
      }
      function thumbs(){
        var t=$('thumbs');t.innerHTML='';
        if(!images.length){t.innerHTML='<span class="thint">Your images appear here →</span>';}
        images.forEach(function(it,i){var im=document.createElement('img');im.src=it.url||it.img.src;im.className=i===sel?'sel':'';im.title=it.name;im.onclick=function(){sel=i;render();thumbs();};t.appendChild(im);});
        $('dlall').hidden=images.length<2;
      }
      function addFiles(files){
        Array.prototype.slice.call(files).filter(function(f){return f.type.indexOf('image/')===0;}).forEach(function(f){
          var url=window.SnapJarKit.track(f);var im=new Image();im.onload=function(){images.push({img:im,name:f.name.replace(/\.[^.]+$/,''),url:url});$('prompt').hidden=true;$('canvas').hidden=false;sel=images.length-1;render();thumbs();};im.onerror=function(){$('info').textContent='Could not open "'+f.name+'" — it may be corrupt or unsupported.';};im.src=url;
        });
      }
      // Encode + download one item, fully, before returning (serialized batch).
      function download(item){
        return new Promise(function(resolve){
          var fit=window.SnapJarKit.fitDims(item.img.naturalWidth,item.img.naturalHeight);
          var c=document.createElement('canvas'),w=fit.w,h=fit.h;c.width=w;c.height=h;
          var ctx=c.getContext('2d');ctx.drawImage(item.img,0,0,w,h);apply(ctx,w,h);
          c.toBlob(function(b){
            if(!b){$('info').textContent='Could not create the image (your device may not support this format).';resolve();return;}
            var a=document.createElement('a');a.href=URL.createObjectURL(b);a.download='watermarked-'+item.name+'.png';a.click();setTimeout(function(){URL.revokeObjectURL(a.href);},1500);resolve();
          },'image/png');
        });
      }

      document.querySelector('.wm-tabs').addEventListener('click',function(e){
        var b=e.target.closest('.wt');if(!b)return;mode=b.dataset.m;
        document.querySelectorAll('.wt').forEach(function(x){x.classList.toggle('on',x===b);});
        document.querySelectorAll('.wm-panel').forEach(function(p){p.hidden=p.dataset.panel!==mode;});
        render();
      });
      ['t_bold','t_italic'].forEach(function(id){$(id).onclick=function(){$(id).classList.toggle('on');render();};});
      document.querySelectorAll('.tg.align[data-a]').forEach(function(b){b.onclick=function(){document.querySelectorAll('.tg.align[data-a]').forEach(function(x){x.classList.remove('on');});b.classList.add('on');talign=b.dataset.a;render();};});
      document.querySelectorAll('.tg.align[data-sa]').forEach(function(b){b.onclick=function(){document.querySelectorAll('.tg.align[data-sa]').forEach(function(x){x.classList.remove('on');});b.classList.add('on');salign=b.dataset.sa;render();};});
      document.querySelectorAll('.wm-panel input,.wm-panel select,.wm-panel textarea').forEach(function(el){
        if(el.id==='l_file')return; el.addEventListener('input',function(){render();});
      });
      $('l_file').onchange=function(e){var f=e.target.files[0];if(!f)return;var im=new Image();im.onload=function(){logoImg=im;render();};im.onerror=function(){$('info').textContent='Could not open that logo image — it may be corrupt or unsupported.';};im.src=URL.createObjectURL(f);};
      $('browse').onclick=function(e){e.stopPropagation();$('file').click();};
      $('dropzone').onclick=function(){ if($('canvas').hidden) $('file').click(); };
      $('file').onchange=function(e){addFiles(e.target.files);};
      ['dragover','dragenter'].forEach(function(ev){$('dropzone').addEventListener(ev,function(e){e.preventDefault();$('dropzone').classList.add('drag');});});
      ['dragleave','drop'].forEach(function(ev){$('dropzone').addEventListener(ev,function(e){e.preventDefault();$('dropzone').classList.remove('drag');});});
      $('dropzone').addEventListener('drop',function(e){addFiles(e.dataTransfer.files);});
      window.SnapJarKit.guard('dl', function(){if(images[sel])return download(images[sel]);});
      // Serialize: encode + download one image fully before the next, yielding between, to avoid OOM from N concurrent full-res encodes.
      window.SnapJarKit.guard('dlall', async function(){
        for(var i=0;i<images.length;i++){ $('info').textContent='Downloading '+(i+1)+' of '+images.length+'…'; await download(images[i]); await window.SnapJarKit.breathe(); }
        $('info').textContent='Done — '+images.length+' image(s) downloaded.';
      });
      $('reset').onclick=function(){images=[];sel=0;logoImg=null;window.SnapJarKit.clear();clampNoticeShown=false;$('l_file').value='';$('file').value='';$('canvas').hidden=true;$('prompt').hidden=false;$('info').textContent='Drop a photo to begin';thumbs();};
    })();
  </script>
</Base>
