---
import Base from '../../layouts/Base.astro';
import Faq from '../../components/Faq.astro';
import HowTo from '../../components/HowTo.astro';
import AppLd from '../../components/AppLd.astro';
const title = 'Merge PDF — Combine & Reorder PDF Files Free (Private, In Browser)';
const description = 'Free PDF merger. Combine multiple PDFs, reorder them with up/down arrows, rotate pages, then download. Nothing is uploaded — your files stay private.';
const faqItems = [
  { q: 'How do I merge multiple PDFs into one file?', a: 'Drop or browse to add two or more PDF files. They appear in a numbered list, and clicking "Merge & download" combines them into a single document in the order shown.' },
  { q: 'Can I change the order of the PDFs before merging?', a: 'Yes. Each file in the list has up and down arrow buttons — use them to move a file earlier or later. The PDFs merge in the exact order displayed, so arrange the list before you merge.' },
  { q: 'How do I remove a file I added by mistake?', a: 'Click the ✕ button next to that file in the list to remove it. The remaining files keep their order, and you can add more files at any time before merging.' },
  { q: 'Can I rotate the pages while merging?', a: 'Yes. Use the "Rotate all pages" option to turn every page 90° right, 180°, or 90° left, which is handy for scans that came in sideways. The rotation applies to all merged pages.' },
  { q: 'Why does merging fail for some PDFs?', a: 'Merging can fail if a file is password-protected or encrypted. Remove the protection from the PDF first, then add it again to merge it.' },
  { q: 'Are my PDF files uploaded or stored anywhere?', a: 'No. The entire merge runs locally in your browser using JavaScript, so your files are never uploaded, stored, or shared. Even confidential documents stay private on your device.' },
];
const howSteps = [
  { name: 'Add your PDFs', text: 'Drop two or more PDF files onto the drop zone, or click "browse" to select them.' },
  { name: 'Reorder the list', text: 'Use the up and down arrows on each file to set the exact sequence you want, and the ✕ button to remove any file.' },
  { name: 'Rotate if needed', text: 'Optionally use the "Rotate all pages" menu to turn every page 90° right, 180°, or 90° left.' },
  { name: 'Merge and download', text: 'Click "Merge & download" to combine the files in the displayed order and save the single merged PDF to your device.' },
];
---
<Base title={title} description={description}>
  <header class="head"><div class="wrap">
    <p class="kicker">PDF Tool</p><h1>Merge PDF</h1>
    <p>Drop in your PDFs, drag-free reorder them with up/down arrows, then merge into one file — right here in your browser.</p>
  </div></header>
  <div class="wrap"><div class="tool wm">
    <div id="drop" class="drop"><input id="file" type="file" accept="application/pdf,.pdf" multiple hidden />
      <div class="drop-ic">📄</div><p class="drop-t">Drop PDF files, or <button id="browse" type="button" class="linklike">browse</button></p>
      <p class="drop-s">Reorder them before merging · 🔒 nothing leaves your device</p></div>
    <div id="editor" hidden>
      <p class="flist-hint">Files merge top to bottom — use the arrows to reorder.</p>
      <ol class="flist" id="flist"></ol>
      <div class="wm-actions" style="margin-bottom:16px"><button id="addmore" type="button" class="wm-btn ghost">+ Add more PDFs</button></div>
      <label class="ctl">Rotate all pages
        <select id="rot"><option value="0" selected>No rotation</option><option value="90">90° right</option><option value="180">180°</option><option value="270">90° left</option></select></label>
      <div class="wm-actions"><button id="merge" type="button" class="wm-btn">⬇ Merge &amp; download</button>
        <button id="reset" type="button" class="wm-btn ghost">Clear</button></div>
      <p id="status" class="status"></p>
    </div>
  </div></div>
  <div class="ad">Advertisement</div>
  <div class="content">
    <h2>How to merge and reorder PDF files</h2>
    <p>Add two or more PDFs and they appear in a numbered list. Use the <b>up and down arrows</b> on each file to set the exact order, or the <b>✕</b> to drop one — the files merge top to bottom in the order shown. You can optionally rotate every page, handy for scans that came in sideways. Click <b>Merge &amp; download</b> to get the combined file.</p>
    <p><b>Your documents never leave your device.</b> The merge happens entirely in your browser, so even confidential PDFs stay private.</p>
    <div class="xlinks"><a href="/">All tools →</a></div>
  </div>
  <HowTo task="merge and reorder PDF files" steps={howSteps} />
  <AppLd name="Merge PDF" description="Drop or browse to add your PDF files, reorder them with up and down arrows, optionally rotate every page, then merge and download the combined file right in your browser." category="BusinessApplication" features={["Drag-and-drop PDF files to combine","Reorder files with up/down arrows before merging","Remove individual files from the list","Merge multiple PDFs in the displayed order","Rotate all pages 90° right, 180°, or 90° left","One-click merge and download","Runs fully in-browser — no uploads"]} />
  <Faq items={faqItems} />
  <style is:global>
    .drop{border:2px dashed var(--line);border-radius:16px;background:var(--surface2);padding:48px 24px;text-align:center;cursor:pointer}
    .drop.drag{border-color:var(--brand)}.drop-ic{font-size:44px;margin-bottom:10px}.drop-t{font-size:17px;font-weight:600}.drop-s{font-size:13px;color:var(--dim);margin-top:8px}
    .linklike{background:none;border:0;color:var(--brand);font:inherit;font-weight:700;cursor:pointer;text-decoration:underline}
    .wm{padding:20px}.flist-hint{font-size:13px;color:var(--dim);margin:0 0 10px 0}
    .flist{margin:0 0 16px 0;padding:0;list-style:none;counter-reset:fl}
    .flist li{display:flex;align-items:center;gap:10px;padding:10px 12px;margin-bottom:8px;background:var(--surface2);border:1px solid var(--line);border-radius:10px}
    .flist li::before{counter-increment:fl;content:counter(fl);flex:0 0 auto;width:24px;height:24px;display:flex;align-items:center;justify-content:center;border-radius:7px;background:var(--bg);color:var(--dim);font-size:12px;font-weight:700}
    .fl-name{flex:1 1 auto;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--txt);font-size:14px;font-weight:600}
    .fl-btns{flex:0 0 auto;display:flex;gap:6px}
    .fl-btn{width:30px;height:30px;display:flex;align-items:center;justify-content:center;border-radius:8px;border:1px solid var(--line);background:var(--bg);color:var(--txt);font:inherit;font-size:14px;font-weight:700;cursor:pointer;line-height:1}
    .fl-btn:hover:not(:disabled){border-color:var(--brand);color:var(--brand)}
    .fl-btn:disabled{opacity:.35;cursor:not-allowed}
    .fl-btn.rm:hover{border-color:#e5484d;color:#e5484d}
    .ctl{display:flex;flex-direction:column;gap:6px;font-size:13px;font-weight:600;color:var(--dim);margin-bottom:16px;max-width:240px}
    .ctl select{background:var(--surface2);border:1px solid var(--line);border-radius:9px;color:var(--txt);font:inherit;font-weight:600;padding:10px 11px}
    .wm-actions{display:flex;gap:10px;flex-wrap:wrap}.wm-btn{padding:12px 18px;border-radius:10px;font-weight:700;color:#fff;border:0;cursor:pointer;background:linear-gradient(135deg,var(--brand2),var(--brand))}
    .wm-btn.ghost{background:var(--surface2);color:var(--dim);border:1px solid var(--line)}.status{margin-top:10px;font-size:13px;color:var(--dim)}
    .status.err{color:#e5484d}
  </style>
  <script>
    import * as PDFLib from 'pdf-lib';
    (function(){
      var files=[];
      function $(i){return document.getElementById(i);}
      function esc(s){return String(s).replace(/[&<>"']/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];});}
      function relist(){
        $('flist').innerHTML=files.map(function(f,i){
          return '<li>'+
            '<span class="fl-name" title="'+esc(f.name)+'">'+esc(f.name)+'</span>'+
            '<span class="fl-btns">'+
              '<button type="button" class="fl-btn" data-up="'+i+'" title="Move up" aria-label="Move up"'+(i===0?' disabled':'')+'>▲</button>'+
              '<button type="button" class="fl-btn" data-down="'+i+'" title="Move down" aria-label="Move down"'+(i===files.length-1?' disabled':'')+'>▼</button>'+
              '<button type="button" class="fl-btn rm" data-rm="'+i+'" title="Remove" aria-label="Remove">✕</button>'+
            '</span>'+
          '</li>';
        }).join('');
      }
      function move(i,d){
        var j=i+d;
        if(j<0||j>=files.length)return;
        var t=files[i];files[i]=files[j];files[j]=t;
        relist();
      }
      function remove(i){
        files.splice(i,1);
        if(!files.length){ $('editor').hidden=true; $('drop').hidden=false; $('status').textContent=''; }
        else relist();
      }
      function add(list){
        Array.prototype.slice.call(list).forEach(function(f){ if(f.type==='application/pdf'||/\.pdf$/i.test(f.name)) files.push(f); });
        if(files.length){$('drop').hidden=true;$('editor').hidden=false;relist();}
      }
      function setStatus(msg,isErr){ var el=$('status'); el.textContent=msg; el.className='status'+(isErr?' err':''); }
      async function merge(){
        if(files.length<1)return;
        if(typeof PDFLib==='undefined'||!PDFLib.PDFDocument){
          setStatus('The PDF engine is still loading (or was blocked). Check your connection, then try again.',true);
          return;
        }
        setStatus('Merging…',false);
        try{
          var out=await PDFLib.PDFDocument.create();
          var deg=parseInt($('rot').value,10);
          for(var i=0;i<files.length;i++){
            var buf=await files[i].arrayBuffer();
            var src=await PDFLib.PDFDocument.load(buf,{ignoreEncryption:true});
            var pages=await out.copyPages(src, src.getPageIndices());
            pages.forEach(function(p){ if(deg){p.setRotation(PDFLib.degrees(deg));} out.addPage(p); });
          }
          var bytes=await out.save();
          var blob=new Blob([bytes],{type:'application/pdf'});
          var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='merged.pdf';a.click();
          setTimeout(function(){URL.revokeObjectURL(a.href);},1500);
          setStatus('Done — '+files.length+' files merged in the order shown.',false);
        }catch(e){ setStatus('Could not merge (a file may be password-protected).',true); }
      }
      $('browse').onclick=function(){$('file').click();};
      $('addmore').onclick=function(){$('file').click();};
      $('drop').onclick=function(e){if(e.target.id==='drop'||e.target.className.indexOf('drop-')===0)$('file').click();};
      $('file').onchange=function(e){add(e.target.files);e.target.value='';};
      $('flist').addEventListener('click',function(e){
        var b=e.target.closest('button');
        if(!b)return;
        if(b.hasAttribute('data-up'))move(parseInt(b.getAttribute('data-up'),10),-1);
        else if(b.hasAttribute('data-down'))move(parseInt(b.getAttribute('data-down'),10),1);
        else if(b.hasAttribute('data-rm'))remove(parseInt(b.getAttribute('data-rm'),10));
      });
      ['dragover','dragenter'].forEach(function(ev){$('drop').addEventListener(ev,function(e){e.preventDefault();$('drop').classList.add('drag');});});
      ['dragleave','drop'].forEach(function(ev){$('drop').addEventListener(ev,function(e){e.preventDefault();$('drop').classList.remove('drag');});});
      $('drop').addEventListener('drop',function(e){add(e.dataTransfer.files);});
      $('merge').onclick=merge;
      $('reset').onclick=function(){files=[];$('flist').innerHTML='';$('file').value='';setStatus('',false);$('editor').hidden=true;$('drop').hidden=false;};
    })();
  </script>
</Base>
