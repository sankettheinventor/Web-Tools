---
import Base from '../../layouts/Base.astro';
const title = 'Merge PDF — Combine PDF Files Free (Private, In Browser)';
const description = 'Free PDF merger. Combine multiple PDF files into one in your browser, optionally rotating pages, then download. Nothing is uploaded — your documents stay private.';
---
<Base title={title} description={description}>
  <Fragment slot="head">
    <script is:inline src="https://cdn.jsdelivr.net/npm/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>
  </Fragment>
  <header class="head"><div class="wrap">
    <p class="kicker">PDF Tool</p><h1>Merge PDF</h1>
    <p>Combine several PDFs into one — in your browser, never uploaded.</p>
  </div></header>
  <div class="wrap"><div class="tool wm">
    <div id="drop" class="drop"><input id="file" type="file" accept="application/pdf,.pdf" multiple hidden />
      <div class="drop-ic">📄</div><p class="drop-t">Drop PDF files, or <button id="browse" type="button" class="linklike">browse</button></p>
      <p class="drop-s">They merge in the order added · 🔒 nothing leaves your device</p></div>
    <div id="editor" hidden>
      <ol class="flist" id="flist"></ol>
      <label class="ctl">Rotate all pages
        <select id="rot"><option value="0" selected>No rotation</option><option value="90">90° right</option><option value="180">180°</option><option value="270">90° left</option></select></label>
      <div class="wm-actions"><button id="merge" type="button" class="wm-btn">⬇ Merge &amp; download</button>
        <button id="reset" type="button" class="wm-btn ghost">Clear</button></div>
      <p id="status" class="status"></p>
    </div>
  </div></div>
  <div class="ad">Ad space</div>
  <div class="content">
    <h2>How to merge PDF files</h2>
    <p>Add two or more PDFs, and they'll be combined into a single document in the order you added them. You can optionally rotate every page — handy for scans that came in sideways. Click <b>Merge &amp; download</b> to get the combined file.</p>
    <p><b>Your documents never leave your device.</b> The merge happens entirely in your browser, so even confidential PDFs stay private.</p>
    <div class="xlinks"><a href="/">All tools →</a></div>
  </div>
  <style>
    .drop{border:2px dashed var(--line);border-radius:16px;background:var(--surface2);padding:48px 24px;text-align:center;cursor:pointer}
    .drop.drag{border-color:var(--brand)}.drop-ic{font-size:44px;margin-bottom:10px}.drop-t{font-size:17px;font-weight:600}.drop-s{font-size:13px;color:var(--dim);margin-top:8px}
    .linklike{background:none;border:0;color:var(--brand);font:inherit;font-weight:700;cursor:pointer;text-decoration:underline}
    .wm{padding:20px}.flist{margin:0 0 16px 0;padding-left:22px}.flist li{padding:6px 0;color:var(--txt);font-size:14px;font-weight:600}
    .ctl{display:flex;flex-direction:column;gap:6px;font-size:13px;font-weight:600;color:var(--dim);margin-bottom:16px;max-width:240px}
    .ctl select{background:var(--surface2);border:1px solid var(--line);border-radius:9px;color:var(--txt);font:inherit;font-weight:600;padding:10px 11px}
    .wm-actions{display:flex;gap:10px}.wm-btn{padding:12px 18px;border-radius:10px;font-weight:700;color:#fff;border:0;cursor:pointer;background:linear-gradient(135deg,var(--brand2),var(--brand))}
    .wm-btn.ghost{background:var(--surface2);color:var(--dim);border:1px solid var(--line)}.status{margin-top:10px;font-size:13px;color:var(--dim)}
  </style>
  <script is:inline>
    (function(){
      var files=[];
      function $(i){return document.getElementById(i);}
      function relist(){$('flist').innerHTML=files.map(function(f){return '<li>'+f.name+'</li>';}).join('');}
      function add(list){
        Array.prototype.slice.call(list).forEach(function(f){ if(f.type==='application/pdf'||/\.pdf$/i.test(f.name)) files.push(f); });
        if(files.length){$('drop').hidden=true;$('editor').hidden=false;relist();}
      }
      async function merge(){
        if(files.length<1)return;
        $('status').textContent='Merging…';
        try{
          var out=await PDFLib.PDFDocument.create();
          var deg=parseInt($('rot').value,10);
          for(var i=0;i<files.length;i++){
            var buf=await files[i].arrayBuffer();
            var src=await PDFLib.PDFDocument.load(buf,{ignoreEncryption:true});
            var pages=await out.copyPages(src, src.getPageIndices());
            pages.forEach(function(p){ if(deg){p.setRotation(PDFLib.degrees(deg));} out.addPage(p); });
          }
          var bytes=await out.save();
          var blob=new Blob([bytes],{type:'application/pdf'});
          var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='merged.pdf';a.click();
          setTimeout(function(){URL.revokeObjectURL(a.href);},1500);
          $('status').textContent='Done — '+files.length+' files merged.';
        }catch(e){ $('status').textContent='Could not merge (a file may be password-protected).'; }
      }
      $('browse').onclick=function(){$('file').click();};
      $('drop').onclick=function(e){if(e.target.id==='drop'||e.target.className.indexOf('drop-')===0)$('file').click();};
      $('file').onchange=function(e){add(e.target.files);};
      ['dragover','dragenter'].forEach(function(ev){$('drop').addEventListener(ev,function(e){e.preventDefault();$('drop').classList.add('drag');});});
      ['dragleave','drop'].forEach(function(ev){$('drop').addEventListener(ev,function(e){e.preventDefault();$('drop').classList.remove('drag');});});
      $('drop').addEventListener('drop',function(e){add(e.dataTransfer.files);});
      $('merge').onclick=merge;
      $('reset').onclick=function(){files=[];$('flist').innerHTML='';$('file').value='';$('status').textContent='';$('editor').hidden=true;$('drop').hidden=false;};
    })();
  </script>
</Base>
