---
import Base from '../../layouts/Base.astro';
import Faq from '../../components/Faq.astro';
import AppLd from '../../components/AppLd.astro';
const title = 'PDF Editor — Create, Edit, Sign & Read PDFs (Free, Private)';
const description = 'Create PDFs from scratch or photos, then add titles, text, images and diagrams, sign, rotate, reorder and delete pages — plus read, search and copy. Everything stays on your device. Nothing is uploaded.';
const faqItems = [
  { q: 'Can I create a PDF from scratch?', a: 'Yes. Start a new PDF, then add pages, a title, text boxes, images and simple diagrams (boxes, lines, ovals). Export when you are done — all on your device.' },
  { q: 'Can I edit a PDF I already have?', a: 'Yes. Open any PDF and add new pages, titles, text, images, signatures and shapes on top of it, then reorder, rotate or delete pages and export the result. The original baked-in text stays as it is; you layer your edits on top.' },
  { q: 'Can I copy text and search inside a PDF?', a: 'Yes. The reader builds a real text layer over every page, so you can select and copy text, and search inside the document to jump to each match.' },
  { q: 'Is my PDF uploaded anywhere?', a: 'No. Everything — opening, editing and exporting — happens entirely on your device with JavaScript. Your files are never uploaded, stored or shared.' },
];
---
<Base title={title} description={description}>
  <div class="pr" id="pr">
    <!-- OPEN SCREEN -->
    <div class="pr-open" id="prOpen">
      <header class="head"><div class="wrap">
        <h1>PDF Editor</h1>
        <p>Create, edit and sign PDFs — privately, on your device.</p>
      </div></header>
      <div class="wrap"><div class="tool">
        <div id="prDrop" class="drop" role="button" tabindex="0" aria-label="Open a document">
          <input id="prFile" type="file" accept="application/pdf,.pdf,.doc,.docx,.xls,.xlsx" hidden />
          <input id="prImg" type="file" accept="image/*" multiple hidden />
          <div class="drop-ic">📂</div>
          <p class="drop-t">Open a document</p>
          <p class="drop-s">Files · Google Drive · any storage · Scan</p></div>
        <button id="prNew" class="pr-new" type="button"><span class="pr-new-ic">✎</span> Create a new PDF</button>
        <p id="prStatus" class="status" role="status" aria-live="polite"></p>
      </div></div>

      <!-- source chooser sheet -->
      <div class="pr-sheet" id="prSheet" hidden>
        <div class="pr-sheet-card" role="dialog" aria-modal="true" aria-label="Open a document">
          <div class="pr-sheet-h">Open a document</div>
          <button class="pr-src" id="srcDoc" type="button"><span class="pr-src-ic">📁</span><span class="pr-src-tx"><b>Open a PDF</b><small>Pick any PDF — incl. Google Drive &amp; Downloads</small></span></button>
          <button class="pr-src" id="srcFolder" type="button"><span class="pr-src-ic">🗂️</span><span class="pr-src-tx"><b>Browse a folder</b><small>Grant a folder and open any PDF inside it</small></span></button>
          <button class="pr-src" id="srcGallery" type="button"><span class="pr-src-ic">🖼️</span><span class="pr-src-tx"><b>Photos → PDF</b><small>Pick images and combine into a PDF</small></span></button>
          <button class="pr-src" id="srcScan" type="button"><span class="pr-src-ic">📷</span><span class="pr-src-tx"><b>Scan document</b><small>Use the camera to scan to PDF</small></span></button>
          <button class="pr-src" id="srcOcr" type="button"><span class="pr-src-ic">🔤</span><span class="pr-src-tx"><b>Scan to text (OCR)</b><small>Extract editable text from a photo</small></span></button>
          <button class="pr-sheet-close" id="prSheetClose" type="button">Cancel</button>
        </div>
      </div>

      <!-- folder PDFs (Storage Access Framework — Play-safe, no broad permission) -->
      <div class="pr-sheet" id="prFolder" hidden>
        <div class="pr-sheet-card" role="dialog" aria-modal="true" aria-label="PDFs in folder">
          <div class="pr-folder-top">
            <div class="pr-sheet-h" id="prFolderName">Folder</div>
            <button class="pr-folder-change" id="prFolderChange" type="button">Change folder</button>
          </div>
          <div id="prFolderList" class="pr-folder-list"></div>
          <button class="pr-sheet-close" id="prFolderClose" type="button">Close</button>
        </div>
      </div>
    </div>

    <!-- READER (immersive: full-bleed page, right rail + bottom bar, auto-hiding) -->
    <div class="pr-main" id="prMain" hidden>
      <div class="pr-doc" id="prDoc"></div>

      <!-- right floating quick-action rail -->
      <div class="pr-rail" id="prRail">
        <button id="prMode" class="pr-fab" type="button" title="Reading theme" aria-label="Reading theme &amp; brightness"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 3v18a9 9 0 0 0 0-18Z" fill="currentColor" stroke="none"/></svg></button>
        <button id="prListen" class="pr-fab pr-fab-listen" type="button" title="Listen — read aloud" aria-label="Listen — read this document aloud"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14v-2a8 8 0 0 1 16 0v2"/><rect x="2.5" y="13.5" width="4.5" height="7" rx="1.6"/><rect x="17" y="13.5" width="4.5" height="7" rx="1.6"/></svg></button>
        <button id="prEditBtn" class="pr-fab pr-fab-edit" type="button" title="Edit PDF" aria-label="Edit this PDF"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg></button>
      </div>

      <!-- search (floats just above the reader bar) -->
      <div class="pr-find" id="prFind" hidden>
        <input id="prQuery" type="search" placeholder="Search in document…" aria-label="Search text" autocomplete="off" />
        <span id="prMatch" class="pr-match"></span>
        <button id="prPrev" class="pr-btn" type="button" aria-label="Previous match">↑</button>
        <button id="prNext" class="pr-btn" type="button" aria-label="Next match">↓</button>
        <button id="prFindClose" class="pr-btn" type="button" aria-label="Close search">✕</button>
      </div>

      <!-- bottom reader control bar -->
      <div class="pr-rbar" id="prRbar">
        <button id="prJump" class="pr-rb pr-rb-page" type="button" aria-label="Pages — tap for thumbnails"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pr-pi-ic"><rect x="3" y="3" width="7" height="7" rx="1.4"/><rect x="14" y="3" width="7" height="7" rx="1.4"/><rect x="3" y="14" width="7" height="7" rx="1.4"/><rect x="14" y="14" width="7" height="7" rx="1.4"/></svg><span id="prCur">1</span>/<span id="prTot">1</span></button>
        <span class="pr-rb-zoom">
          <button id="prOut" class="pr-rb" type="button" title="Zoom out" aria-label="Zoom out"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14"/></svg></button>
          <button id="prFit" class="pr-rb pr-zoom" type="button" title="Fit width" aria-label="Fit width"><span id="prZoom">100%</span></button>
          <button id="prIn" class="pr-rb" type="button" title="Zoom in" aria-label="Zoom in"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></button>
        </span>
        <span class="pr-spacer"></span>
        <button id="prShare" class="pr-rb" type="button" title="Share / Save" aria-label="Share or save this PDF"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v7a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-7"/><path d="M12 16V4M8 8l4-4 4 4"/></svg></button>
        <button id="prMore" class="pr-rb" type="button" title="More" aria-label="More options"><svg viewBox="0 0 24 24" fill="currentColor"><circle cx="5" cy="12" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="19" cy="12" r="2"/></svg></button>
      </div>

      <!-- More — dropdown popover (opens upward from the bar) -->
      <div class="pr-menu" id="prMoreSheet" role="menu" aria-label="More" hidden>
        <button class="pr-mi" id="prFindBtn" type="button" role="menuitem"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg><span>Search in document</span></button>
        <button class="pr-mi" id="prOpenNew" type="button" role="menuitem"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 0 1 2-2h3.4a2 2 0 0 1 1.6.8l.9 1.2a2 2 0 0 0 1.6.8H19a2 2 0 0 1 2 2"/><path d="M3.3 10h17.4a1 1 0 0 1 .98 1.2l-1.3 6.4a1 1 0 0 1-.98.8H4.6a1 1 0 0 1-.98-.8l-1.3-6.4A1 1 0 0 1 3.3 10Z"/></svg><span>Open another PDF</span></button>
        <button class="pr-mi" id="prNotes" type="button" role="menuitem"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3h10l4 4v14H5Z"/><path d="M15 3v4h4M9 12h6M9 16h4"/></svg><span>Notes</span><span id="prNotesBadge" class="pr-badge pr-badge-row" hidden></span></button>
        <button class="pr-mi" id="prSplit" type="button" role="menuitem"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="2.6"/><circle cx="6" cy="18" r="2.6"/><path d="M8.1 7.6 20 18M8.1 16.4 20 6"/></svg><span>Split into pages</span></button>
      </div>
    </div>

    <!-- EDITOR (immersive overlay) -->
    <div class="ed" id="prEdit" hidden>
      <div class="ed-top">
        <button id="edClose" class="ed-x" type="button" aria-label="Close editor">✕</button>
        <span class="ed-page-ind"><span id="edCur">1</span> / <span id="edTot">1</span></span>
        <span class="pr-spacer"></span>
        <button id="edSave" class="ed-save" type="button">Save &amp; share</button>
      </div>
      <div class="pr-doc ed-doc" id="edDoc"></div>
      <div class="ed-tools" id="edTools">
        <button class="ed-tool" data-tool="page" type="button"><span class="ed-ti">＋</span><span>Page</span></button>
        <button class="ed-tool" data-tool="title" type="button"><span class="ed-ti">T</span><span>Title</span></button>
        <button class="ed-tool" data-tool="text" type="button"><span class="ed-ti ed-ti-sm">T</span><span>Text</span></button>
        <button class="ed-tool" data-tool="image" type="button"><span class="ed-ti">🖼️</span><span>Image</span></button>
        <button class="ed-tool" data-tool="sign" type="button"><span class="ed-ti">✍️</span><span>Sign</span></button>
        <button class="ed-tool" data-tool="rect" type="button"><span class="ed-ti">▭</span><span>Box</span></button>
        <button class="ed-tool" data-tool="line" type="button"><span class="ed-ti">╱</span><span>Line</span></button>
        <button class="ed-tool" data-tool="ellipse" type="button"><span class="ed-ti">◯</span><span>Oval</span></button>
        <button class="ed-tool" data-tool="rotate" type="button"><span class="ed-ti">⟳</span><span>Rotate</span></button>
        <button class="ed-tool ed-danger" data-tool="delpage" type="button"><span class="ed-ti">🗑️</span><span>Delete</span></button>
      </div>
      <input id="edImg" type="file" accept="image/*" hidden />
    </div>

    <!-- WRITE (full-screen writing surface → paginated PDF) -->
    <div class="wr" id="prWrite" hidden>
      <div class="wr-top">
        <button id="wrClose" class="wr-x" type="button" aria-label="Close">✕</button>
        <span class="wr-count" id="wrCount">0 words</span>
        <span class="pr-spacer"></span>
        <button id="wrDone" class="wr-done" type="button">Done</button>
      </div>
      <div class="wr-scroll" id="wrScroll">
        <div class="wr-page">
          <div id="wrTitle" class="wr-title" contenteditable="true" data-ph="Title" role="textbox" aria-label="Document title"></div>
          <div id="wrBody" class="wr-body" contenteditable="true" role="textbox" aria-multiline="true" data-ph="Start writing, or paste from anywhere…"></div>
        </div>
      </div>
      <div class="wr-colors" id="wrColors" hidden></div>
      <div class="wr-bar" id="wrBar">
        <div class="wr-tools">
          <button class="wr-tool wr-style" id="wrCustomize" type="button" title="Document style"><span style="font-weight:800">Aa</span> Style</button>
          <span class="wr-sep"></span>
          <button class="wr-tool" data-cmd="bold" type="button" title="Bold" style="font-weight:800">B</button>
          <button class="wr-tool" data-cmd="italic" type="button" title="Italic" style="font-style:italic;font-family:Georgia,serif">I</button>
          <button class="wr-tool" data-cmd="underline" type="button" title="Underline" style="text-decoration:underline">U</button>
          <button class="wr-tool" id="wrColor" type="button" title="Text colour"><span class="wr-cdot" id="wrCdot"></span></button>
          <span class="wr-sep"></span>
          <button class="wr-tool" id="wrH" type="button" title="Heading">H</button>
          <button class="wr-tool" data-cmd="insertUnorderedList" type="button" title="Bullet list">&#9679;&#8202;&#8202;</button>
          <button class="wr-tool" id="wrQuote" type="button" title="Quote">&#10077;</button>
          <span class="wr-sep"></span>
          <button class="wr-tool wr-ins" id="wrInsImg" type="button" title="Insert image">&#128443;&#65039;</button>
          <button class="wr-tool wr-ins" id="wrInsDraw" type="button" title="Draw">&#9998;</button>
          <button class="wr-tool wr-ins" id="wrInsTable" type="button" title="Insert table">&#9638;</button>
          <button class="wr-tool" id="wrRow" type="button" title="Add table row">+Row</button>
          <button class="wr-tool" id="wrCol" type="button" title="Add table column">+Col</button>
          <button class="wr-tool wr-ins" id="wrInsScan" type="button" title="Scan text">&#128247;</button>
        </div>
      </div>
      <input id="wrImg" type="file" accept="image/*" hidden />
      <input id="wrOcr" type="file" accept="image/*" hidden />

      <!-- drawing overlay -->
      <div class="wr-draw" id="wrDraw" hidden>
        <div class="wr-draw-top">
          <button class="wr-x" id="wrDrawCancel" type="button" aria-label="Cancel">✕</button>
          <span class="wr-draw-h">Draw</span>
          <span class="pr-spacer"></span>
          <button class="wr-tool" id="wrDrawUndo" type="button" title="Undo">&#8630;</button>
          <button class="wr-tool" id="wrDrawClear" type="button" title="Clear">Clear</button>
          <button class="wr-done" id="wrDrawInsert" type="button">Insert</button>
        </div>
        <canvas id="wrDrawCanvas" class="wr-draw-canvas"></canvas>
        <div class="wr-draw-bar">
          <span class="wr-swatch on" data-c="#15131c" style="background:#15131c"></span>
          <span class="wr-swatch" data-c="#7c5cff" style="background:#7c5cff"></span>
          <span class="wr-swatch" data-c="#e5484d" style="background:#e5484d"></span>
          <span class="wr-swatch" data-c="#2bb673" style="background:#2bb673"></span>
          <span class="wr-swatch" data-c="#3a8cff" style="background:#3a8cff"></span>
          <span class="wr-swatch" data-c="#e0a23a" style="background:#e0a23a"></span>
          <span class="pr-spacer"></span>
          <input id="wrPen" type="range" min="1" max="14" value="3" class="wr-pen" aria-label="Pen size" />
        </div>
      </div>
    </div>
  </div>

  <!-- QR scanner: capture a photo of a QR → decode on-device -->
  <input id="prQrIn" type="file" accept="image/*" capture="environment" hidden />
  <div class="pr-sheet" id="prQrRes" hidden>
    <div class="pr-sheet-card" role="dialog" aria-modal="true" aria-label="QR result">
      <div class="pr-sheet-h">QR result</div>
      <div id="prQrText" class="qr-res-text"></div>
      <button class="pr-src" id="prQrOpen" type="button" hidden><span class="pr-src-ic">🔗</span><span class="pr-src-tx"><b>Open link</b></span></button>
      <button class="pr-src" id="prQrCopy" type="button"><span class="pr-src-ic">📋</span><span class="pr-src-tx"><b>Copy</b></span></button>
      <button class="pr-src" id="prQrAgain" type="button"><span class="pr-src-ic">📷</span><span class="pr-src-tx"><b>Scan again</b></span></button>
      <button class="pr-sheet-close" id="prQrClose" type="button">Close</button>
    </div>
  </div>

  <!-- custom scan filter screen (Original/Grey/B&W/Darken/Lighten — live previews on the actual page) -->
  <input id="fxIn" type="file" accept="image/*" capture="environment" hidden />
  <div class="fx" id="prFilter" hidden>
    <div class="fx-top">
      <button class="fx-x" id="fxClose" type="button" aria-label="Cancel">✕</button>
      <span class="fx-h">Review scan</span>
      <span class="pr-spacer"></span>
    </div>
    <div class="fx-stage" id="fxStage"><canvas id="fxCanvas" class="fx-canvas"></canvas></div>
    <div class="fx-strip" id="fxStrip"></div>
    <div class="fx-actions">
      <button class="fx-retake" id="fxRetake" type="button"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 3-6.7L3 8"/><path d="M3 4v4h4"/></svg> Retake</button>
      <button class="fx-use" id="fxApply" type="button"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg> Use scan</button>
    </div>
  </div>

  <!-- premium share sheet -->
  <div class="pr-sheet" id="prShareSheet" hidden>
    <div class="pr-sheet-card" role="dialog" aria-modal="true" aria-label="Share PDF">
      <div class="pr-share-prev">
        <div class="pr-share-thumb"><img id="prShareThumb" alt="" /><svg id="prShareThumbPh" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M7 3h7l4 4v13a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Z"/><path d="M14 3v4h4"/></svg></div>
        <div class="pr-share-meta"><b id="prShareName">Document.pdf</b><small id="prShareSize">PDF</small></div>
        <button class="pr-share-x" id="prShareClose" type="button" aria-label="Close">✕</button>
      </div>
      <div class="pr-sa-grid">
        <button class="pr-sa" id="prShareGo" type="button"><span class="pr-sa-ic sa-share"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 14V3"/><path d="m8 7 4-4 4 4"/><path d="M5 12v7a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-7"/></svg></span><span class="pr-sa-l">Share</span></button>
        <button class="pr-sa" id="prShareFiles" type="button"><span class="pr-sa-ic sa-files"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7.5A1.5 1.5 0 0 1 4.5 6h4l2 2.2h7A1.5 1.5 0 0 1 19 9.7v7.8A1.5 1.5 0 0 1 17.5 19h-13A1.5 1.5 0 0 1 3 17.5v-10Z"/></svg></span><span class="pr-sa-l">My Files</span></button>
        <button class="pr-sa" id="prShareSave" type="button"><span class="pr-sa-ic sa-save"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v11"/><path d="m8 11 4 4 4-4"/><path d="M5 20h14"/></svg></span><span class="pr-sa-l">Save</span></button>
        <button class="pr-sa" id="prSharePrint" type="button"><span class="pr-sa-ic sa-print"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9V3h12v6"/><rect x="4" y="9" width="16" height="8" rx="2"/><path d="M8 15h8v6H8z"/></svg></span><span class="pr-sa-l">Print</span></button>
      </div>
    </div>
  </div>

  <!-- LISTEN — read-aloud player (offline, on-device voices) -->
  <div class="tts" id="ttsBar" hidden>
    <div class="tts-now" id="ttsNow" role="status" aria-live="polite"></div>
    <div class="tts-row">
      <button class="tts-chip" id="ttsRate" type="button" aria-label="Reading speed">1×</button>
      <button class="tts-b" id="ttsPrev" type="button" aria-label="Previous sentence"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M7 6a1 1 0 0 1 2 0v12a1 1 0 0 1-2 0Zm11.5-.43a1 1 0 0 1 1.5.87v11.12a1 1 0 0 1-1.5.87l-9.2-5.56a1 1 0 0 1 0-1.74Z"/></svg></button>
      <button class="tts-b tts-play" id="ttsPlay" type="button" aria-label="Play"></button>
      <button class="tts-b" id="ttsNext" type="button" aria-label="Next sentence"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M17 6a1 1 0 0 0-2 0v12a1 1 0 0 0 2 0Zm-11.5-.43a1 1 0 0 0-1.5.87v11.12a1 1 0 0 0 1.5.87l9.2-5.56a1 1 0 0 0 0-1.74Z"/></svg></button>
      <button class="tts-chip" id="ttsVoice" type="button" aria-label="Choose voice"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a3 3 0 0 1 3 3v6a3 3 0 0 1-6 0V6a3 3 0 0 1 3-3Z"/><path d="M5 11a7 7 0 0 0 14 0M12 18v3"/></svg></button>
      <button class="tts-b" id="ttsClose" type="button" aria-label="Stop reading"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M6 6 18 18M18 6 6 18"/></svg></button>
    </div>
  </div>

  <!-- voice picker -->
  <div class="pr-sheet" id="ttsVoiceSheet" hidden>
    <div class="pr-sheet-card" role="dialog" aria-modal="true" aria-label="Choose a voice">
      <div class="pr-sheet-h">Choose a voice · on-device</div>
      <input id="ttsVFilter" type="search" class="tts-vfilter" placeholder="Filter — e.g. Hindi, India, English…" aria-label="Filter voices" autocomplete="off" />
      <div class="tts-vlist" id="ttsVlist"></div>
      <button class="tts-getvoices" id="ttsGetVoices" type="button"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>Get more voices — Indian, Hindi &amp; more</button>
      <button class="pr-sheet-close" id="ttsVoiceClose" type="button">Done</button>
    </div>
  </div>

  <!-- reading comfort (theme + brightness) -->
  <div class="pr-sheet" id="prComfort" hidden>
    <div class="pr-sheet-card" role="dialog" aria-modal="true" aria-label="Reading comfort">
