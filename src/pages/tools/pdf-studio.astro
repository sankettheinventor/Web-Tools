  <!-- internet needed (premium prompt for the few online features) -->
  <div class="pr-sheet" id="sjNetSheet" hidden>
    <div class="pr-sheet-card" role="dialog" aria-modal="true" aria-label="Internet needed">
      <div class="sjnet-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14 0"/><path d="M1.5 8.5a16 16 0 0 1 21 0"/><path d="M8.5 16.4a6 6 0 0 1 7 0"/><circle cx="12" cy="20" r="1" fill="currentColor"/></svg></div>
      <div class="sjnet-h">Turn on the internet</div>
