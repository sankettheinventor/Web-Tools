          var b = document.createElement('button'); b.type = 'button'; b.className = 'tts-v' + (TTS.voiceObj && v.voiceURI === TTS.voiceObj.voiceURI ? ' on' : '');
          b.innerHTML = '<span class="tts-v-tx"><b></b><small></small></span><span class="tts-v-ck">✓</span>';
          b.querySelector('b').textContent = v.name || v.voiceURI || 'Voice';
          b.querySelector('small').textContent = (v.localService === false ? 'needs network' : 'on-device');
          b.onclick = function (){
            TTS.voiceObj = v; TTS.voiceIndex = (v._idx != null ? v._idx : -1); TTS.lang = v.lang || 'en-US'; TTS.userPicked = true;
            try { localStorage.setItem('sj_tts_voice', v.voiceURI); } catch (e) {}
            list.querySelectorAll('.tts-v').forEach(function (x){ x.classList.remove('on'); }); b.classList.add('on');
            ttsRestart();
          };
          list.appendChild(b);
        });
      }
      function ttsOpenVoices(){
        ttsLoadVoices().then(function (){ ttsRenderVoices($('ttsVFilter') ? $('ttsVFilter').value : ''); $('ttsVoiceSheet').hidden = false; });
      }
      $('ttsVoice').onclick = ttsOpenVoices;
      if ($('ttsVFilter')) $('ttsVFilter').addEventListener('input', function (){ ttsRenderVoices(this.value); });
      $('ttsVoiceClose').onclick = function (){ $('ttsVoiceSheet').hidden = true; };
      $('ttsVoiceSheet').onclick = function (e){ if (e.target === $('ttsVoiceSheet')) $('ttsVoiceSheet').hidden = true; };
      /* one-tap install of free offline voices (Indian English, Hindi & many Indian languages)
         from inside the app — no digging through Android Settings. Works offline after download. */
      $('ttsGetVoices').onclick = function (){
        function go(){
          TTS.voicesLoaded = false;
          if (TTSP && TTSP.openInstall){ TTSP.openInstall().catch(function (){}); if (window.SnapJarKit) window.SnapJarKit.toast('Pick English (India), Hindi or any language to download — it works offline after.', 'info', 6000); }
          else if (window.SnapJarKit) window.SnapJarKit.toast('Voice download is available in the SnapJar app.', 'info');
        }
        if (window.__requireNet) window.__requireNet(go); else go();   // downloading voices needs internet
      };
      /* coming back from the installer (or any app switch) → refresh the available voices */
      document.addEventListener('visibilitychange', function (){ if (!document.hidden){ TTS.voicesLoaded = false; ttsLoadVoices(); } });
      window.addEventListener('pagehide', function (){ ttsStopEngine(); });

      /* ===================== READING COMFORT (theme + brightness, persisted) ===================== */
      (function (){
        var bright = 1;
        try { var sb = localStorage.getItem('sj_pr_bright'); if (sb) bright = +sb || 1; } catch (e) {}
        try { var sm = localStorage.getItem('sj_pr_theme'); if (sm !== null && sm !== undefined){ var mi = modes.indexOf(sm); if (mi >= 0) modeI = mi; } } catch (e) {}
        function applyTheme(){ var d = $('prDoc'); d.classList.remove('sepia', 'night'); if (modes[modeI]) d.classList.add(modes[modeI]); $('cfTheme').querySelectorAll('button').forEach(function (b){ b.classList.toggle('on', b.getAttribute('data-m') === modes[modeI]); }); }
        function applyBright(){ $('prDoc').style.setProperty('--pr-bright', bright); var s = $('cfBright'); if (s) s.value = Math.round(bright * 100); var l = $('cfBrightVal'); if (l) l.textContent = Math.round(bright * 100) + '%'; }
        $('prMode').onclick = function (){ if (!doc) return; applyTheme(); applyBright(); $('prComfort').hidden = false; };
        $('cfTheme').querySelectorAll('button').forEach(function (b){ b.onclick = function (){ var mi = modes.indexOf(b.getAttribute('data-m')); modeI = mi >= 0 ? mi : 0; try { localStorage.setItem('sj_pr_theme', modes[modeI]); } catch (e) {} applyTheme(); }; });
        $('cfBright').oninput = function (){ bright = Math.max(0.5, Math.min(1.6, (+$('cfBright').value || 100) / 100)); try { localStorage.setItem('sj_pr_bright', String(bright)); } catch (e) {} applyBright(); };
        $('cfClose').onclick = function (){ $('prComfort').hidden = true; };
        $('prComfort').onclick = function (e){ if (e.target === $('prComfort')) $('prComfort').hidden = true; };
        applyTheme(); applyBright();
      })();

      /* ===================== NOTES (on-device, per document) ===================== */
      (function (){
        function key(){ return curName || 'Document.pdf'; }
        function load(){ try { return JSON.parse(localStorage.getItem('sj_notes') || '{}'); } catch (e) { return {}; } }
        function save(all){ try { localStorage.setItem('sj_notes', JSON.stringify(all)); } catch (e) {} }
        function notesFor(){ var all = load(); return all[key()] || []; }
        function setNotes(arr){ var all = load(); if (arr.length) all[key()] = arr; else delete all[key()]; save(all); }
        function badge(){ var b = $('prNotesBadge'); if (!b) return; var n = notesFor().length; if (n){ b.textContent = n > 99 ? '99+' : n; b.hidden = false; } else b.hidden = true; }
        window.__notesBadge = badge;
        function render(){
          var list = $('ntList'), arr = notesFor(); list.innerHTML = '';
          if (!arr.length){ list.innerHTML = '<p class="nt-empty">No notes yet. Jot something below — it’s saved on this device and tied to this document.</p>'; return; }
          arr.slice().reverse().forEach(function (it){
            var d = document.createElement('div'); d.className = 'nt-item';
            d.innerHTML = '<div class="nt-item-top"><button class="nt-item-pg" type="button">Page ' + (it.page || 1) + '</button><button class="nt-item-del" type="button" aria-label="Delete note">🗑️</button></div><div class="nt-item-tx"></div>';
            d.querySelector('.nt-item-tx').textContent = it.text;
            d.querySelector('.nt-item-pg').onclick = function (){ var el = pageEls[(it.page || 1) - 1]; if (el){ el.scrollIntoView({ block: 'start' }); curPage = it.page || 1; updateInd(); } $('prNotesSheet').hidden = true; };
            d.querySelector('.nt-item-del').onclick = function (){ setNotes(notesFor().filter(function (x){ return x.id !== it.id; })); render(); badge(); };
            list.appendChild(d);
          });
        }
        $('prNotes').onclick = function (){ if (!doc){ if (window.SnapJarKit) window.SnapJarKit.toast('Open a document first', 'info'); return; } render(); $('prNotesSheet').hidden = false; setTimeout(function (){ $('ntAdd').focus(); }, 120); };
        $('ntSave').onclick = function (){
          var t = ($('ntAdd').value || '').trim(); if (!t) return;
          var arr = notesFor(); arr.push({ id: 'n' + Date.now(), text: t, page: curPage || 1 });
          setNotes(arr); $('ntAdd').value = ''; render(); badge();
          if (window.SnapJarKit) window.SnapJarKit.toast('Note saved', 'ok');
        };
        $('ntClose').onclick = function (){ $('prNotesSheet').hidden = true; };
        $('prNotesSheet').onclick = function (e){ if (e.target === $('prNotesSheet')) $('prNotesSheet').hidden = true; };
      })();

      /* ===================== PASTE into the writer (images / links / tables / rich HTML) ===================== */
      (function (){
        function sanitize(html){
          var tmp = document.createElement('div'); tmp.innerHTML = html;
          tmp.querySelectorAll('script,style,meta,link,iframe,object,embed,noscript,title,head').forEach(function (n){ n.remove(); });
          tmp.querySelectorAll('*').forEach(function (n){
            Array.prototype.slice.call(n.attributes || []).forEach(function (a){
              var nm = a.name.toLowerCase();
              if (nm.indexOf('on') === 0 || nm === 'style' || nm === 'class' || nm === 'id') n.removeAttribute(a.name);
              if (nm === 'href' && /^\s*javascript:/i.test(a.value)) n.removeAttribute(a.name);
            });
          });
          tmp.querySelectorAll('table').forEach(function (t){ t.className = 'wr-tbl'; });
          tmp.querySelectorAll('a[href]').forEach(function (a){ a.setAttribute('rel', 'noopener'); });
          return tmp.innerHTML;
        }
        function pasteImageFile(f){ var r = new FileReader(); r.onload = function (){ var im = new Image(); im.onload = function (){ insertHTML('<img src="' + r.result + '" alt="">'); }; im.onerror = function (){ if (window.SnapJarKit) window.SnapJarKit.toast('Could not paste that image', 'err'); }; im.src = r.result; }; r.readAsDataURL(f); }
        wrBody.addEventListener('paste', function (e){
          var cd = e.clipboardData || window.clipboardData; if (!cd) return;
          var items = cd.items ? Array.prototype.slice.call(cd.items) : [], imgItem = null, i;
          for (i = 0; i < items.length; i++){ if (items[i].kind === 'file' && /image/i.test(items[i].type)){ imgItem = items[i]; break; } }
          if (imgItem){ var f = imgItem.getAsFile(); if (f){ e.preventDefault(); pasteImageFile(f); } return; }
          var html = cd.getData && cd.getData('text/html');
          if (html){ e.preventDefault(); insertHTML(sanitize(html)); return; }
          var txt = cd.getData && cd.getData('text/plain');
          if (txt && /^https?:\/\/\S+$/i.test(txt.trim())){ e.preventDefault(); var u = txt.trim(); insertHTML('<a href="' + u.replace(/"/g, '%22') + '" rel="noopener">' + esc(u) + '</a> '); return; }
          /* otherwise allow the default plain-text paste */
        });
        wrBody.addEventListener('dragover', function (e){ if (e.dataTransfer && Array.prototype.some.call(e.dataTransfer.items || [], function (it){ return it.kind === 'file'; })) e.preventDefault(); });
        wrBody.addEventListener('drop', function (e){
          var dt = e.dataTransfer; if (!dt || !dt.files) return; var f = null, i;
          for (i = 0; i < dt.files.length; i++){ if (/image/i.test(dt.files[i].type)){ f = dt.files[i]; break; } }
          if (f){ e.preventDefault(); pasteImageFile(f); }
        });
      })();

      /* ===================== IMMERSIVE CHROME — auto-hide on scroll + 'More' sheet ===================== */
      (function (){
        var rail = $('prRail'), rbar = $('prRbar'), host = $('prDoc'), hidden = false, ct;
        function setHidden(h){ if (h === hidden) return; hidden = h; if (rail) rail.classList.toggle('pr-chrome-hidden', h); if (rbar) rbar.classList.toggle('pr-chrome-hidden', h); }
        window.__prShowChrome = function (){ setHidden(false); };
        if (host){
          var praf = 0;
          host.addEventListener('scroll', function (){ setHidden(true); clearTimeout(ct); ct = setTimeout(function (){ setHidden(false); }, 1100); if (!praf) praf = requestAnimationFrame(function (){ praf = 0; computeCurPage(); }); }, { passive: true });
          /* tap a line of text → start/jump read-aloud from there; tap empty area → toggle controls */
          host.addEventListener('click', function (e){
            var t = e.target;
            if (t && t.closest){
              if (t.closest('button,a,input,textarea')) return;
              var span = t.closest('.textLayer span');
              if (span && (span.textContent || '').trim()){ try { ttsStartFromSpan(span); } catch (x) {} return; }
            }
            setHidden(!hidden);
          });
        }
        var more = $('prMoreSheet');
        function onDocClick(e){ if (e.target && e.target.closest && e.target.closest('#prMoreSheet')) return; closeMore(); }
        function closeMore(){ if (more) more.hidden = true; document.removeEventListener('click', onDocClick, true); }
        function openMore(){ if (!more) return; more.hidden = false; setTimeout(function (){ document.addEventListener('click', onDocClick, true); }, 0); }
        if ($('prMore')) $('prMore').onclick = function (e){ if (e.stopPropagation) e.stopPropagation(); if (!more) return; if (more.hidden) openMore(); else closeMore(); };
        if (more){ more.querySelectorAll('.pr-mi').forEach(function (b){ b.addEventListener('click', closeMore); }); }
      })();

      /* ===================== INTERNET-NEEDED prompt (premium, only for online features) ===================== */
      (function (){
        function ok(){ return navigator.onLine !== false; }
        var pending = null, sheet = $('sjNetSheet');
        window.__requireNet = function (fn){ if (ok()){ fn && fn(); return true; } pending = fn || null; if (sheet) sheet.hidden = false; return false; };
        if (sheet){
          $('sjNetRetry').onclick = function (){ if (ok()){ sheet.hidden = true; var f = pending; pending = null; if (f) f(); } else if (window.SnapJarKit) window.SnapJarKit.toast('Still offline — please switch on Wi-Fi or mobile data.', 'err'); };
          $('sjNetClose').onclick = function (){ sheet.hidden = true; pending = null; };
          sheet.onclick = function (e){ if (e.target === sheet) sheet.hidden = true; };
          window.addEventListener('online', function (){ if (sheet && !sheet.hidden){ sheet.hidden = true; var f = pending; pending = null; if (f) f(); } });
        }
      })();

      /* ===================== FOCUS SOUND — generated on-device (Web Audio), fully offline =====================
         No audio files, no streaming, no licensing: calm/rain/ocean ambiences are synthesised from noise so
         they play instantly, offline, and keep the privacy promise. Plays alongside read-aloud at a low level. */
      (function (){
        var FS = { ctx: null, src: null, gain: null, lfo: null, cur: 'off', vol: 0.4 };
        try { var sc = localStorage.getItem('sj_fs'); if (sc){ var o = JSON.parse(sc); FS.cur = o.cur || 'off'; if (o.vol != null) FS.vol = o.vol; } } catch (e) {}
        function save(){ try { localStorage.setItem('sj_fs', JSON.stringify({ cur: FS.cur, vol: FS.vol })); } catch (e) {} }
        function stop(){ try { if (FS.lfo){ FS.lfo.stop(); FS.lfo.disconnect(); FS.lfo = null; } if (FS.src){ FS.src.stop(); FS.src.disconnect(); FS.src = null; } } catch (e) {} }
        function start(kind){
          stop();
          if (!kind || kind === 'off'){ FS.cur = 'off'; return; }
          var Ctx = window.AudioContext || window.webkitAudioContext; if (!Ctx) return;
          if (!FS.ctx){ try { FS.ctx = new Ctx(); } catch (e) { return; } }
          var ctx = FS.ctx; if (ctx.state === 'suspended') ctx.resume();
          var sr = ctx.sampleRate, len = sr * 4, buf = ctx.createBuffer(1, len, sr), d = buf.getChannelData(0), i;
          if (kind === 'brown' || kind === 'ocean'){ var last = 0; for (i = 0; i < len; i++){ var w = Math.random() * 2 - 1; last = (last + 0.02 * w) / 1.02; d[i] = last * 3.2; } }
          else { for (i = 0; i < len; i++) d[i] = Math.random() * 2 - 1; }
          var src = ctx.createBufferSource(); src.buffer = buf; src.loop = true;
          var gain = ctx.createGain(), f;
          if (kind === 'brown'){ f = ctx.createBiquadFilter(); f.type = 'lowpass'; f.frequency.value = 500; src.connect(f); f.connect(gain); }
          else if (kind === 'rain'){ var hp = ctx.createBiquadFilter(); hp.type = 'highpass'; hp.frequency.value = 500; var lp = ctx.createBiquadFilter(); lp.type = 'lowpass'; lp.frequency.value = 7000; src.connect(hp); hp.connect(lp); lp.connect(gain); }
          else if (kind === 'ocean'){ f = ctx.createBiquadFilter(); f.type = 'lowpass'; f.frequency.value = 420; src.connect(f); f.connect(gain); }
          else { f = ctx.createBiquadFilter(); f.type = 'lowpass'; f.frequency.value = 9000; src.connect(f); f.connect(gain); }
          gain.connect(ctx.destination);
          if (kind === 'ocean'){ gain.gain.value = FS.vol * 0.6; var lfo = ctx.createOscillator(); lfo.frequency.value = 0.12; var lg = ctx.createGain(); lg.gain.value = FS.vol * 0.4; lfo.connect(lg); lg.connect(gain.gain); lfo.start(); FS.lfo = lfo; }
          else gain.gain.value = FS.vol;
          src.start(); FS.src = src; FS.gain = gain; FS.cur = kind;
        }
        function setVol(v){ FS.vol = v; if (FS.gain) FS.gain.gain.value = (FS.cur === 'ocean' ? v * 0.6 : v); save(); }
        function syncUI(){
          var seg = $('cfSound'); if (seg) seg.querySelectorAll('button').forEach(function (b){ b.classList.toggle('on', b.getAttribute('data-s') === FS.cur); });
          var vr = $('cfVolRow'); if (vr) vr.hidden = (FS.cur === 'off');
          var vv = $('cfVol'); if (vv) vv.value = Math.round(FS.vol * 100);
        }
        if ($('cfSound')) $('cfSound').querySelectorAll('button').forEach(function (b){ b.onclick = function (){ start(b.getAttribute('data-s')); save(); syncUI(); }; });
        if ($('cfVol')) $('cfVol').oninput = function (){ setVol((+$('cfVol').value || 0) / 100); };
        syncUI();
        window.__fsStop = stop;
      })();

      /* deep links from My Files: ?recent=<id> (open saved), ?new=1 (create), ?open=1 (source sheet) */
      try {
        var qs = new URLSearchParams(location.search);
        var rid = qs.get('recent');
        if (rid && window.SJRecents) {
          status('Opening…');
          window.SJRecents.get(rid).then(function (rec){ if (rec && rec.blob) openFile(rec.blob); else status('That file is no longer available.'); });
        } else if (qs.get('new') === '1') {
          enterWrite(true);
        } else if (qs.get('open') === '1') {
          openSheet();
        } else if (qs.get('scanqr') === '1') {
          startQr();
        } else if (qs.get('ocr') === '1') {
          startOcr();
        } else if (qs.get('filterscan') === '1') {
          startFilterScan();
        }
      } catch (e) {}
    })();
  </script>
