      <button class="nt-save" id="sjNetRetry" type="button">I've turned it on — retry</button>
      <button class="pr-sheet-close" id="sjNetClose" type="button">Not now</button>
    </div>
  </div>

  <!-- notes (on-device, per document) -->
  <div class="pr-sheet" id="prNotesSheet" hidden>
