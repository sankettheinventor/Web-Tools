  <!-- document style panel (fonts / typography / alignment / colour) -->
  <div class="pr-sheet" id="wrSettings" hidden>
    <div class="pr-sheet-card wr-set">
      <div class="wr-set-h">Document style</div>
      <div class="wr-set-prev" id="wrSetPrev">So we beat on, boats against the current, borne back ceaselessly into the past.</div>
      <div class="wr-set-lab">Font</div>
      <div class="wr-fonts" id="wrFontCards"></div>
      <div class="wr-set-lab">Typography</div>
      <div class="wr-set-row"><span class="wr-set-rl">Text size</span><div class="wr-step"><button data-sz="-1" type="button">−</button><b id="wrSzVal">16</b><button data-sz="1" type="button">+</button></div></div>
      <div class="wr-set-row"><span class="wr-set-rl">Weight</span><div class="wr-seg" id="wrWeight"><button data-w="400" type="button">Regular</button><button data-w="600" type="button">Medium</button><button data-w="700" type="button">Bold</button></div></div>
      <div class="wr-set-row"><span class="wr-set-rl">Line spacing</span><div class="wr-seg" id="wrLineSeg"><button data-l="1.45" type="button">Tight</button><button data-l="1.7" type="button">Normal</button><button data-l="2" type="button">Airy</button></div></div>
      <div class="wr-set-lab">Alignment</div>
      <div class="wr-seg wr-seg-full" id="wrAlign"><button data-a="left" type="button">Left</button><button data-a="center" type="button">Center</button><button data-a="right" type="button">Right</button><button data-a="justify" type="button">Justify</button></div>
      <div class="wr-set-lab">Text colour</div>
      <div class="wr-set-colors" id="wrSetColors"></div>
      <button class="pr-sheet-close" id="wrSetClose" type="button">Done</button>
    </div>
  </div>

  <div class="content" id="prSeo">
    <h2>Create, edit and read PDFs — privately</h2>
    <p>Start a PDF from scratch or from your photos, then add a <b>title</b>, <b>text</b>, <b>images</b>, a <b>signature</b> and simple <b>diagrams</b> (boxes, lines, ovals). Reorder, rotate and delete pages, then export the finished file. Open an existing PDF to layer your edits on top, or just read it — the reader builds a real <b>text layer</b> so you can <b>select, copy</b> and <b>search inside</b> the document. Everything happens on your device; the file is never uploaded.</p>
    <div class="xlinks"><a href="/tools/compress-pdf">Compress PDF →</a><a href="/tools/pdf-tools">Merge PDF →</a><a href="/tools/pdf-to-jpg">PDF to JPG →</a></div>
  </div>

  <AppLd name="PDF Editor" description="Create PDFs from scratch or photos and add titles, text, images, signatures and diagrams; reorder, rotate and delete pages; plus read, search and copy — fully on-device, nothing uploaded." category="UtilitiesApplication" features={["Create a new PDF from blank pages or photos","Add titles, text boxes, images and signatures","Draw simple diagrams: boxes, lines and ovals","Reorder, rotate and delete pages","Read with zoom, text selection and copy","Search inside the document","100% private — nothing is uploaded"]} />
  <Faq items={faqItems} />

  <style is:global>
    /* In the app, the reader/editor is the whole experience — hide web SEO + FAQ */
    body.is-app #prSeo, body.is-app .faq{display:none !important}
    .pr-open .head{padding:var(--s6) 0 var(--s4)}
    .drop{border:1.5px solid var(--line);border-radius:18px;background:linear-gradient(160deg,rgba(139,123,255,.10),var(--surface2));padding:40px 20px;text-align:center;cursor:pointer;transition:border-color .15s,transform .12s,box-shadow .15s}
    .drop:hover,.drop.drag{border-color:var(--brand);box-shadow:0 14px 34px -18px var(--brand)}
    .drop:active{transform:scale(.99)}
    .drop-ic{font-size:44px;margin-bottom:10px}.drop-t{font-size:17px;font-weight:700}.drop-s{font-size:12.5px;color:var(--dim);margin-top:8px}
    .pr-new{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;margin-top:12px;padding:14px;border:1px solid var(--line);border-radius:14px;background:var(--surface2);color:var(--txt);font:inherit;font-weight:700;font-size:14.5px;cursor:pointer;transition:border-color .15s,transform .12s}
    .pr-new:hover{border-color:var(--brand)}.pr-new:active{transform:scale(.99)}
    .pr-new-ic{font-size:16px}
    .status{max-width:var(--read);margin:14px auto 0;text-align:center;font-size:13px;color:var(--dim)}

    .pr-sheet{position:fixed;inset:0;z-index:120;background:rgba(8,6,16,.5);display:flex;align-items:flex-end;justify-content:center;animation:app-fade .2s ease both}
    .pr-sheet[hidden]{display:none}
    .pr-sheet-card{position:relative;background:var(--sheet-card,var(--surface));border:1px solid var(--sheet-line,var(--line));border-bottom:0;border-radius:24px 24px 0 0;width:100%;max-width:520px;padding:8px 18px calc(20px + env(safe-area-inset-bottom));box-shadow:var(--sheet-shadow,0 -16px 50px -12px rgba(0,0,0,.45));animation:app-rise .28s cubic-bezier(.22,1,.36,1) both}
    .pr-sheet-card::before{content:"";display:block;width:40px;height:4px;border-radius:4px;background:var(--sheet-grab,rgba(140,130,160,.4));margin:0 auto 14px}
    .pr-sheet-h{font-size:13px;font-weight:800;text-transform:uppercase;letter-spacing:.8px;color:var(--app-dim,var(--dim));margin:0 4px 12px}
    .pr-src{display:flex;align-items:center;gap:14px;width:100%;text-align:left;padding:14px;margin-bottom:8px;border:1px solid var(--sheet-line,var(--line));border-radius:14px;background:var(--sheet-row,var(--surface2));color:var(--app-ink,var(--txt));font:inherit;cursor:pointer;transition:border-color .15s,transform .12s,background .15s}
    .pr-src:hover{border-color:var(--app-accent,var(--brand))}.pr-src:active{transform:scale(.98);background:var(--sheet-row-active,var(--surface2))}
    .pr-src-ic{font-size:26px;flex:0 0 auto}
    .pr-src-tx{display:flex;flex-direction:column;gap:2px}.pr-src-tx b{font-size:15px;font-weight:700}.pr-src-tx small{font-size:12px;color:var(--app-dim,var(--dim))}
    .pr-sheet-close{width:100%;padding:14px;margin-top:6px;border:0;border-radius:14px;background:var(--sheet-row,var(--surface2));color:var(--app-dim,var(--dim));font:inherit;font-weight:700;cursor:pointer}
    .pr-sheet-close:active{background:var(--sheet-row-active,var(--surface2))}
    .pr-folder-top{display:flex;align-items:center;justify-content:space-between;gap:10px}
    .pr-folder-change{flex:0 0 auto;padding:6px 12px;border:1px solid var(--line);border-radius:10px;background:none;color:var(--brand);font:inherit;font-weight:700;font-size:12px;cursor:pointer}
    .pr-folder-list{max-height:50vh;overflow:auto;display:flex;flex-direction:column;gap:7px;margin:4px 0 10px;-webkit-overflow-scrolling:touch}
    .pr-folder-item{display:flex;align-items:center;gap:12px;width:100%;text-align:left;padding:11px 12px;border:1px solid var(--line);border-radius:12px;background:var(--surface2);color:var(--txt);font:inherit;cursor:pointer}
    .pr-folder-item:active{transform:scale(.98);border-color:var(--brand)}
    .pr-fi-ic{font-size:20px;flex:0 0 auto}
    .pr-fi-tx{display:flex;flex-direction:column;min-width:0}.pr-fi-tx b{font-size:14px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.pr-fi-tx small{font-size:11.5px;color:var(--dim)}
    .pr-folder-empty{text-align:center;color:var(--dim);font-size:13px;padding:24px 0}
    .qr-res-text{word-break:break-all;font-size:14px;font-weight:600;color:var(--txt);background:var(--surface2);border:1px solid var(--line);border-radius:12px;padding:14px;margin-bottom:10px;max-height:30vh;overflow:auto}
    .pr-share-prev{display:flex;align-items:center;gap:13px;padding:12px;margin-bottom:14px;border-radius:16px;background:var(--surface2);border:1px solid var(--line)}
    .pr-share-thumb{flex:0 0 auto;width:48px;height:60px;border-radius:8px;overflow:hidden;background:#fff;border:1px solid var(--line);display:grid;place-items:center;color:var(--dim);box-shadow:0 4px 12px -6px rgba(20,16,44,.3)}
    .pr-share-thumb img{width:100%;height:100%;object-fit:cover;object-position:top;display:none}
    .pr-share-thumb img[src]{display:block}.pr-share-thumb img[src] ~ svg,.pr-share-thumb:has(img[src]) svg{display:none}
    .pr-share-thumb svg{width:24px;height:24px}
    .pr-share-meta{flex:1;display:flex;flex-direction:column;min-width:0}.pr-share-meta b{font-size:15px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:var(--txt)}.pr-share-meta small{font-size:12px;color:var(--dim);margin-top:3px}
    .pr-share-x{flex:0 0 auto;width:30px;height:30px;border:0;border-radius:50%;background:color-mix(in srgb,var(--txt) 8%,transparent);color:var(--dim);font-size:13px;cursor:pointer}
    .pr-sa-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:4px}
    .pr-sa{display:flex;flex-direction:column;align-items:center;gap:9px;padding:12px 4px;border:0;background:none;cursor:pointer;font:inherit}
    .pr-sa:active{transform:scale(.95)}
    .pr-sa-ic{width:54px;height:54px;border-radius:16px;display:grid;place-items:center;color:#fff;box-shadow:0 8px 20px -10px rgba(20,16,44,.5)}
    .pr-sa-ic svg{width:24px;height:24px}
    .sa-share{background:linear-gradient(150deg,#8b7bff,#6b4dff)}
    .sa-files{background:linear-gradient(150deg,#ffb648,#f59e0b)}
    .sa-save{background:linear-gradient(150deg,#3aa0ff,#2563eb)}
    .sa-print{background:linear-gradient(150deg,#8b8b9c,#5b5868)}
    .pr-sa-l{font-size:12px;font-weight:700;color:var(--txt)}
    /* custom scan filter screen */
    .fx{position:fixed;inset:0;z-index:220;display:flex;flex-direction:column;background:#0d0a15}
    .fx[hidden]{display:none}
    .fx-top{flex:0 0 auto;display:flex;align-items:center;gap:10px;padding:10px 14px;padding-top:calc(10px + env(safe-area-inset-top));background:var(--nav-bg);border-bottom:1px solid var(--line)}
    .fx-x{width:38px;height:38px;border-radius:10px;border:1px solid var(--line);background:var(--surface);color:var(--txt);font-size:16px;cursor:pointer}
    .fx-h{font-weight:800;color:var(--txt)}
    .fx-stage{flex:1;display:grid;place-items:center;overflow:hidden;padding:16px}
    .fx-actions{flex:0 0 auto;display:flex;gap:12px;padding:12px 16px;padding-bottom:calc(14px + env(safe-area-inset-bottom));background:var(--nav-bg);border-top:1px solid var(--line)}
    .fx-retake,.fx-use{flex:1;height:50px;display:inline-flex;align-items:center;justify-content:center;gap:9px;border-radius:14px;font:inherit;font-weight:800;font-size:15px;cursor:pointer;transition:transform var(--d-micro) var(--ease-out)}
    .fx-retake{border:1px solid var(--line);background:var(--surface);color:var(--txt)}
    .fx-use{border:0;background:linear-gradient(135deg,#2bb673,#15a06b);color:#fff;box-shadow:0 10px 24px -10px rgba(43,182,115,.7)}
    .fx-retake svg,.fx-use svg{width:19px;height:19px}
    .fx-retake:active,.fx-use:active{transform:scale(.97)}
    .fx-canvas{max-width:100%;max-height:100%;border-radius:6px;box-shadow:0 20px 56px -22px rgba(0,0,0,.8)}
    .fx-strip{flex:0 0 auto;display:flex;gap:14px;overflow-x:auto;-webkit-overflow-scrolling:touch;padding:14px 16px;padding-bottom:calc(14px + env(safe-area-inset-bottom));background:var(--nav-bg);border-top:1px solid var(--line)}
    .fx-strip::-webkit-scrollbar{display:none}
    .fx-opt{flex:0 0 auto;display:flex;flex-direction:column;align-items:center;gap:7px;border:0;background:none;cursor:pointer;padding:0}
    .fx-opt canvas{width:64px;height:84px;border-radius:10px;border:2.5px solid transparent;background:#fff;object-fit:cover;transition:border-color var(--d-micro) var(--ease-out)}
    .fx-opt.on canvas{border-color:var(--brand);box-shadow:0 0 0 2px rgba(124,92,255,.35)}
    .fx-opt span{font-size:11px;font-weight:700;color:rgba(255,255,255,.55)}
    .fx-opt.on span{color:#fff}
    @keyframes pr-rise{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:none}}

    /* premium reader chrome: frosted bar, borderless soft buttons, refined backdrop */
    .pr-bar{position:sticky;top:0;z-index:20;display:flex;align-items:center;gap:7px;padding:9px 12px;
      background:color-mix(in srgb, var(--nav-bg) 86%, transparent);backdrop-filter:blur(18px) saturate(1.4);-webkit-backdrop-filter:blur(18px) saturate(1.4);
      border-bottom:1px solid color-mix(in srgb, var(--line) 60%, transparent);overflow-x:auto}
    .pr-bar::-webkit-scrollbar{display:none}
    .pr-spacer{flex:1}
    .pr-btn{min-width:40px;height:40px;padding:0 10px;border-radius:12px;border:0;background:color-mix(in srgb, var(--txt) 7%, transparent);
      color:var(--txt);font:inherit;font-size:16px;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;flex:0 0 auto;
      transition:background var(--d-micro) var(--ease-out),transform var(--d-micro) var(--ease-out)}
    .pr-btn:hover{background:color-mix(in srgb, var(--brand) 16%, transparent);color:var(--brand)}
    .pr-btn:active{transform:scale(.92)}
    .pr-edit-cta{background:linear-gradient(135deg,var(--brand2),var(--brand));color:#fff;font-size:13px;font-weight:800;padding:0 16px;box-shadow:0 8px 22px -10px var(--brand)}
    .pr-edit-cta:hover{color:#fff;filter:brightness(1.05)}
    .pr-zoom{font-size:12.5px;min-width:56px}
    .pr-btn svg{width:19px;height:19px;display:block}
    .pr-edit-cta svg{width:15px;height:15px;margin-right:6px}
    .pr-page-ind{height:40px;padding:0 13px;border-radius:12px;border:0;background:color-mix(in srgb, var(--txt) 7%, transparent);color:var(--txt);font:inherit;font-size:13px;font-weight:700;cursor:pointer;flex:0 0 auto;display:inline-flex;align-items:center;gap:7px}
    .pr-page-ind:active{transform:scale(.95)}
    .pr-pi-ic{width:15px;height:15px;opacity:.75}
    .pr-name{max-width:38vw;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:12px;font-weight:700;color:var(--dim);flex:0 1 auto;align-self:center}

    /* page-thumbnail jump grid (tap the page pill) */
    .pr-thumbs{position:fixed;inset:0;z-index:1200;background:rgba(12,10,20,.55);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);display:flex;flex-direction:column;animation:prtIn .18s var(--ease-out)}
    @keyframes prtIn{from{opacity:0}to{opacity:1}}
    .pr-thumbs-top{display:flex;align-items:center;gap:10px;padding:16px 18px calc(12px + env(safe-area-inset-top));color:#fff}
    .pr-thumbs-top h4{margin:0;font-size:16px;font-weight:800;flex:1}
    .pr-thumbs-x{width:38px;height:38px;border:0;border-radius:50%;background:rgba(255,255,255,.14);color:#fff;font-size:16px;cursor:pointer;display:grid;place-items:center}
    .pr-thumbs-grid{flex:1;overflow:auto;-webkit-overflow-scrolling:touch;display:grid;grid-template-columns:repeat(auto-fill,minmax(96px,1fr));gap:14px;padding:6px 18px calc(22px + env(safe-area-inset-bottom))}
    .pr-thumb{cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:6px;border:0;background:none;padding:0}
    .pr-thumb-img{display:block;width:100%;aspect-ratio:3/4;border-radius:8px;background:#fff;box-shadow:0 8px 22px -10px rgba(0,0,0,.6);object-fit:cover;object-position:top;border:2px solid transparent;transition:border-color .12s,transform .12s}
    .pr-thumb.on .pr-thumb-img{border-color:var(--brand)}
    .pr-thumb:active .pr-thumb-img{transform:scale(.95)}
    .pr-thumb-n{font-size:11px;font-weight:700;color:rgba(255,255,255,.82)}
    .pr-find{position:sticky;top:58px;z-index:20;display:flex;align-items:center;gap:7px;padding:9px 12px;background:color-mix(in srgb, var(--nav-bg) 86%, transparent);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);border-bottom:1px solid color-mix(in srgb, var(--line) 60%, transparent)}
    .pr-find input{flex:1;min-width:0;height:40px;padding:0 14px;border-radius:12px;border:1px solid var(--line);background:var(--surface);color:var(--txt);font:inherit;font-size:14px;outline:none}
    .pr-find input:focus{border-color:var(--brand)}
    .pr-match{font-size:12px;color:var(--dim);font-weight:700;white-space:nowrap}

    .pr-doc{height:calc(100vh - 58px - 60px);overflow-y:auto;overflow-x:hidden;background:#e9e7f1;padding:18px 0;display:flex;flex-direction:column;align-items:center;gap:16px;-webkit-overflow-scrolling:touch;overscroll-behavior:contain;will-change:scroll-position}
    :root[data-theme="dark"] .pr-doc{background:#13111b}
    body.is-app .pr-doc{height:calc(100vh - 58px - 62px - env(safe-area-inset-bottom))}
    .pr-doc.sepia{background:#c9c2a8}
    .pr-doc.night{background:#0b0b10}
    .pr-page{position:relative;background:#fff;box-shadow:0 14px 44px -16px rgba(20,16,44,.5),0 2px 6px -3px rgba(20,16,44,.18);flex:0 0 auto}
    .pr-canvas{display:block}
    .pr-doc.sepia .pr-canvas{filter:sepia(.18) saturate(.92) brightness(.98)}
    .pr-doc.night .pr-page{background:#15151c}
    .pr-doc.night .pr-canvas{filter:invert(1) hue-rotate(180deg) brightness(.95) contrast(.95)}

    .textLayer{position:absolute;inset:0;overflow:hidden;line-height:1;text-size-adjust:none;forced-color-adjust:none;transform-origin:0 0;opacity:1}
    .textLayer span,.textLayer br{color:transparent;position:absolute;white-space:pre;cursor:text;transform-origin:0% 0%}
    .textLayer span.pr-hit{background:rgba(255,210,0,.45);border-radius:2px;color:transparent}
    .textLayer ::selection{background:rgba(124,92,255,.35)}
    @media(max-width:560px){.pr-zoom{min-width:46px}.pr-btn{min-width:36px;height:36px}}

    /* ===== READER CHROME v2 — immersive: right rail + floating bottom bar (auto-hide) ===== */
    .pr-main{position:relative}
    .pr-doc{padding-bottom:180px}
    /* right floating quick-action rail */
    .pr-rail{position:fixed;right:10px;top:50%;transform:translateY(-50%);z-index:60;display:flex;flex-direction:column;gap:10px;transition:opacity .26s var(--ease-out),transform .26s var(--ease-out)}
    .pr-fab{width:42px;height:42px;border-radius:50%;border:0;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;position:relative;
      background:color-mix(in srgb,var(--nav-bg) 90%,transparent);backdrop-filter:blur(16px) saturate(1.3);-webkit-backdrop-filter:blur(16px) saturate(1.3);
      color:var(--txt);box-shadow:0 6px 18px -8px rgba(20,16,44,.5),0 0 0 1px color-mix(in srgb,var(--line) 55%,transparent);
      transition:transform var(--d-micro) var(--ease-out),background var(--d-micro) var(--ease-out)}
    .pr-fab svg{width:19px;height:19px;display:block}
    .pr-fab:active{transform:scale(.9)}
    .pr-fab-listen{background:linear-gradient(135deg,#2bb673,#15a06b);color:#fff;box-shadow:0 10px 26px -10px rgba(43,182,115,.7)}
    .pr-fab-listen.on{background:linear-gradient(135deg,#e0a23a,#e5484d)}
    .pr-fab-edit{background:linear-gradient(135deg,var(--brand2),var(--brand));color:#fff;box-shadow:0 10px 26px -10px var(--brand)}
    /* floating bottom reader bar */
    .pr-rbar{position:fixed;left:50%;transform:translateX(-50%);bottom:calc(60px + env(safe-area-inset-bottom) + 58px);z-index:60;
      display:flex;align-items:center;gap:5px;padding:7px 8px;max-width:min(94vw,440px);
      background:color-mix(in srgb,var(--nav-bg) 93%,transparent);backdrop-filter:blur(20px) saturate(1.4);-webkit-backdrop-filter:blur(20px) saturate(1.4);
      border-radius:20px;box-shadow:0 14px 40px -14px rgba(20,16,44,.6),0 0 0 1px color-mix(in srgb,var(--line) 50%,transparent);
      transition:opacity .26s var(--ease-out),transform .26s var(--ease-out)}
    .pr-rbar .pr-spacer{flex:1;min-width:4px}
    .pr-rb{min-width:38px;height:38px;padding:0 9px;border:0;border-radius:11px;background:transparent;color:var(--txt);font:inherit;font-weight:700;font-size:13.5px;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;flex:0 0 auto;transition:transform var(--d-micro) var(--ease-out),background var(--d-micro)}
    .pr-rb:hover{background:color-mix(in srgb,var(--brand) 14%,transparent)}
    .pr-rb:active{transform:scale(.9)}
    .pr-rb svg{width:19px;height:19px;display:block}
    .pr-rb-page{gap:6px;font-size:12.5px;font-weight:800;background:color-mix(in srgb,var(--txt) 8%,transparent);padding:0 12px}
    .pr-rb-page .pr-pi-ic{width:15px;height:15px;opacity:.7}
    .pr-rb-zoom{display:inline-flex;align-items:center;background:color-mix(in srgb,var(--txt) 8%,transparent);border-radius:11px}
    .pr-zoom{font-size:12px;min-width:48px}
    /* hide the reader bar while the Listen player is up (it replaces it) */
    .pr-main.tts-on .pr-rbar{display:none}
    /* search docked above the reader bar */
    .pr-find{position:fixed;left:50%;right:auto;top:auto;transform:translateX(-50%);bottom:calc(60px + env(safe-area-inset-bottom) + 116px);z-index:61;width:min(94vw,440px);
      display:flex;align-items:center;gap:7px;padding:8px 10px;border-radius:18px;
      background:color-mix(in srgb,var(--nav-bg) 95%,transparent);backdrop-filter:blur(20px) saturate(1.4);-webkit-backdrop-filter:blur(20px) saturate(1.4);
      border:1px solid color-mix(in srgb,var(--line) 55%,transparent);box-shadow:0 14px 40px -14px rgba(20,16,44,.6)}
    .pr-find[hidden]{display:none}
    .pr-main.tts-on .pr-find{bottom:calc(60px + env(safe-area-inset-bottom) + 150px)}
    /* auto-hide chrome while scrolling */
    .pr-chrome-hidden{opacity:0;pointer-events:none}
    .pr-rail.pr-chrome-hidden{transform:translateY(-50%) translateX(26px)}
    .pr-rbar.pr-chrome-hidden{transform:translateX(-50%) translateY(26px)}
    .pr-badge-row{position:static;margin-left:auto}
    /* More — dropdown popover (Canva-style), opens upward from the bar's right edge */
    .pr-menu{position:fixed;right:calc(50% - min(47vw,220px));bottom:calc(60px + env(safe-area-inset-bottom) + 120px);z-index:70;
      display:flex;flex-direction:column;gap:1px;padding:6px;min-width:212px;
      background:color-mix(in srgb,var(--nav-bg) 97%,transparent);backdrop-filter:blur(22px) saturate(1.4);-webkit-backdrop-filter:blur(22px) saturate(1.4);
      border:1px solid color-mix(in srgb,var(--line) 55%,transparent);border-radius:15px;
      box-shadow:0 20px 54px -16px rgba(20,16,44,.7);transform-origin:bottom right;animation:pr-menu-in .16s var(--ease-out) both}
    .pr-menu[hidden]{display:none}
    @keyframes pr-menu-in{from{opacity:0;transform:translateY(8px) scale(.96)}to{opacity:1;transform:none}}
    .pr-mi{display:flex;align-items:center;gap:12px;width:100%;text-align:left;padding:11px 12px;border:0;border-radius:10px;background:transparent;color:var(--txt);font:inherit;font-size:14.5px;font-weight:600;cursor:pointer;transition:background var(--d-micro) var(--ease-out)}
    .pr-mi:hover{background:color-mix(in srgb,var(--brand) 14%,transparent)}
    .pr-mi:active{transform:scale(.98)}
    .pr-mi svg{width:19px;height:19px;flex:0 0 auto;opacity:.85}
    .pr-mi span{flex:1}
    .pr-mi .pr-badge-row{flex:0 0 auto}

    /* ---------- EDITOR ---------- */
    .ed{position:fixed;inset:0;z-index:200;display:flex;flex-direction:column;background:var(--app-bg,#0b0b10)}
    .ed[hidden]{display:none}
    .ed-top{flex:0 0 auto;display:flex;align-items:center;gap:8px;padding:10px 12px;padding-top:calc(10px + env(safe-area-inset-top));background:var(--nav-bg);border-bottom:1px solid var(--line)}
    .ed-x{width:38px;height:38px;border-radius:10px;border:1px solid var(--line);background:var(--surface);color:var(--txt);font-size:16px;cursor:pointer}
    .ed-page-ind{font-size:13px;font-weight:700;color:var(--dim);padding-left:4px}
    .ed-save{height:38px;padding:0 16px;border:0;border-radius:11px;background:linear-gradient(135deg,var(--brand2),var(--brand));color:#fff;font:inherit;font-weight:800;font-size:13.5px;cursor:pointer;box-shadow:0 8px 20px -10px var(--brand)}
    .ed-save:active{transform:scale(.97)}
    .ed-doc{flex:1;height:auto;background:#3a3a48}
    .ed-tools{flex:0 0 auto;display:flex;gap:8px;padding:10px 12px;padding-bottom:calc(10px + env(safe-area-inset-bottom));background:var(--nav-bg);border-top:1px solid var(--line);overflow-x:auto;-webkit-overflow-scrolling:touch}
    .ed-tool{flex:0 0 auto;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;min-width:58px;height:56px;border:1px solid var(--line);border-radius:13px;background:var(--surface);color:var(--txt);font:inherit;font-size:10.5px;font-weight:700;cursor:pointer;transition:border-color .12s,transform .1s}
    .ed-tool:active{transform:scale(.95);border-color:var(--brand)}
    .ed-tool.ed-danger{color:#ff6b6b}
    .ed-ti{font-size:20px;line-height:1;font-weight:800}.ed-ti-sm{font-size:14px}
    .ed-layer{position:absolute;inset:0;z-index:5}
    .ed-el{position:absolute;box-sizing:border-box;touch-action:none;cursor:move}
    .ed-el.sel{outline:2px solid var(--brand);outline-offset:1px}
    .ed-text,.ed-title{padding:2px 4px;color:#111;line-height:1.25;white-space:pre-wrap;word-break:break-word;overflow:hidden;background:transparent;outline:none;min-width:24px}
    .ed-title{font-weight:800}
    .ed-el img{width:100%;height:100%;display:block;pointer-events:none;object-fit:contain}
    .ed-shape{width:100%;height:100%}
    .ed-rect{border:2px solid #111}
    .ed-ellipse{border:2px solid #111;border-radius:50%}
    .ed-del{position:absolute;top:-12px;right:-12px;width:24px;height:24px;border-radius:50%;border:0;background:#ff5470;color:#fff;font-size:13px;line-height:1;cursor:pointer;z-index:6;display:none;align-items:center;justify-content:center}
    .ed-el.sel .ed-del{display:flex}
    .ed-handle{position:absolute;right:-9px;bottom:-9px;width:18px;height:18px;border-radius:50%;background:var(--brand);border:2px solid #fff;cursor:nwse-resize;z-index:6;display:none}
    .ed-el.sel .ed-handle{display:block}
    .ed-hint{position:absolute;left:50%;top:10px;transform:translateX(-50%);z-index:7;background:rgba(0,0,0,.78);color:#fff;font-size:12px;font-weight:600;padding:7px 13px;border-radius:20px;pointer-events:none;opacity:0;transition:opacity .2s}
    .ed-hint.show{opacity:1}

    /* ---------- WRITE (document authoring) ---------- */
    .wr{position:fixed;inset:0;z-index:210;display:flex;flex-direction:column;background:var(--app-bg,#0b0b10)}
    .wr[hidden]{display:none}
    .wr-top{flex:0 0 auto;display:flex;align-items:center;gap:12px;padding:10px 14px;padding-top:calc(10px + env(safe-area-inset-top));background:var(--nav-bg);border-bottom:1px solid var(--line)}
    .wr-x{width:38px;height:38px;border-radius:10px;border:1px solid var(--line);background:var(--surface);color:var(--txt);font-size:16px;cursor:pointer}
    .wr-count{font-size:12px;font-weight:700;color:var(--dim)}
    .wr-done{height:38px;padding:0 20px;border:0;border-radius:11px;background:linear-gradient(135deg,var(--brand2),var(--brand));color:#fff;font:inherit;font-weight:800;font-size:13.5px;cursor:pointer;box-shadow:0 8px 20px -10px var(--brand)}
    .wr-done:active{transform:scale(.97)}
    .wr-scroll{flex:1;overflow:auto;-webkit-overflow-scrolling:touch;background:#e8e7ef;padding:20px 0 28px}
    :root[data-theme="dark"] .wr-scroll{background:#15131e}
    .wr-page{max-width:720px;margin:0 auto;background:#fff;min-height:74vh;border-radius:8px;box-shadow:0 14px 50px -22px rgba(0,0,0,.45);padding:44px 40px}
    @media(max-width:560px){.wr-page{padding:30px 22px;border-radius:0;margin:0;min-height:82vh}}
    .wr-title{display:block;width:100%;border:0;outline:none;background:none;color:#15131c;font:inherit;font-size:27px;font-weight:800;letter-spacing:-.3px;margin:0 0 16px;padding:0;min-height:34px}
    .wr-title:empty:before{content:attr(data-ph);color:#c2bfce}
    .wr-body{outline:none;color:#2b2836;font-size:17px;line-height:1.72;min-height:52vh;white-space:pre-wrap;word-break:break-word}
    .wr-body:empty:before{content:attr(data-ph);color:#c2bfce}
    .wr-body.sz1{font-size:18.5px}.wr-body.sz2{font-size:20px}
    .wr-body .wr-q{border-left:3px solid var(--brand);padding-left:15px;margin:10px 0;color:#5e5970;font-style:italic}
    .wr-bar{flex:0 0 auto;display:flex;align-items:center;gap:8px;padding:10px 12px;padding-bottom:calc(10px + env(safe-area-inset-bottom));background:color-mix(in srgb, var(--nav-bg) 88%, transparent);backdrop-filter:blur(16px) saturate(1.3);-webkit-backdrop-filter:blur(16px) saturate(1.3);border-top:1px solid color-mix(in srgb, var(--line) 60%, transparent);transition:transform .2s ease}
    .wr-tool{min-width:40px;height:40px;padding:0 11px;border:0;border-radius:12px;background:color-mix(in srgb, var(--txt) 6%, transparent);color:var(--txt);font:inherit;font-size:15px;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;flex:0 0 auto;transition:background var(--d-micro) var(--ease-out),transform var(--d-micro) var(--ease-out),color var(--d-micro) var(--ease-out)}
    .wr-tool:hover{background:color-mix(in srgb, var(--brand) 14%, transparent)}
    .wr-tool:active{transform:scale(.9)}
    .wr-tool.on{background:color-mix(in srgb, var(--brand) 20%, transparent);color:var(--brand)}
    .wr-ins{color:var(--brand)}
    /* rich toolbar */
    .wr-tools{display:flex;align-items:center;gap:7px;overflow-x:auto;-webkit-overflow-scrolling:touch;width:100%}
    .wr-tools::-webkit-scrollbar{display:none}
    .wr-tools::-webkit-scrollbar{display:none}
    .wr-sel{flex:0 0 auto;height:36px;border:1px solid var(--line);border-radius:9px;background:var(--surface);color:var(--txt);font:inherit;font-size:13px;font-weight:700;padding:0 8px;cursor:pointer}
    .wr-sep{flex:0 0 auto;width:1px;height:22px;background:var(--line);margin:0 2px}
    .wr-cdot{display:block;width:18px;height:18px;border-radius:50%;background:#15131c;box-shadow:0 0 0 2px #fff,0 0 0 3px var(--line)}
    .wr-style{min-width:auto;gap:6px;font-size:13.5px;font-weight:700;padding:0 14px}
    /* document style panel */
    .wr-set{max-height:84vh;overflow-y:auto}
    .wr-set-h{font-size:17px;font-weight:800;color:var(--txt);margin:2px 2px 10px}
    .wr-set-prev{background:var(--surface2);border:1px solid var(--line);border-radius:14px;padding:16px;color:var(--txt);font-size:15px;line-height:1.6;margin-bottom:14px}
    .wr-set-lab{font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.8px;color:var(--dim);margin:14px 4px 9px}
    .wr-fonts{display:grid;grid-template-columns:repeat(4,1fr);gap:9px}
    .wr-fc{display:flex;flex-direction:column;align-items:center;gap:6px;padding:12px 4px;border:1.5px solid var(--line);border-radius:14px;background:var(--surface);color:var(--txt);cursor:pointer;transition:border-color var(--d-micro) var(--ease-out)}
    .wr-fc.on{border-color:var(--brand);box-shadow:0 0 0 2px rgba(124,92,255,.25)}
    .wr-fc-aa{font-size:22px;font-weight:700;line-height:1}.wr-fc-l{font-size:11px;font-weight:700;color:var(--dim)}
    .wr-set-row{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:11px 14px;border:1px solid var(--line);border-radius:13px;background:var(--surface);margin-bottom:8px}
    .wr-set-rl{font-size:14.5px;font-weight:600;color:var(--txt)}
    .wr-step{display:flex;align-items:center;gap:4px}
    .wr-step button{width:34px;height:34px;border:1px solid var(--line);border-radius:9px;background:var(--surface2);color:var(--txt);font-size:18px;font-weight:700;cursor:pointer}
    .wr-step b{min-width:34px;text-align:center;font-size:15px;font-weight:800;color:var(--txt)}
    .wr-seg{display:inline-flex;gap:3px;background:var(--surface2);border:1px solid var(--line);border-radius:11px;padding:3px}
    .wr-seg-full{display:flex;width:100%}
    .wr-seg button{flex:1;padding:8px 12px;border:0;border-radius:8px;background:none;color:var(--dim);font:inherit;font-weight:700;font-size:13px;cursor:pointer;white-space:nowrap}
    .wr-seg button.on{background:linear-gradient(135deg,var(--brand2),var(--brand));color:#fff}
    .wr-set-colors{display:flex;gap:10px;flex-wrap:wrap}
    .wr-scs{width:30px;height:30px;border-radius:50%;cursor:pointer;border:2px solid transparent}
    .wr-scs.on{border-color:var(--brand);box-shadow:0 0 0 2px var(--brand)}
    .wr-colors{display:flex;gap:9px;align-items:center;padding:11px 16px;background:var(--nav-bg);border-top:1px solid var(--line);overflow-x:auto}
    .wr-colors[hidden]{display:none}
    .wr-csw{flex:0 0 auto;width:26px;height:26px;border-radius:50%;cursor:pointer;border:2px solid transparent}
    .wr-csw.on{border-color:var(--brand);box-shadow:0 0 0 2px var(--brand)}
    /* rich body content */
    .wr-body img{max-width:100%;border-radius:7px;margin:10px 0;display:block}
    .wr-body h2{font-size:21px;font-weight:800;margin:16px 0 6px;color:#15131c}
    .wr-body ul,.wr-body ol{margin:8px 0;padding-left:24px}
    .wr-body table.wr-tbl{border-collapse:collapse;width:100%;margin:12px 0}
    .wr-body table.wr-tbl td{border:1px solid #d3d0dd;padding:8px 11px;font-size:15px;min-width:40px;vertical-align:top}
    .wr-body table.wr-tbl tr:first-child td{background:#f4f2f9;font-weight:700}
    /* drawing overlay */
    .wr-draw{position:fixed;inset:0;z-index:230;display:flex;flex-direction:column;background:var(--app-bg,#0b0b10)}
    .wr-draw[hidden]{display:none}
    .wr-draw-top{flex:0 0 auto;display:flex;align-items:center;gap:8px;padding:10px 14px;padding-top:calc(10px + env(safe-area-inset-top));background:var(--nav-bg);border-bottom:1px solid var(--line)}
    .wr-draw-h{font-weight:800;color:var(--txt)}
    .wr-draw-canvas{flex:1;width:100%;background:#fff;touch-action:none;display:block}
    .wr-draw-bar{flex:0 0 auto;display:flex;align-items:center;gap:10px;padding:12px 16px;padding-bottom:calc(12px + env(safe-area-inset-bottom));background:var(--nav-bg);border-top:1px solid var(--line)}
    .wr-swatch{flex:0 0 auto;width:26px;height:26px;border-radius:50%;cursor:pointer;border:2px solid transparent}
    .wr-swatch.on{border-color:#fff;box-shadow:0 0 0 2px var(--brand)}
    .wr-pen{width:110px}
    .wr-body a{color:var(--brand,#6b4dff);text-decoration:underline;word-break:break-word}

    /* ---------- LISTEN (read aloud) ---------- */
    .pr-listen-cta{background:linear-gradient(135deg,#2bb673,#15a06b);color:#fff;box-shadow:0 8px 20px -10px rgba(43,182,115,.7)}
    .pr-listen-cta:hover{color:#fff;filter:brightness(1.06)}
    .pr-listen-cta.on{background:linear-gradient(135deg,#e0a23a,#e5484d)}
    .tts{position:fixed;left:0;right:0;bottom:0;z-index:130;display:flex;flex-direction:column;
      background:color-mix(in srgb,var(--nav-bg) 93%,transparent);backdrop-filter:blur(20px) saturate(1.4);-webkit-backdrop-filter:blur(20px) saturate(1.4);
      border-top:1px solid color-mix(in srgb,var(--line) 60%,transparent);padding:11px 12px calc(12px + env(safe-area-inset-bottom));box-shadow:0 -14px 44px -18px rgba(0,0,0,.5);animation:app-rise .26s cubic-bezier(.22,1,.36,1) both}
    .tts[hidden]{display:none}
    body.is-app .tts{bottom:calc(60px + env(safe-area-inset-bottom))}
    .tts-now{font-size:16px;line-height:1.5;font-weight:600;color:var(--txt);max-width:var(--read);margin:0 auto 11px;text-align:center;min-height:24px;display:-webkit-box;-webkit-line-clamp:2;line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
    .tts-now:empty:before{content:"Tap play to read this document aloud";color:var(--dim);font-weight:500}
    .tts-row{display:flex;align-items:center;justify-content:center;gap:10px;max-width:var(--read);margin:0 auto;width:100%}
    .tts-b{width:50px;height:50px;border-radius:50%;border:0;background:color-mix(in srgb,var(--txt) 8%,transparent);color:var(--txt);cursor:pointer;display:inline-flex;align-items:center;justify-content:center;flex:0 0 auto;transition:background var(--d-micro) var(--ease-out),transform var(--d-micro) var(--ease-out)}
    .tts-b:hover{background:color-mix(in srgb,var(--brand) 16%,transparent)}
    .tts-b:active{transform:scale(.92)}
    .tts-b svg{width:23px;height:23px}
    .tts-play{width:64px;height:64px;background:linear-gradient(135deg,var(--brand2),var(--brand));color:#fff;box-shadow:0 10px 26px -10px var(--brand)}
    .tts-play:hover{filter:brightness(1.05)}
    .tts-play svg{width:30px;height:30px}
    .tts-chip{height:50px;min-width:50px;padding:0 16px;border-radius:25px;border:0;background:color-mix(in srgb,var(--txt) 8%,transparent);color:var(--txt);font:inherit;font-weight:800;font-size:14.5px;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;gap:6px;flex:0 0 auto;transition:background var(--d-micro) var(--ease-out),transform var(--d-micro) var(--ease-out)}
    .tts-chip:active{transform:scale(.94)}
    .tts-chip svg{width:21px;height:21px}
    @media(max-width:420px){.tts-chip{min-width:46px;padding:0 11px;font-size:13.5px}.tts-b{width:46px;height:46px}.tts-play{width:58px;height:58px}}
    /* read-along highlight in the text layer */
    .textLayer span.tts-read{background:rgba(124,92,255,.32);color:transparent;border-radius:3px;box-shadow:0 0 0 2px rgba(124,92,255,.18)}
    .pr-doc.night .textLayer span.tts-read{background:rgba(255,210,0,.30);box-shadow:0 0 0 2px rgba(255,210,0,.2)}
    /* voice list */
    .tts-vlist{max-height:46vh;overflow:auto;display:flex;flex-direction:column;gap:7px;margin:2px 0 12px;-webkit-overflow-scrolling:touch}
    .tts-v{display:flex;align-items:center;gap:12px;width:100%;text-align:left;padding:12px 14px;border:1px solid var(--line);border-radius:13px;background:var(--surface2);color:var(--txt);font:inherit;cursor:pointer;transition:border-color .12s}
    .tts-v.on{border-color:var(--brand);box-shadow:0 0 0 2px rgba(124,92,255,.22)}
    .tts-v-tx{display:flex;flex-direction:column;min-width:0;flex:1}
    .tts-v-tx b{font-size:14.5px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .tts-v-tx small{font-size:12px;color:var(--dim)}
    .tts-v-ck{flex:0 0 auto;color:var(--brand);font-weight:900;opacity:0}
    .tts-v.on .tts-v-ck{opacity:1}
    .tts-vfilter{width:100%;box-sizing:border-box;height:42px;padding:0 14px;margin:0 0 10px;border:1px solid var(--line);border-radius:12px;background:var(--surface);color:var(--txt);font:inherit;font-size:14px;outline:none}
    .tts-vfilter:focus{border-color:var(--brand)}
    .tts-vgroup{font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.7px;color:var(--brand);padding:10px 6px 5px;position:sticky;top:0;background:var(--sheet-card,var(--surface))}
    .tts-getvoices{display:flex;align-items:center;justify-content:center;gap:9px;width:100%;padding:13px;margin:0 0 8px;border:1px dashed color-mix(in srgb,var(--brand) 55%,transparent);border-radius:13px;background:color-mix(in srgb,var(--brand) 9%,transparent);color:var(--brand);font:inherit;font-weight:800;font-size:13.5px;cursor:pointer}
    .tts-getvoices svg{width:18px;height:18px;flex:0 0 auto}
    .tts-getvoices:active{transform:scale(.98)}

    /* ---------- READING COMFORT ---------- */
    .pr-doc .pr-page{filter:brightness(var(--pr-bright,1))}
    .cf-lab{font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.8px;color:var(--dim);margin:14px 4px 9px}
    .cf-bright{display:flex;align-items:center;gap:13px;padding:4px 2px 2px}
    .cf-bright svg{width:21px;height:21px;color:var(--dim);flex:0 0 auto}
    .cf-bright input{flex:1;height:34px}

    /* ---------- NOTES ---------- */
    #prNotes{position:relative}
    .pr-badge{position:absolute;top:2px;right:2px;min-width:16px;height:16px;padding:0 4px;border-radius:9px;background:var(--brand);color:#fff;font-size:10px;font-weight:800;display:inline-flex;align-items:center;justify-content:center;line-height:1;box-shadow:0 0 0 2px var(--nav-bg)}
    .pr-badge[hidden]{display:none}
    .nt-add{width:100%;min-height:74px;border:1px solid var(--line);border-radius:13px;background:var(--surface2);color:var(--txt);font:inherit;font-size:14.5px;line-height:1.5;padding:12px 14px;resize:vertical;outline:none;box-sizing:border-box}
    .nt-add:focus{border-color:var(--brand)}
    .nt-addbar{display:flex;gap:8px;margin:10px 0 14px}
    .nt-save{flex:1;height:46px;border:0;border-radius:13px;background:linear-gradient(135deg,var(--brand2),var(--brand));color:#fff;font:inherit;font-weight:800;font-size:14.5px;cursor:pointer;box-shadow:0 8px 20px -10px var(--brand)}
    .nt-save:active{transform:scale(.98)}
    .nt-list{max-height:42vh;overflow:auto;display:flex;flex-direction:column;gap:9px;-webkit-overflow-scrolling:touch}
    .nt-item{border:1px solid var(--line);border-radius:13px;background:var(--surface2);padding:11px 13px}
    .nt-item-top{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:6px}
    .nt-item-pg{border:0;font-size:11.5px;font-weight:800;color:var(--brand);background:color-mix(in srgb,var(--brand) 14%,transparent);padding:4px 10px;border-radius:20px;cursor:pointer;font-family:inherit}
    .nt-item-del{border:0;background:none;color:var(--dim);font-size:15px;cursor:pointer;padding:2px 6px;line-height:1}
    .nt-item-tx{font-size:14.5px;line-height:1.55;color:var(--txt);white-space:pre-wrap;word-break:break-word}
    .nt-empty{text-align:center;color:var(--dim);font-size:13.5px;line-height:1.55;padding:24px 8px}
    /* internet-needed prompt */
    .sjnet-ic{width:60px;height:60px;margin:4px auto 12px;border-radius:50%;display:grid;place-items:center;background:color-mix(in srgb,var(--brand) 14%,transparent);color:var(--brand)}
    .sjnet-ic svg{width:30px;height:30px}
    .sjnet-h{text-align:center;font-size:18px;font-weight:800;color:var(--txt);margin:0 0 8px}
    .sjnet-p{text-align:center;font-size:14px;line-height:1.55;color:var(--dim);margin:0 8px 16px}
  </style>

  <script>
    import * as pdfjsLib from 'pdfjs-dist';
    import { PDFDocument, StandardFonts, rgb, degrees } from 'pdf-lib';
    import pdfWorkerUrl from 'pdfjs-dist/build/pdf.worker.min.js?url';
    import html2canvas from 'html2canvas';
    import jsQR from 'jsqr';
    pdfjsLib.GlobalWorkerOptions.workerSrc = pdfWorkerUrl;

    (function () {
      function $(i){ return document.getElementById(i); }
      var doc = null, scale = 1, baseScale = 1, fitMode = true, pageEls = [], state = {}, io = null;
      var curPage = 1, query = '', matches = [], matchIdx = -1, indexBuilt = false, textIndex = {};
      var lastBytes = null;            // bytes of the currently open PDF (for "Edit")
      var curName = 'Document.pdf';    // name of the currently open PDF (for Share)
      var PAD = 14, A4 = { w: 595, h: 842 };

      function status(m){ $('prStatus').textContent = m || ''; }
      /* page-1 thumbnail (JPEG data URL) for the Recent library card */
      async function makeThumb(){
        try {
          var page = await doc.getPage(1);
          var vp = page.getViewport({ scale: 1 });
          var s = Math.min(300 / vp.width, 400 / vp.height, 1.6);
          var v = page.getViewport({ scale: s });
          var c = document.createElement('canvas'); c.width = Math.round(v.width); c.height = Math.round(v.height);
          await page.render({ canvasContext: c.getContext('2d'), viewport: v }).promise;
          return c.toDataURL('image/jpeg', 0.72);
        } catch (e) { return null; }
      }

      /* ============================ READER ============================ */
      async function openFile(file, recentName){
        if (!file) return;
        try { ttsStop(); } catch (e) {} try { if (window.__fsStop) window.__fsStop(); } catch (e) {}
        status('Opening…');
        try {
          var buf = await file.arrayBuffer();
          lastBytes = buf.slice(0);
          curName = recentName || (file && file.name) || 'Document.pdf';
          try { if (window.__notesBadge) window.__notesBadge(); } catch (e) {}
          doc = await pdfjsLib.getDocument({ data: buf }).promise;
        } catch (e) {
          status('Could not open this PDF — it may be corrupt or password-protected.');
          return;
        }
        indexBuilt = false; textIndex = {}; matches = []; matchIdx = -1; query = '';
        $('prTot').textContent = doc.numPages;
        setReaderName(curName);
        $('prOpen').hidden = true; $('prSeo').style.display = 'none';
        var faq = document.querySelector('.faq'); if (faq) faq.style.display = 'none';
        $('prEdit').hidden = true; $('prFilter').hidden = true; $('prWrite').hidden = true; $('prMain').hidden = false;
        // wait for the viewer to actually lay out, else clientWidth is 0 → blank pages
        await new Promise(function (r){ requestAnimationFrame(function (){ requestAnimationFrame(r); }); });
        await layout(false);
        status('');   // clear "Opening…" — the page is rendered now
        if (window.SnapJarKit) window.SnapJarKit.toast('Opened ' + shortName(curName) + ' · ' + doc.numPages + ' page' + (doc.numPages === 1 ? '' : 's'), 'ok');
        try { if (!localStorage.getItem('sj_tapread_hint')){ setTimeout(function (){ if (window.SnapJarKit && doc) window.SnapJarKit.toast('Tip: tap any line to start read-aloud from there 🎧', 'info', 5000); }, 1800); localStorage.setItem('sj_tapread_hint', '1'); } } catch (e) {}
        /* save into the on-device library (with a thumbnail) when user-initiated */
        if (recentName && window.SJRecents) { try { var thumb = await makeThumb(); window.SJRecents.add({ name: recentName, kind: 'pdf', blob: file, thumb: thumb }); } catch (e) {} }
      }
      /* a clean, short display name (drops the ugly "-watermarked-compressed" tails for toasts) */
      function shortName(n){ n = String(n || 'Document.pdf'); var base = n.replace(/\.[a-z0-9]+$/i, ''); if (base.length > 28) base = base.slice(0, 27) + '…'; return base + (/\.pdf$/i.test(n) ? '.pdf' : ''); }
      function setReaderName(n){ var el = $('prName'); if (el){ el.textContent = n || ''; el.title = n || ''; } try { document.title = (n ? n + ' — ' : '') + 'SnapJar'; } catch (e) {} }
      function pad2(x){ return String(x).length < 2 ? '0' + x : String(x); }
      function scanName(){ var d = new Date(); return 'Scan ' + (d.getMonth() + 1) + '-' + pad2(d.getDate()) + ' ' + pad2(d.getHours()) + pad2(d.getMinutes()) + '.pdf'; }
      function editedName(n){ var base = String(n || 'Document.pdf').replace(/\.pdf$/i, ''); if (/\(edited\)$/i.test(base)) return base + '.pdf'; return base + ' (edited).pdf'; }

      async function layout(keepPage){
        var want = keepPage ? curPage : 1;
        var first = await doc.getPage(1);
        var vp1 = first.getViewport({ scale: 1 });
        var avail = $('prDoc').clientWidth || window.innerWidth || 360;   // never 0 → never blank
        var contW = Math.min(avail, 900) - PAD * 2;
        baseScale = contW / vp1.width;
        if (fitMode) scale = baseScale;
        var phW = Math.round(vp1.width * scale), phH = Math.round(vp1.height * scale);
        var host = $('prDoc'); host.innerHTML = ''; pageEls = []; state = {};
        for (var n = 1; n <= doc.numPages; n++){
          var el = document.createElement('div');
          el.className = 'pr-page'; el.dataset.n = String(n);
          el.style.width = phW + 'px'; el.style.height = phH + 'px';
          host.appendChild(el); pageEls.push(el);
        }
        observe();
        $('prZoom').textContent = Math.round(scale / baseScale * 100) + '%';
        if (keepPage && pageEls[want - 1]) pageEls[want - 1].scrollIntoView();
        updateInd();
      }

      function observe(){
        if (io) io.disconnect();
        io = new IntersectionObserver(function (entries){
          entries.forEach(function (e){ if (e.isIntersecting) renderPage(+e.target.dataset.n); });
        }, { root: $('prDoc'), rootMargin: '1400px 0px', threshold: 0 });
        pageEls.forEach(function (el){ io.observe(el); });
      }
      function updateInd(){ $('prCur').textContent = curPage; }
      /* Current page = the page under the upper third of the viewport, from REAL geometry —
         not the IntersectionObserver (its 1400px render-ahead margin reports off-screen pages
         as visible, which made read-aloud start on the wrong page). Incremental from curPage,
         so it stays cheap even on a 200-page document. */
      function computeCurPage(){
        var host = $('prDoc'); if (!host || !pageEls.length) return;
        var hostTop = host.getBoundingClientRect().top, probeY = host.clientHeight * 0.35;
        function topOf(i){ return pageEls[i - 1].getBoundingClientRect().top - hostTop; }
        var p = Math.min(Math.max(curPage || 1, 1), pageEls.length);
        while (p < pageEls.length && topOf(p + 1) <= probeY) p++;
        while (p > 1 && topOf(p) > probeY) p--;
        if (p !== curPage){ curPage = p; updateInd(); }
      }
      /* if the user selected text, start read-aloud from the page that selection sits on */
      function ttsSelectionPage(){
        try {
          var sel = window.getSelection(); if (!sel || !sel.rangeCount || sel.isCollapsed) return 0;
          var node = sel.anchorNode, el = node && (node.nodeType === 1 ? node : node.parentNode);
          var pg = el && el.closest && el.closest('.pr-page');
          if (pg){ var idx = pageEls.indexOf(pg); if (idx >= 0) return idx + 1; }
        } catch (e) {}
        return 0;
      }
      /* the text-layer span at the START of the current selection (so play reads from there) */
      function ttsSelectionSpan(){
        try {
          var sel = window.getSelection(); if (!sel || !sel.rangeCount) return null;
          var r = sel.getRangeAt(0); var node = r.startContainer || sel.anchorNode; if (!node) return null;
          var el = node.nodeType === 1 ? node : node.parentNode;
          var span = el && el.closest ? el.closest('.textLayer span') : null;
          return (span && (span.textContent || '').trim()) ? span : null;
        } catch (e) { return null; }
      }

      async function renderPage(n){
        var el = pageEls[n - 1];
        if (!el || state[n] === 'busy' || state[n] === 'done') return;
        state[n] = 'busy';
        try {
          var page = await doc.getPage(n);
          var vp = page.getViewport({ scale: scale });
          // Render at the device's pixel density (capped at 3×) so text is razor-sharp
          // on hi-DPI phones, then DISPLAY the canvas at CSS-pixel size. Without this the
          // canvas backing store was 1× and the screen up-scaled it → the blurry page.
          // Floor at 2× so a WebView that under-reports devicePixelRatio (some report 1)
          // still renders crisp; cap at 3× to keep canvas memory light for smooth scrolling.
          var dpr = Math.min(Math.max(window.devicePixelRatio || 1, 2), 3);
          // Clamp the backing-store size (cssPx × dpr) to the canvas memory ceiling; only
          // huge pages lose a little density, layout size is unchanged either way.
          var fit = window.SnapJarKit ? window.SnapJarKit.fitDims(vp.width * dpr, vp.height * dpr) : { scale: 1, clamped: false };
          var outScale = dpr * (fit.clamped ? fit.scale : 1);
          el.style.width = Math.round(vp.width) + 'px';
          el.style.height = Math.round(vp.height) + 'px';
          var canvas = document.createElement('canvas');
          canvas.className = 'pr-canvas';
          canvas.width = Math.round(vp.width * outScale); canvas.height = Math.round(vp.height * outScale);
          canvas.style.width = Math.round(vp.width) + 'px'; canvas.style.height = Math.round(vp.height) + 'px';
          var ctx = canvas.getContext('2d');
          el.innerHTML = ''; el.appendChild(canvas);
          await page.render({ canvasContext: ctx, viewport: vp, transform: outScale !== 1 ? [outScale, 0, 0, outScale, 0, 0] : null }).promise;
          try {
            var tl = document.createElement('div');
            tl.className = 'textLayer';
            tl.style.width = Math.round(vp.width) + 'px'; tl.style.height = Math.round(vp.height) + 'px';
            el.appendChild(tl);
            var tc = await page.getTextContent();
            await pdfjsLib.renderTextLayer({ textContentSource: tc, container: tl, viewport: vp, textDivs: [] }).promise;
            if (query) highlight(tl);
          } catch (te) {}
          state[n] = 'done';
        } catch (e) { state[n] = null; }
      }

      function relayout(){ var keep = curPage; layout(true).then(function (){ curPage = keep; }); }
      function zoom(f){ fitMode = false; scale = Math.min(Math.max(scale * f, baseScale * 0.5), baseScale * 4); relayout(); }

      async function buildIndex(){
        if (indexBuilt || !doc) return;
        for (var n = 1; n <= doc.numPages; n++){
          try { var p = await doc.getPage(n); var tc = await p.getTextContent();
            textIndex[n] = tc.items.map(function (i){ return i.str; }).join(' ').toLowerCase();
          } catch (e) { textIndex[n] = ''; }
        }
        indexBuilt = true;
      }
      async function runSearch(){
        if (!doc) return;
        query = ($('prQuery').value || '').trim().toLowerCase();
        clearHighlights();
        if (!query){ $('prMatch').textContent = ''; matches = []; matchIdx = -1; return; }
        await buildIndex();
        matches = [];
        for (var n = 1; n <= doc.numPages; n++){ if (textIndex[n] && textIndex[n].indexOf(query) >= 0) matches.push(n); }
        matchIdx = matches.length ? 0 : -1;
        $('prMatch').textContent = matches.length ? ('1 / ' + matches.length + ' pages') : 'No matches';
        if (matchIdx >= 0) gotoMatch(0);
      }
      function gotoMatch(i){
        if (!matches.length) return;
        matchIdx = (i + matches.length) % matches.length;
        var n = matches[matchIdx];
        $('prMatch').textContent = (matchIdx + 1) + ' / ' + matches.length + ' pages';
        var el = pageEls[n - 1]; if (el){ el.scrollIntoView({ block: 'start' }); renderPage(n).then(function (){ var tl = el.querySelector('.textLayer'); if (tl) highlight(tl); }); }
      }
      function highlight(tl){ if (!query) return; tl.querySelectorAll('span').forEach(function (s){ if ((s.textContent || '').toLowerCase().indexOf(query) >= 0) s.classList.add('pr-hit'); }); }
      function clearHighlights(){ document.querySelectorAll('.textLayer span.pr-hit').forEach(function (s){ s.classList.remove('pr-hit'); }); }

      var modes = ['', 'sepia', 'night'], modeI = 0;
      function cycleMode(){ modeI = (modeI + 1) % modes.length; var d = $('prDoc'); d.classList.remove('sepia', 'night'); if (modes[modeI]) d.classList.add(modes[modeI]); }

      /* ===================== SOURCE / OPEN WIRING ===================== */
      var drop = $('prDrop'), file = $('prFile'), img = $('prImg'), sheet = $('prSheet');
      function openSheet(){ sheet.hidden = false; }
      function closeSheet(){ sheet.hidden = true; }
      $('prSheetClose').onclick = closeSheet;
      sheet.onclick = function (e){ if (e.target === sheet) closeSheet(); };
      drop.onclick = openSheet;
      drop.addEventListener('keydown', function (e){ if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openSheet(); } });
      ['dragover', 'dragenter'].forEach(function (ev){ drop.addEventListener(ev, function (e){ e.preventDefault(); drop.classList.add('drag'); }); });
      ['dragleave', 'drop'].forEach(function (ev){ drop.addEventListener(ev, function (e){ e.preventDefault(); drop.classList.remove('drag'); }); });
      drop.addEventListener('drop', function (e){ if (e.dataTransfer.files[0]) openFile(e.dataTransfer.files[0]); });

      $('srcDoc').onclick = function (){ closeSheet(); file.click(); };
      file.onchange = function (e){
        var f = e.target.files[0]; if (!f) return;
        if (/\.pdf$/i.test(f.name) || f.type === 'application/pdf') openFile(f, f.name);
        else status('That looks like a ' + ((f.name.split('.').pop() || 'document').toUpperCase()) + ' file. PDF opens now — Word/Excel preview is coming soon.');
      };
      $('srcGallery').onclick = function (){ closeSheet(); img.click(); };
      img.onchange = async function (e){
        var files = Array.prototype.slice.call(e.target.files || []); if (!files.length) return;
        status('Building a PDF from ' + files.length + ' image(s)…');
        try {
          var out = await PDFDocument.create();
          for (var i = 0; i < files.length; i++){
            var bytes = new Uint8Array(await files[i].arrayBuffer()), im;
            try { im = /png/i.test(files[i].type) ? await out.embedPng(bytes) : await out.embedJpg(bytes); }
            catch (er) { try { im = await out.embedPng(bytes); } catch (e2) { continue; } }
            var pg = out.addPage([im.width, im.height]);
            pg.drawImage(im, { x: 0, y: 0, width: im.width, height: im.height });
            if (window.SnapJarKit) await window.SnapJarKit.breathe();
          }
          var gBlob = new Blob([await out.save()], { type: 'application/pdf' });
          openFile(gBlob, 'Photos.pdf');
        } catch (er) { status('Could not build a PDF from those images.'); }
      };
      /* "Scan document" → our own capture + premium filter screen (Original/Grey/B&W/Darken/Lighten) */
      $('srcScan').onclick = function (){ closeSheet(); startFilterScan(); };
      $('srcOcr').onclick = function (){ closeSheet(); startOcr(); };

      /* Browse a folder — Storage Access Framework (Play-safe, no broad permission).
         Grant a folder once (persisted), list its PDFs, open one on tap. */
      var Folder = window.SnapJarKit ? window.SnapJarKit.plugin('FolderAccess') : null;
      function b64ToBlob(b64){ var bin = atob(b64), len = bin.length, u8 = new Uint8Array(len); for (var i = 0; i < len; i++) u8[i] = bin.charCodeAt(i); return new Blob([u8], { type: 'application/pdf' }); }
      function fSize(b){ if (!b) return ''; if (b < 1024) return b + ' B'; if (b < 1048576) return Math.round(b / 1024) + ' KB'; return (b / 1048576).toFixed(1) + ' MB'; }
      function showFolder(uri, name){
        $('prFolder').hidden = false; $('prFolderName').textContent = name || 'Folder';
        var listEl = $('prFolderList'); listEl.innerHTML = '<p class="pr-folder-empty">Loading…</p>';
        Folder.listPdfs({ uri: uri }).then(function (res){
          var files = (res && res.files) || [];
          if (!files.length){ listEl.innerHTML = '<p class="pr-folder-empty">No PDFs in this folder.</p>'; return; }
          files.sort(function (a, b){ return (b.modified || 0) - (a.modified || 0); });
          listEl.innerHTML = '';
          files.forEach(function (f){
            var b = document.createElement('button'); b.type = 'button'; b.className = 'pr-folder-item';
            b.innerHTML = '<span class="pr-fi-ic">📄</span><span class="pr-fi-tx"><b></b><small></small></span>';
            b.querySelector('b').textContent = f.name || 'Document.pdf';
            b.querySelector('small').textContent = fSize(f.size);
            b.onclick = function (){ openFromFolder(f); };
            listEl.appendChild(b);
          });
        }).catch(function (){ listEl.innerHTML = '<p class="pr-folder-empty">Could not read this folder.</p>'; });
      }
      function openFromFolder(f){
        $('prFolder').hidden = true; status('Opening…');
        Folder.readFile({ uri: f.uri }).then(function (res){
          if (!res || !res.data){ status('Could not open this PDF.'); return; }
          var blob = b64ToBlob(res.data);
          openFile(blob, f.name || 'Document.pdf');
        }).catch(function (){ status('Could not open this PDF — it may have been moved.'); });
      }
      function pickFolder(){
        if (!Folder) return;
        Folder.pickFolder().then(function (res){
          if (!res || !res.uri) return;
          try { localStorage.setItem('sj_folder', JSON.stringify({ uri: res.uri, name: res.name })); } catch (e) {}
          showFolder(res.uri, res.name);
        }).catch(function (){ /* cancelled */ });
      }
      $('srcFolder').onclick = function (){
        closeSheet();
        if (!Folder){ status('Folder browsing is available in the SnapJar app.'); return; }
        var saved = null; try { saved = JSON.parse(localStorage.getItem('sj_folder') || 'null'); } catch (e) {}
        if (saved && saved.uri) showFolder(saved.uri, saved.name); else pickFolder();
      };
      $('prFolderChange').onclick = pickFolder;
      $('prFolderClose').onclick = function (){ $('prFolder').hidden = true; };
      $('prFolder').onclick = function (e){ if (e.target === $('prFolder')) $('prFolder').hidden = true; };

      /* ---- QR scanner: capture photo → jsQR decode (on-device) ---- */
      var qrIn = $('prQrIn');
      function startQr(){ qrIn.value = ''; qrIn.click(); }
      qrIn.onchange = function (e){ var f = e.target.files[0]; if (f) decodeQr(f); };
      async function decodeQr(file){
        status('Reading QR…');
        try {
          var url = URL.createObjectURL(file);
          var img = window.SnapJarKit ? await window.SnapJarKit.loadImage(url) : await new Promise(function (res, rej){ var i = new Image(); i.onload = function (){ res(i); }; i.onerror = rej; i.src = url; });
          var fit = window.SnapJarKit ? window.SnapJarKit.fitDims(img.naturalWidth, img.naturalHeight) : { w: img.naturalWidth, h: img.naturalHeight };
          var c = document.createElement('canvas'); c.width = fit.w; c.height = fit.h;
          var x = c.getContext('2d'); x.drawImage(img, 0, 0, fit.w, fit.h);
          var d = x.getImageData(0, 0, fit.w, fit.h);
          var code = jsQR(d.data, d.width, d.height, { inversionAttempts: 'attemptBoth' });
          try { URL.revokeObjectURL(url); } catch (e) {}
          if (code && code.data){ status(''); showQr(code.data); }
          else { status(''); if (window.SnapJarKit) window.SnapJarKit.toast('No QR code found — try a closer, clearer photo', 'err'); }
        } catch (e){ status(''); if (window.SnapJarKit) window.SnapJarKit.toast('Could not read that image', 'err'); }
      }
      function showQr(text){
        $('prQrText').textContent = text;
        $('prQrOpen').hidden = !/^https?:\/\//i.test(text);
        $('prQrRes').hidden = false;
      }
      $('prQrOpen').onclick = function (){ var t = $('prQrText').textContent; try { window.open(t, '_system'); } catch (e) { try { window.open(t, '_blank'); } catch (_) {} } };
      $('prQrCopy').onclick = function (){ var t = $('prQrText').textContent; if (window.SnapJarKit) window.SnapJarKit.copy(t).then(function (){ window.SnapJarKit.toast('Copied', 'ok'); }); };
