      <div class="pr-sheet-h">Notes · saved on this device</div>
      <textarea id="ntAdd" class="nt-add" placeholder="Write a note about this document…" aria-label="New note"></textarea>
      <div class="nt-addbar"><button class="nt-save" id="ntSave" type="button">Save note</button></div>
      <div class="nt-list" id="ntList"></div>
      <button class="pr-sheet-close" id="ntClose" type="button">Close</button>
    </div>
