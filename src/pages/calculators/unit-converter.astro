---
import Base from '../../layouts/Base.astro';
import Faq from '../../components/Faq.astro';
import AppLd from '../../components/AppLd.astro';
const title = 'Unit Converter — Switch Units & See Results Live';
const description = 'Free unit converter for length, weight, temperature, area, volume, speed, digital storage and time. Convert metric and imperial units instantly in your browser — nothing uploaded, runs locally.';
const faqItems = [
  { q: 'What units can I convert?', a: 'This tool covers length, weight, temperature, area (square meters, square feet, acres, hectares), volume (liters, milliliters, US gallons, cups), speed (km/h, mph, knots, m/s), digital storage (KB, MB, GB, TB plus binary KiB, MiB, GiB) and time (seconds, minutes, hours, days, weeks).' },
  { q: 'How are the conversions calculated?', a: 'Every category except temperature converts through a base unit — meters for length, kilograms for weight, square meters for area, liters for volume, meters per second for speed, bytes for storage and seconds for time — so any unit can map to any other. Temperature uses the standard Celsius, Fahrenheit and Kelvin formulas.' },
  { q: 'What is the difference between GB and GiB?', a: 'Decimal units (KB, MB, GB, TB) use powers of 1000, while binary units (KiB, MiB, GiB) use powers of 1024. So 1 GB is 1,000,000,000 bytes but 1 GiB is 1,073,741,824 bytes. Both are included so you can convert between them.' },
  { q: 'Does the result update automatically?', a: 'Yes. As soon as you change the category, the from or to unit, or the value you type, the converted result updates instantly with no button to press.' },
  { q: 'Can it convert between metric and imperial?', a: 'Yes. You can freely convert in either direction, for example meters to feet, kilograms to pounds, or Celsius to Fahrenheit, and back again.' },
  { q: 'Is my data uploaded or stored?', a: 'No. Every conversion runs entirely in your browser using local JavaScript. Nothing you enter is uploaded, stored, or shared.' },
];
---
<Base title={title} description={description}>
  <header class="head"><div class="wrap">
    <p class="kicker">Everyday Tool</p><h1>Unit Converter</h1>
    <p>Pick a category, type a value and switch units to watch the result update live.</p>
  </div></header>
  <div class="wrap"><div class="tool">
    <div class="field"><div class="field-top"><label for="cat">Category</label></div>
      <select id="cat" aria-label="Category">
        <option value="length" selected>Length</option><option value="weight">Weight</option><option value="temperature">Temperature</option><option value="area">Area</option><option value="volume">Volume</option><option value="speed">Speed</option><option value="data">Digital Storage</option><option value="time">Time</option>
      </select></div>
    <div class="grid2">
      <div class="field"><div class="field-top"><label for="from">From</label></div>
        <div class="valwrap"><input id="val" type="number" inputmode="decimal" value="1" /></div>
        <select id="from" class="usel" aria-label="From unit"></select></div>
      <div class="field"><div class="field-top"><label for="to">To</label></div>
        <div class="result" style="padding:14px;margin-top:0;text-align:left"><div class="rbig" id="out" style="font-size:28px;margin:0">—</div></div>
        <select id="to" class="usel" aria-label="To unit"></select></div>
    </div>
  </div></div>
  <div class="ad">Advertisement</div>
  <div class="content">
    <h2>Convert between any units</h2>
    <p>Pick a category, choose your "from" and "to" units, and type a value — the result updates instantly. Convert length, weight, temperature, area, volume, speed, digital storage and time. Every category except temperature converts through a base unit (meters, kilograms, square meters, liters, meters per second, bytes and seconds); temperature uses the standard Celsius, Fahrenheit and Kelvin formulas.</p>
    <div class="xlinks"><a href="/#everyday">All calculators →</a></div>
  </div>
  <style>.usel{width:100%;margin-top:10px;padding:11px 12px;border:1px solid var(--line);border-radius:10px;background:var(--surface2);color:var(--txt);font:inherit;font-weight:600;outline:none}.usel:focus{border-color:var(--brand)}</style>
  <AppLd name="Unit Converter" description="Choose a category, type a value and switch the from and to dropdowns to watch the converted result update live in your browser." category="UtilitiesApplication" features={["Live conversion as you type or change units", "Length, weight, temperature, area, volume, speed, digital storage and time categories", "Metric and imperial unit dropdowns", "Instant two-way conversion with no button to press"]} />
  <Faq items={faqItems} />
  <script is:inline>
    (function(){
      function el(i){return document.getElementById(i);}
      var U={length:{m:1,km:1000,cm:0.01,mm:0.001,mi:1609.344,yd:0.9144,ft:0.3048,in:0.0254},
             weight:{kg:1,g:0.001,mg:0.000001,lb:0.45359237,oz:0.0283495231,t:1000},
             temperature:{'°C':1,'°F':1,K:1},
             area:{'m²':1,'km²':1000000,'cm²':0.0001,ha:10000,acre:4046.8564224,'ft²':0.09290304,'mi²':2589988.110336},
             volume:{L:1,mL:0.001,'m³':1000,gal:3.785411784,qt:0.946352946,cup:0.2365882365,'fl oz':0.0295735295625},
             speed:{'m/s':1,'km/h':0.2777777778,mph:0.44704,kn:0.5144444444,'ft/s':0.3048},
             data:{B:1,KB:1000,MB:1000000,GB:1000000000,TB:1000000000000,KiB:1024,MiB:1048576,GiB:1073741824},
             time:{s:1,ms:0.001,min:60,h:3600,d:86400,wk:604800}};
      var LABEL={m:'Meter',km:'Kilometer',cm:'Centimeter',mm:'Millimeter',mi:'Mile',yd:'Yard',ft:'Foot',in:'Inch',
        kg:'Kilogram',g:'Gram',mg:'Milligram',lb:'Pound',oz:'Ounce',t:'Tonne','°C':'Celsius','°F':'Fahrenheit',K:'Kelvin',
        'm²':'Square meter','km²':'Square kilometer','cm²':'Square centimeter',ha:'Hectare',acre:'Acre','ft²':'Square foot','mi²':'Square mile',
        L:'Liter',mL:'Milliliter','m³':'Cubic meter',gal:'US gallon',qt:'US quart',cup:'US cup','fl oz':'US fluid ounce',
        'm/s':'Meters per second','km/h':'Kilometers per hour',mph:'Miles per hour',kn:'Knot','ft/s':'Feet per second',
        B:'Byte',KB:'Kilobyte',MB:'Megabyte',GB:'Gigabyte',TB:'Terabyte',KiB:'Kibibyte',MiB:'Mebibyte',GiB:'Gibibyte',
        s:'Second',ms:'Millisecond',min:'Minute',h:'Hour',d:'Day',wk:'Week'};
      function fill(){
        var cat=el('cat').value, keys=Object.keys(U[cat]);
        ['from','to'].forEach(function(id){el(id).innerHTML=keys.map(function(k){return '<option value="'+k+'">'+LABEL[k]+' ('+k+')</option>';}).join('');});
        el('to').selectedIndex=Math.min(1,keys.length-1);
      }
      function toBase(cat,u,v){if(cat!=='temperature')return v*U[cat][u];if(u==='°C')return v;if(u==='°F')return (v-32)*5/9;return v-273.15;}
      function fromBase(cat,u,c){if(cat!=='temperature')return c/U[cat][u];if(u==='°C')return c;if(u==='°F')return c*9/5+32;return c+273.15;}
      function c(){var cat=el('cat').value,v=parseFloat(el('val').value);if(!isFinite(v)){el('out').textContent='—';return;}
        var base=toBase(cat,el('from').value,v),out=fromBase(cat,el('to').value,base);
        el('out').textContent=(Math.round(out*100000)/100000).toLocaleString();}
      el('cat').addEventListener('change',function(){fill();c();});
      ['val','from','to'].forEach(function(i){el(i).addEventListener('input',c);});
      fill();c();
    })();
  </script>
</Base>
