---
import Base from '../../layouts/Base.astro';
import Faq from '../../components/Faq.astro';
import AppLd from '../../components/AppLd.astro';
const title = 'Mortgage Calculator with Extra Payments & Prepay';
const description = 'Free mortgage calculator with taxes and insurance. Enter home price, down payment, rate and term to see your total monthly payment instantly.';
const faqItems = [
  { q: 'What does this mortgage calculator include?', a: 'It calculates your full monthly payment (PITI): principal, interest, property tax and home insurance. Principal and interest use the standard amortization formula; tax and insurance are entered yearly and divided by 12.' },
  { q: 'How much should my down payment be?', a: 'A larger down payment lowers both your monthly payment and your total interest. 20% is common because it usually avoids private mortgage insurance (PMI), but you can model any percentage with the slider.' },
  { q: 'Why is my total interest so high?', a: 'Over a 15–30 year term, interest compounds on the remaining balance every month, so total interest can approach or exceed the loan amount at higher rates. Shortening the term or increasing the down payment both reduce it sharply.' },
  { q: 'How much do extra payments and a one-time prepayment save?', a: 'Extra payments reduce the loan principal directly, so all future interest is charged on a smaller balance. Use the "Beat the bank" controls to add an annual payment step-up, a yearly extra payment, or a one-time lump-sum prepayment in any year — the calculator runs a month-by-month amortization on the principal and interest portion and shows the exact interest saved, your new payoff time, and a year-by-year schedule.' },
  { q: 'Is my financial data saved or uploaded?', a: 'No. The calculator runs entirely in your browser — nothing you type is sent to a server, stored, or shared. Closing the tab discards everything.' },
];
---
<Base title={title} description={description}>
  <header class="head"><div class="wrap">
    <p class="kicker">Finance Calculator</p>
    <h1>Mortgage Calculator</h1>
    <p>Drag the sliders for price, rate and down payment to watch your monthly payment update live.</p>
  </div></header>

  <div class="wrap">
    <div class="tool">
      <div class="field">
        <div class="field-top"><label for="cur">Currency</label></div>
        <select id="cur" aria-label="Currency">
          <option value="USD" data-sym="$" data-loc="en-US" selected>$ US Dollar (USD)</option>
          <option value="INR" data-sym="₹" data-loc="en-IN">₹ Indian Rupee (INR)</option>
          <option value="EUR" data-sym="€" data-loc="de-DE">€ Euro (EUR)</option>
          <option value="GBP" data-sym="£" data-loc="en-GB">£ British Pound (GBP)</option>
        </select>
      </div>
      <div class="field">
        <div class="field-top"><label for="price">Home price</label>
          <div class="valwrap"><span class="sym">$</span><input id="price" type="number" inputmode="decimal" min="0" value="350000" /></div></div>
        <input id="priceR" type="range" min="10000" max="2000000" step="5000" value="350000" aria-label="Home price" />
      </div>
      <div class="grid2">
        <div class="field">
          <div class="field-top"><label for="down">Down payment</label>
            <div class="valwrap"><input id="down" type="number" inputmode="decimal" min="0" max="100" step="1" value="20" /><span>%</span></div></div>
          <input id="downR" type="range" min="0" max="60" step="1" value="20" aria-label="Down payment percent" />
        </div>
        <div class="field">
          <div class="field-top"><label for="rate">Interest rate</label>
            <div class="valwrap"><input id="rate" type="number" inputmode="decimal" min="0" step="0.1" value="6.5" /><span>%</span></div></div>
          <input id="rateR" type="range" min="1" max="15" step="0.1" value="6.5" aria-label="Interest rate" />
        </div>
      </div>
      <div class="grid2">
        <div class="field">
          <div class="field-top"><label for="term">Term</label>
            <div class="valwrap"><input id="term" type="number" inputmode="numeric" min="1" value="30" /><span>yr</span></div></div>
          <input id="termR" type="range" min="5" max="40" step="1" value="30" aria-label="Term in years" />
        </div>
        <div class="field">
          <div class="field-top"><label for="tax">Property tax / yr</label>
            <div class="valwrap"><span class="sym">$</span><input id="tax" type="number" inputmode="decimal" min="0" value="3000" /></div></div>
          <input id="taxR" type="range" min="0" max="30000" step="100" value="3000" aria-label="Annual property tax" />
        </div>
      </div>
      <div class="field">
        <div class="field-top"><label for="ins">Home insurance / yr</label>
          <div class="valwrap"><span class="sym">$</span><input id="ins" type="number" inputmode="decimal" min="0" value="1200" /></div></div>
        <input id="insR" type="range" min="0" max="12000" step="100" value="1200" aria-label="Annual home insurance" />
      </div>

      <div class="result" aria-live="polite">
        <div class="rlabel">Total monthly payment</div>
        <div class="rbig" id="total">—</div>
        <div class="rsub" id="sub"></div>
        <div class="breakdown">
          <div class="bd"><div class="k">Principal &amp; interest</div><div class="v" id="bdPI">—</div></div>
          <div class="bd"><div class="k">Tax + insurance</div><div class="v" id="bdTI">—</div></div>
          <div class="bd"><div class="k">Loan amount</div><div class="v" id="bdLoan">—</div></div>
          <div class="bd"><div class="k">Total interest</div><div class="v" id="bdInt">—</div></div>
        </div>
      </div>

      <div class="adv">
        <div class="adv-h"><span>🏦 Beat the bank</span><small>Optional — model extra payments &amp; a prepayment an AI snippet can't compute</small></div>
        <div class="grid2">
          <div class="field">
            <div class="field-top"><label for="stepup">Annual payment step-up</label>
              <div class="valwrap"><input id="stepup" type="number" inputmode="numeric" min="0" max="50" step="1" value="0" /><span>%/yr</span></div></div>
            <input id="stepupR" type="range" min="0" max="25" step="1" value="0" aria-label="Annual payment step-up percent" />
          </div>
          <div class="field">
            <div class="field-top"><label for="annual">Extra payment every year</label>
              <div class="valwrap"><span class="sym">$</span><input id="annual" type="number" inputmode="decimal" min="0" step="500" value="0" /></div></div>
            <input id="annualR" type="range" min="0" max="100000" step="1000" value="0" aria-label="Annual extra payment" />
          </div>
        </div>
        <div class="grid2">
          <div class="field">
            <div class="field-top"><label for="onetime">One-time prepayment</label>
              <div class="valwrap"><span class="sym">$</span><input id="onetime" type="number" inputmode="decimal" min="0" step="5000" value="0" /></div></div>
            <input id="onetimeR" type="range" min="0" max="500000" step="5000" value="0" aria-label="One-time prepayment amount" />
          </div>
          <div class="field">
            <div class="field-top"><label for="otyear">…paid in year</label>
              <div class="valwrap"><input id="otyear" type="number" inputmode="numeric" min="1" value="3" /><span>yr</span></div></div>
            <input id="otyearR" type="range" min="1" max="40" step="1" value="3" aria-label="One-time prepayment year" />
          </div>
        </div>

        <div class="save" aria-live="polite">
          <div class="save-row">
            <div class="save-box"><div class="k">Interest saved</div><div class="v ok" id="saveInt">—</div></div>
            <div class="save-box"><div class="k">Loan-free earlier by</div><div class="v" id="saveTime">—</div></div>
          </div>
          <div class="save-row">
            <div class="save-box"><div class="k">New total interest</div><div class="v" id="newInt">—</div></div>
            <div class="save-box"><div class="k">New payoff time</div><div class="v" id="newPay">—</div></div>
          </div>
          <p class="save-hint" id="saveHint">Add a step-up or prepayment above to see how much interest you save on your loan.</p>
        </div>

        <details class="sched">
          <summary>Year-by-year amortization schedule</summary>
          <div class="sched-wrap">
            <table>
              <thead><tr><th>Yr</th><th>P&amp;I/mo</th><th>Principal</th><th>Interest</th><th>Extra</th><th>Balance</th></tr></thead>
              <tbody id="schedBody"></tbody>
            </table>
          </div>
        </details>
      </div>
    </div>
  </div>

  <div class="ad">Ad space</div>

  <div class="content">
    <h2>How your mortgage payment is calculated</h2>
    <p>A monthly mortgage payment usually has four parts, often called <b>PITI</b>: principal, interest, taxes and insurance. The principal and interest are fixed by the loan amount, rate and term using the standard amortization formula:</p>
    <div class="formula">P&amp;I = L × r × (1 + r)ⁿ ÷ ( (1 + r)ⁿ − 1 )</div>
    <p>where <b>L</b> is the loan amount (home price − down payment), <b>r</b> is the monthly rate (annual ÷ 12 ÷ 100) and <b>n</b> is the number of monthly payments. Property tax and home insurance are estimated yearly and divided by 12 to add to your monthly total.</p>
    <h3>A bigger down payment helps twice</h3>
    <p>It lowers the loan amount (smaller payments) and reduces total interest over the life of the loan. Try moving the down payment slider and watch both the monthly payment and total interest fall.</p>
    <div class="xlinks">
      <a href="/calculators/emi">EMI Calculator →</a>
      <a href="/calculators/loan-payoff">Loan Payoff →</a>
      <a href="/#calculators">All calculators →</a>
    </div>
  </div>

  <AppLd name="Mortgage Calculator" description="Drag the sliders for home price, interest rate, down payment and term to watch your full monthly payment and total interest update live in your browser." category="FinanceApplication" features={["Live sliders for price, rate, down payment and term", "Instant PITI breakdown of principal, interest, tax and insurance", "Adjustable annual property tax and home insurance", "Model extra payments, a yearly payment step-up and a one-time prepayment", "Interest saved, earlier payoff time and year-by-year amortization schedule", "Multi-currency support (USD, INR, EUR, GBP)", "Runs entirely client-side — nothing uploaded"]} />

  <Faq items={faqItems} />

  <style is:global>
    .adv{margin-top:var(--s5);border-top:1px solid var(--line);padding-top:var(--s5)}
    .adv-h{display:flex;align-items:baseline;gap:var(--s3);margin-bottom:var(--s4);flex-wrap:wrap}
    .adv-h span{font-weight:800;font-size:var(--t-md)}
    .adv-h small{color:var(--dim);font-size:var(--t-sm)}
    .save{background:var(--result-bg);border:1px solid var(--line);border-radius:var(--r-lg);padding:var(--s4);margin-top:var(--s4)}
    .save-row{display:grid;grid-template-columns:1fr 1fr;gap:var(--s3)}
    .save-row+.save-row{margin-top:var(--s3)}
    .save-box{background:var(--surface);border:1px solid var(--line);border-radius:var(--r);padding:var(--s3) var(--s4)}
    .save-box .k{font-size:var(--t-xs);color:var(--dim)}
    .save-box .v{font-size:var(--t-lg);font-weight:800;margin-top:2px}
    .save-box .v.ok{color:var(--ok)}
    .save-hint{font-size:var(--t-sm);color:var(--dim);margin-top:var(--s3);line-height:1.5}
    .sched{margin-top:var(--s4)}
    .sched summary{cursor:pointer;font-weight:700;font-size:var(--t-sm);color:var(--brand);padding:var(--s2) 0}
    .sched-wrap{overflow-x:auto;margin-top:var(--s3)}
    .sched table{width:100%;border-collapse:collapse;font-size:var(--t-sm);min-width:540px}
    .sched th,.sched td{text-align:right;padding:var(--s2) var(--s3);border-bottom:1px solid var(--line);white-space:nowrap}
    .sched th:first-child,.sched td:first-child{text-align:left}
    .sched th{color:var(--dim);font-weight:700;font-size:var(--t-xs);text-transform:uppercase;letter-spacing:.4px}
  </style>

  <script is:inline>
    (function () {
      var cur='USD', loc='en-US';
      function el(id){return document.getElementById(id);}
      function num(id){var v=parseFloat(el(id).value);return isFinite(v)?v:0;}
      function money(v){try{return new Intl.NumberFormat(loc,{style:'currency',currency:cur,maximumFractionDigits:0}).format(Math.round(v));}catch(e){return Math.round(v).toLocaleString();}}
      function fmtDur(months){
        months = Math.round(months);
        var y = Math.floor(months/12), mo = months%12, s = '';
        if (y) s += y + 'y';
        if (mo) s += (s ? ' ' : '') + mo + 'm';
        return s || '0m';
      }
      function pair(a,b){el(a).addEventListener('input',function(){el(b).value=el(a).value;compute();});el(b).addEventListener('input',function(){el(a).value=el(b).value;compute();});}
      // Month-by-month amortization on the LOAN (P&I only) with optional step-up + prepayments.
      function simulate(P, i, pi0, stepup, annual, oneAmt, oneYear){
        if (pi0 <= 0) return { never:true };
        var bal = P, pmt = pi0, totInt = 0, m = 0, cap = 12*60;
        var rows = [], yInt = 0, yPrin = 0, yExtra = 0;
        while (bal > 0.5 && m < cap){
          m++;
          var interest = bal * i;
          var principal = pmt - interest;
          if (principal <= 0) return { never:true };       // payment never covers interest
          if (principal > bal) principal = bal;
          bal -= principal; totInt += interest; yInt += interest; yPrin += principal;
          if (m % 12 === 0){
            var yr = m/12;
            if (annual > 0 && bal > 0){ var e = Math.min(annual, bal); bal -= e; yExtra += e; }
            if (oneAmt > 0 && yr === oneYear && bal > 0){ var o = Math.min(oneAmt, bal); bal -= o; yExtra += o; }
            rows.push({ yr:yr, pmt:pmt, prin:yPrin, int:yInt, extra:yExtra, bal:bal });
            if (stepup > 0) pmt = pmt * (1 + stepup/100);
            yInt = 0; yPrin = 0; yExtra = 0;
          }
        }
        if (m % 12 !== 0) rows.push({ yr:Math.ceil(m/12), pmt:pmt, prin:yPrin, int:yInt, extra:yExtra, bal:bal });
        return { months:m, totInt:totInt, rows:rows, never:false };
      }
      function compute(){
        var price=num('price'), dp=num('down'), R=num('rate'), Y=num('term'), tax=num('tax'), ins=num('ins');
        var loan=price*(1-dp/100); if(loan<0)loan=0;
        var r=R/12/100, n=Y*12;
        var pi=(r>0)?loan*r*Math.pow(1+r,n)/(Math.pow(1+r,n)-1):(n>0?loan/n:0);
        if(!isFinite(pi)||pi<0)pi=0;
        var ti=(tax+ins)/12, total=pi+ti, interest=pi*n-loan;
        el('total').textContent=money(total);
        el('sub').textContent=Y+' years · '+Math.round(dp)+'% down';
        el('bdPI').textContent=money(pi);
        el('bdTI').textContent=money(ti);
        el('bdLoan').textContent=money(loan);
        el('bdInt').textContent=money(interest);

        // Advanced: baseline (no extras) vs optimized (step-up + prepayments) on the loan P&I.
        var stepup=num('stepup'), annual=num('annual'), oneAmt=num('onetime'), oneYear=num('otyear');
        var base = simulate(loan, r, pi, 0, 0, 0, 0);
        var opt  = simulate(loan, r, pi, stepup, annual, oneAmt, oneYear);
        var body = el('schedBody'); body.innerHTML = '';
        if (opt.never || base.never){
          el('saveInt').textContent = '—'; el('saveTime').textContent = '—';
          el('newInt').textContent = '—'; el('newPay').textContent = '—';
          el('saveHint').textContent = 'Enter a loan amount and term to model extra payments.';
          return;
        }
        var saved = base.totInt - opt.totInt, mSaved = base.months - opt.months;
        var hasExtra = (stepup > 0 || annual > 0 || oneAmt > 0);
        el('newInt').textContent = money(opt.totInt);
        el('newPay').textContent = fmtDur(opt.months);
        if (hasExtra && saved > 0.5){
          el('saveInt').textContent = money(saved);
          el('saveTime').textContent = mSaved > 0 ? fmtDur(mSaved) : '—';
          el('saveHint').textContent = 'You cut total interest by ' + money(saved) + ' and become loan-free ' + fmtDur(mSaved) + ' earlier.';
        } else {
          el('saveInt').textContent = money(0);
          el('saveTime').textContent = '—';
          el('saveHint').textContent = 'Add a step-up or prepayment above to see how much interest you save on your loan.';
        }
        for (var k = 0; k < opt.rows.length; k++){
          var row = opt.rows[k], tr = document.createElement('tr');
          tr.innerHTML = '<td>' + row.yr + '</td><td>' + money(row.pmt) + '</td><td>' + money(row.prin) +
            '</td><td>' + money(row.int) + '</td><td>' + (row.extra > 0 ? money(row.extra) : '—') +
            '</td><td>' + money(row.bal) + '</td>';
          body.appendChild(tr);
        }
      }
      pair('price','priceR');pair('down','downR');pair('rate','rateR');pair('term','termR');pair('tax','taxR');pair('ins','insR');
      pair('stepup','stepupR');pair('annual','annualR');pair('onetime','onetimeR');pair('otyear','otyearR');
      el('cur').addEventListener('change',function(){var o=el('cur').selectedOptions[0];cur=el('cur').value;loc=o.dataset.loc;document.querySelectorAll('.valwrap .sym').forEach(function(s){s.textContent=o.dataset.sym;});compute();});
      compute();
    })();
  </script>
</Base>
