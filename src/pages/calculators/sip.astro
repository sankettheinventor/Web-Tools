---
import Base from '../../layouts/Base.astro';
import Faq from '../../components/Faq.astro';
import AppLd from '../../components/AppLd.astro';
const title = 'SIP Calculator with Step-Up & Inflation';
const description = 'Free SIP calculator with annual step-up and inflation-adjusted real corpus. See total invested, nominal & real future value plus a year-by-year table — live in your browser.';
const faqItems = [
  {
    q: 'What does this SIP calculator estimate?',
    a: 'It estimates the future value of a monthly Systematic Investment Plan using the standard monthly-compounding formula, and splits the result into the amount you invested and your estimated returns.',
  },
  {
    q: 'How is the SIP future value calculated?',
    a: 'It uses FV = P × [((1 + i)ⁿ − 1) ÷ i] × (1 + i), where P is your monthly investment, i is the monthly rate (expected annual return ÷ 12 ÷ 100) and n is the number of months. It assumes a constant expected return each month.',
  },
  {
    q: 'What is a SIP step-up and how does inflation adjustment work?',
    a: 'A step-up raises your monthly SIP by a fixed percentage each year, so your investment grows with your income — even a 10% annual step-up can add a large amount to the final corpus. The inflation adjustment then discounts the nominal corpus back to today’s money, showing the real corpus: what your future value is actually worth in purchasing power.',
  },
  {
    q: 'Are the returns guaranteed?',
    a: 'No. The calculator assumes a fixed expected rate you enter, but actual mutual fund returns vary year to year and are never guaranteed. Treat the result as an estimate, not a promise.',
  },
  {
    q: 'Which currencies can I use?',
    a: 'You can switch between Indian Rupee, US Dollar, Euro and British Pound, and the symbol plus number formatting update automatically across the inputs and results.',
  },
  {
    q: 'Is my data uploaded or stored?',
    a: 'No. Everything is processed locally in your browser. Your inputs are never uploaded, stored, or shared, and no calculation leaves your device.',
  },
];
---
<Base title={title} description={description}>
  <header class="head"><div class="wrap">
    <p class="kicker">Finance Calculator</p>
    <h1>SIP Calculator</h1>
    <p>Drag the sliders for amount, return and years, then add a step-up or inflation rate to see your real corpus — live, in your browser.</p>
  </div></header>

  <div class="wrap">
    <div class="tool">
      <div class="field">
        <div class="field-top"><label for="cur">Currency</label></div>
        <select id="cur" aria-label="Currency">
          <option value="INR" data-sym="₹" data-loc="en-IN" selected>₹ Indian Rupee (INR)</option>
          <option value="USD" data-sym="$" data-loc="en-US">$ US Dollar (USD)</option>
          <option value="EUR" data-sym="€" data-loc="de-DE">€ Euro (EUR)</option>
          <option value="GBP" data-sym="£" data-loc="en-GB">£ British Pound (GBP)</option>
        </select>
      </div>
      <div class="field">
        <div class="field-top"><label for="amt">Monthly investment</label>
          <div class="valwrap"><span class="sym">₹</span><input id="amt" type="number" inputmode="decimal" min="0" value="5000" /></div></div>
        <input id="amtR" type="range" min="500" max="200000" step="500" value="5000" aria-label="Monthly investment" />
      </div>
      <div class="grid2">
        <div class="field">
          <div class="field-top"><label for="rate">Expected return</label>
            <div class="valwrap"><input id="rate" type="number" inputmode="decimal" min="0" step="0.1" value="12" /><span>%</span></div></div>
          <input id="rateR" type="range" min="1" max="30" step="0.5" value="12" aria-label="Expected annual return" />
        </div>
        <div class="field">
          <div class="field-top"><label for="years">Duration</label>
            <div class="valwrap"><input id="years" type="number" inputmode="numeric" min="1" value="15" /><span>yr</span></div></div>
          <input id="yearsR" type="range" min="1" max="40" step="1" value="15" aria-label="Duration in years" />
        </div>
      </div>

      <div class="result" aria-live="polite">
        <div class="rlabel">Estimated future value</div>
        <div class="rbig" id="fv">—</div>
        <div class="rsub" id="sub"></div>
        <div class="breakdown">
          <div class="bd"><div class="k">You invested</div><div class="v" id="bdInv">—</div></div>
          <div class="bd"><div class="k">Estimated returns</div><div class="v" id="bdRet">—</div></div>
        </div>
      </div>

      <div class="adv">
        <div class="adv-h"><span>📈 Beat inflation</span><small>Optional — model an annual step-up &amp; inflation an AI snippet can't compute</small></div>
        <div class="grid2">
          <div class="field">
            <div class="field-top"><label for="stepup">Annual SIP step-up</label>
              <div class="valwrap"><input id="stepup" type="number" inputmode="numeric" min="0" max="50" step="1" value="0" /><span>%/yr</span></div></div>
            <input id="stepupR" type="range" min="0" max="25" step="1" value="0" aria-label="Annual SIP step-up percent" />
          </div>
          <div class="field">
            <div class="field-top"><label for="infl">Inflation rate</label>
              <div class="valwrap"><input id="infl" type="number" inputmode="decimal" min="0" max="20" step="0.1" value="0" /><span>%/yr</span></div></div>
            <input id="inflR" type="range" min="0" max="15" step="0.5" value="0" aria-label="Inflation rate percent" />
          </div>
        </div>

        <div class="save" aria-live="polite">
          <div class="save-row">
            <div class="save-box"><div class="k">Total invested</div><div class="v" id="advInv">—</div></div>
            <div class="save-box"><div class="k">Nominal corpus</div><div class="v ok" id="advNom">—</div></div>
          </div>
          <div class="save-row">
            <div class="save-box"><div class="k">Real corpus (today's money)</div><div class="v" id="advReal">—</div></div>
            <div class="save-box"><div class="k">Step-up boost</div><div class="v" id="advBoost">—</div></div>
          </div>
          <p class="save-hint" id="saveHint">Add a step-up or inflation rate above to see your real, inflation-adjusted corpus.</p>
        </div>

        <details class="sched">
          <summary>Year-by-year growth schedule</summary>
          <div class="sched-wrap">
            <table>
              <thead><tr><th>Yr</th><th>SIP/mo</th><th>Invested</th><th>Nominal value</th><th>Real value</th></tr></thead>
              <tbody id="schedBody"></tbody>
            </table>
          </div>
        </details>
      </div>
    </div>
  </div>

  <div class="ad">Advertisement</div>

  <div class="content">
    <h2>How SIP returns are calculated</h2>
    <p>A SIP (Systematic Investment Plan) invests a fixed amount every month. Each instalment buys units at that month's price and then compounds. The future value uses the standard monthly-compounding formula:</p>
    <div class="formula">FV = P × [ ((1 + i)ⁿ − 1) ÷ i ] × (1 + i)</div>
    <p>where <b>P</b> is the monthly investment, <b>i</b> is the monthly return (expected annual return ÷ 12 ÷ 100) and <b>n</b> is the number of months.</p>
    <h3>Rupee-cost averaging</h3>
    <p>Because you invest the same amount monthly, you automatically buy more units when prices are low and fewer when they're high. This averaging smooths out market ups and downs over time.</p>

    <h3>Step-up and inflation: the real story</h3>
    <p>Two levers decide what your SIP is actually worth, and a one-line snippet can't model either:</p>
    <ul>
      <li><b>Annual step-up</b> — raising your monthly SIP a few percent each year, in line with salary growth, compounds far more than a flat SIP. A 10%/year step-up can add a large amount to the final corpus over a long horizon.</li>
      <li><b>Inflation</b> — a corpus that looks huge in future rupees buys far less than it seems. The real corpus discounts the nominal figure back to today's money, so you know its true purchasing power.</li>
    </ul>
    <p>The year-by-year table above shows your rising SIP, the invested total, and both the nominal and inflation-adjusted real value each year — the kind of multi-variable answer you have to model with your own numbers.</p>
    <p><em>Returns are an estimate based on a constant expected rate. Actual market returns vary year to year and are not guaranteed.</em></p>
    <div class="xlinks">
      <a href="/calculators/compound-interest">Compound Interest →</a>
      <a href="/#calculators">All calculators →</a>
    </div>
  </div>

  <AppLd name="SIP Calculator with Step-Up & Inflation" description="Drag the sliders for monthly amount, expected return and duration, add an annual step-up and inflation rate, and watch your nominal and inflation-adjusted real SIP corpus recalculate live." category="FinanceApplication" features={["Live sliders for monthly investment, expected return and duration", "Instant future value and invested-vs-returns breakdown", "Model an annual SIP step-up for income growth", "Inflation-adjusted real corpus in today's money", "Year-by-year growth schedule (invested, nominal & real)", "Switch between INR, USD, EUR and GBP", "Runs fully in your browser, nothing uploaded"]} />

  <Faq items={faqItems} />

  <style is:global>
    .adv{margin-top:var(--s5);border-top:1px solid var(--line);padding-top:var(--s5)}
    .adv-h{display:flex;align-items:baseline;gap:var(--s3);margin-bottom:var(--s4);flex-wrap:wrap}
    .adv-h span{font-weight:800;font-size:var(--t-md)}
    .adv-h small{color:var(--dim);font-size:var(--t-sm)}
    .save{background:var(--result-bg);border:1px solid var(--line);border-radius:var(--r-lg);padding:var(--s4);margin-top:var(--s4)}
    .save-row{display:grid;grid-template-columns:1fr 1fr;gap:var(--s3)}
    .save-row+.save-row{margin-top:var(--s3)}
    .save-box{background:var(--surface);border:1px solid var(--line);border-radius:var(--r);padding:var(--s3) var(--s4)}
    .save-box .k{font-size:var(--t-xs);color:var(--dim)}
    .save-box .v{font-size:var(--t-lg);font-weight:800;margin-top:2px}
    .save-box .v.ok{color:var(--ok)}
    .save-hint{font-size:var(--t-sm);color:var(--dim);margin-top:var(--s3);line-height:1.5}
    .sched{margin-top:var(--s4)}
    .sched summary{cursor:pointer;font-weight:700;font-size:var(--t-sm);color:var(--brand);padding:var(--s2) 0}
    .sched-wrap{overflow-x:auto;margin-top:var(--s3)}
    .sched table{width:100%;border-collapse:collapse;font-size:var(--t-sm);min-width:540px}
    .sched th,.sched td{text-align:right;padding:var(--s2) var(--s3);border-bottom:1px solid var(--line);white-space:nowrap}
    .sched th:first-child,.sched td:first-child{text-align:left}
    .sched th{color:var(--dim);font-weight:700;font-size:var(--t-xs);text-transform:uppercase;letter-spacing:.4px}
  </style>

  <script is:inline>
    (function () {
      var cur='INR', loc='en-IN';
      function el(id){return document.getElementById(id);}
      function num(id){var v=parseFloat(el(id).value);return isFinite(v)?v:0;}
      function money(v){try{return new Intl.NumberFormat(loc,{style:'currency',currency:cur,maximumFractionDigits:0}).format(Math.round(v));}catch(e){return Math.round(v).toLocaleString();}}
      function pair(a,b){el(a).addEventListener('input',function(){el(b).value=el(a).value;compute();});el(b).addEventListener('input',function(){el(a).value=el(b).value;compute();});}
      // Month-by-month SIP growth with optional annual step-up + inflation discounting.
      // Returns nominal corpus, total invested, and per-year rows. With stepup=0 and infl=0
      // it reduces exactly to the standard SIP future-value formula.
      function simulate(P0, i, Y, stepup, infl){
        var n=Y*12, bal=0, sip=P0, invested=0;
        var rows=[];
        for (var m=1; m<=n; m++){
          bal=(bal+sip)*(1+i);   // annuity-due: invest at start of month, then grow — matches closed-form FV
          invested+=sip;
          if (m%12===0){
            var yr=m/12;
            var realFactor=(infl>0)?Math.pow(1+infl/100, yr):1;
            rows.push({ yr:yr, sip:sip, invested:invested, nom:bal, real:bal/realFactor });
            if (stepup>0) sip=sip*(1+stepup/100);   // raise SIP for the next year
          }
        }
        var realFactorEnd=(infl>0)?Math.pow(1+infl/100, Y):1;
        return { nom:bal, invested:invested, real:bal/realFactorEnd, rows:rows };
      }
      function compute(){
        var P=num('amt'), R=num('rate'), Y=num('years');
        var i=R/12/100, n=Y*12;
        // Primary result — unchanged closed-form SIP future value.
        var fv=(i>0)?P*((Math.pow(1+i,n)-1)/i)*(1+i):P*n;
        var invested=P*n, returns=fv-invested;
        el('fv').textContent=money(fv);
        el('sub').textContent=Y+' years · '+R+'% expected';
        el('bdInv').textContent=money(invested);
        el('bdRet').textContent=money(returns);

        // Advanced: step-up + inflation-adjusted real corpus.
        var stepup=num('stepup'), infl=num('infl');
        var base=simulate(P, i, Y, 0, 0);          // baseline (matches closed-form fv)
        var opt=simulate(P, i, Y, stepup, infl);   // with step-up + inflation
        el('advInv').textContent=money(opt.invested);
        el('advNom').textContent=money(opt.nom);
        el('advReal').textContent=money(opt.real);
        var boost=opt.nom-base.nom;
        el('advBoost').textContent=(stepup>0 && boost>0.5)?'+'+money(boost):money(0);
        var hasAdv=(stepup>0 || infl>0);
        if (hasAdv){
          var parts=[];
          if (stepup>0) parts.push('a '+stepup+'%/yr step-up adds '+money(boost)+' to your corpus');
          if (infl>0) parts.push('after '+infl+'% inflation it’s worth '+money(opt.real)+' in today’s money');
          el('saveHint').textContent=parts.join(', ')+'.';
        } else {
          el('saveHint').textContent='Add a step-up or inflation rate above to see your real, inflation-adjusted corpus.';
        }

        var body=el('schedBody'); body.innerHTML='';
        for (var k=0; k<opt.rows.length; k++){
          var row=opt.rows[k], tr=document.createElement('tr');
          tr.innerHTML='<td>'+row.yr+'</td><td>'+money(row.sip)+'</td><td>'+money(row.invested)+
            '</td><td>'+money(row.nom)+'</td><td>'+money(row.real)+'</td>';
          body.appendChild(tr);
        }
      }
      pair('amt','amtR');pair('rate','rateR');pair('years','yearsR');
      pair('stepup','stepupR');pair('infl','inflR');
      el('cur').addEventListener('change',function(){var o=el('cur').selectedOptions[0];cur=el('cur').value;loc=o.dataset.loc;document.querySelectorAll('.valwrap .sym').forEach(function(s){s.textContent=o.dataset.sym;});compute();});
      compute();
    })();
  </script>
</Base>
