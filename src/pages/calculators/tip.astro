---
import Base from '../../layouts/Base.astro';
import Faq from '../../components/Faq.astro';
const title = 'Tip Calculator — Tip & Bill Split (Free, Instant)';
const description = 'Free tip calculator. Enter the bill, choose a tip percentage and split between people to see the tip, total and amount per person instantly.';
const faqItems = [
  { q: 'How does this tip calculator work?', a: 'It multiplies your bill by the tip percentage to get the tip amount, adds that to the bill for the total, then divides by the number of people. Results update instantly as you type or drag the sliders.' },
  { q: 'How much should I tip?', a: 'In the US, 15-20% is common for good service in restaurants, while many other countries tip less or not at all. Adjust the tip slider to match your local custom and the quality of service.' },
  { q: 'Can I split the bill between several people?', a: 'Yes. Set the "Split between" field to the number of people and the calculator shows how much each person pays, including their share of the tip.' },
  { q: 'Which currencies are supported?', a: 'You can choose US Dollar, Indian Rupee, Euro or British Pound, and the results are formatted with the matching currency symbol and number style.' },
  { q: 'Is my bill data uploaded or stored?', a: 'No. Everything is calculated locally in your browser. Nothing you enter is uploaded, stored or shared.' },
];
---
<Base title={title} description={description}>
  <header class="head"><div class="wrap">
    <p class="kicker">Everyday Calculator</p><h1>Tip Calculator</h1>
    <p>Tip and split the bill in seconds.</p>
  </div></header>
  <div class="wrap"><div class="tool">
    <div class="field"><div class="field-top"><label for="cur">Currency</label></div>
      <select id="cur" aria-label="Currency">
        <option value="USD" data-sym="$" data-loc="en-US" selected>$ US Dollar (USD)</option>
        <option value="INR" data-sym="₹" data-loc="en-IN">₹ Indian Rupee (INR)</option>
        <option value="EUR" data-sym="€" data-loc="de-DE">€ Euro (EUR)</option>
        <option value="GBP" data-sym="£" data-loc="en-GB">£ British Pound (GBP)</option>
      </select></div>
    <div class="field"><div class="field-top"><label for="bill">Bill amount</label>
      <div class="valwrap"><span class="sym">$</span><input id="bill" type="number" inputmode="decimal" min="0" value="50" /></div></div>
      <input id="billR" type="range" min="0" max="1000" step="1" value="50" aria-label="Bill amount" /></div>
    <div class="grid2">
      <div class="field"><div class="field-top"><label for="tip">Tip</label>
        <div class="valwrap"><input id="tip" type="number" inputmode="decimal" min="0" step="1" value="15" /><span>%</span></div></div>
        <input id="tipR" type="range" min="0" max="30" step="1" value="15" aria-label="Tip percent" /></div>
      <div class="field"><div class="field-top"><label for="split">Split between</label>
        <div class="valwrap"><input id="split" type="number" inputmode="numeric" min="1" value="2" /><span>ppl</span></div></div>
        <input id="splitR" type="range" min="1" max="20" step="1" value="2" aria-label="Split between people" /></div>
    </div>
    <div class="result" aria-live="polite">
      <div class="rlabel">Each person pays</div><div class="rbig" id="each">—</div><div class="rsub" id="sub"></div>
      <div class="breakdown">
        <div class="bd"><div class="k">Tip amount</div><div class="v" id="bdTip">—</div></div>
        <div class="bd"><div class="k">Total bill</div><div class="v" id="bdTot">—</div></div>
      </div>
    </div>
  </div></div>
  <div class="ad">Ad space</div>
  <div class="content">
    <h2>How to calculate a tip</h2>
    <p>Multiply the bill by the tip percentage, add it to the bill, then divide by the number of people:</p>
    <div class="formula">per person = ( bill × (1 + tip%) ) ÷ people</div>
    <p>Common tips are 15–20% in the US for good service; many other countries tip less or not at all. Adjust the slider to match your situation.</p>
    <div class="xlinks"><a href="/calculators/percentage">Percentage →</a><a href="/#everyday">All calculators →</a></div>
  </div>
  <Faq items={faqItems} />
  <script is:inline>
    (function(){var cur='USD',loc='en-US';function el(i){return document.getElementById(i);}function num(i){var v=parseFloat(el(i).value);return isFinite(v)?v:0;}
    function money(v){try{return new Intl.NumberFormat(loc,{style:'currency',currency:cur,maximumFractionDigits:2}).format(v);}catch(e){return v.toFixed(2);}}
    function pair(a,b){el(a).addEventListener('input',function(){el(b).value=el(a).value;c();});el(b).addEventListener('input',function(){el(a).value=el(b).value;c();});}
    function c(){var bill=num('bill'),tip=num('tip'),split=Math.max(1,num('split'));var tipAmt=bill*tip/100,total=bill+tipAmt;
      el('each').textContent=money(total/split);el('sub').textContent='split between '+split;
      el('bdTip').textContent=money(tipAmt);el('bdTot').textContent=money(total);}
    pair('bill','billR');pair('tip','tipR');pair('split','splitR');
    el('cur').addEventListener('change',function(){var o=el('cur').selectedOptions[0];cur=el('cur').value;loc=o.dataset.loc;document.querySelectorAll('.valwrap .sym').forEach(function(s){s.textContent=o.dataset.sym;});c();});c();})();
  </script>
</Base>
