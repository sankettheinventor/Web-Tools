---
const {
  title = 'SnapJar — Free Online Calculators & Image Tools',
  description = 'Free, fast, private online tools. Calculators and image utilities that run entirely in your browser — no signup, no upload, your data never leaves your device.',
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

// ===== AdSense: paste your publisher ID here once approved (e.g. ca-pub-1234567890123456)
// Leaving it empty keeps ads OFF site-wide (placeholders show instead). Hybrid model:
// this enables Google Auto Ads (ML placement); manual <AdSlot/> components add controlled spots.
const ADSENSE_CLIENT = '';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="robots" content="index, follow" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta name="theme-color" content="#5b54e6" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚡</text></svg>" />
  <link rel="stylesheet" href="/assets/style.css" />
  <script is:inline src="/assets/cloud-import.js"></script>
  <script is:inline>
    (function () {
      try {
        var t = localStorage.getItem('theme');
        if (!t) t = matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', t);
      } catch (e) { document.documentElement.setAttribute('data-theme', 'dark'); }
    })();
  </script>
  {ADSENSE_CLIENT && (
    <script async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_CLIENT}`} crossorigin="anonymous"></script>
  )}
  <slot name="head" />
</head>
<body>
  <div class="promise">
    <span class="pi">Free</span>
    <span class="pi">No signup</span>
    <span class="pi">No upload</span>
    <span class="pi strong">Your data never leaves your device</span>
  </div>
  <nav><div class="nav-in">
    <a class="brand" href="/"><span class="logo">⚡</span> SnapJar</a>
    <div class="nav-links">
      <div class="mega-wrap">
        <button class="mega-trigger" id="megaBtn" type="button" aria-haspopup="true" aria-expanded="false" aria-controls="megaPanel">Products <span class="caret" aria-hidden="true">▾</span></button>
        <div class="mega" id="megaPanel" role="menu" aria-label="All products">
          <div class="mega-col">
            <div class="mega-h">💰 Finance</div>
            <a role="menuitem" href="/calculators/emi">EMI Calculator</a>
            <a role="menuitem" href="/calculators/mortgage">Mortgage</a>
            <a role="menuitem" href="/calculators/sip">SIP Calculator</a>
            <a role="menuitem" href="/calculators/income-tax">Income Tax</a>
            <a role="menuitem" class="all" href="/#calculators">All 9 finance →</a>
          </div>
          <div class="mega-col">
            <div class="mega-h">📐 Everyday</div>
            <a role="menuitem" href="/calculators/percentage">Percentage</a>
            <a role="menuitem" href="/calculators/bmi">BMI</a>
            <a role="menuitem" href="/calculators/age">Age</a>
            <a role="menuitem" href="/calculators/unit-converter">Unit Converter</a>
            <a role="menuitem" class="all" href="/#everyday">All everyday →</a>
          </div>
          <div class="mega-col">
            <div class="mega-h">🖼️ Image</div>
            <a role="menuitem" href="/tools/watermark">Watermark Studio</a>
            <a role="menuitem" href="/tools/compress">Image Compressor</a>
            <a role="menuitem" href="/tools/convert">Convert &amp; Resize</a>
            <a role="menuitem" href="/tools/heic-to-jpg">HEIC → JPG</a>
            <a role="menuitem" class="all" href="/#converters">Format converters →</a>
          </div>
          <div class="mega-col">
            <div class="mega-h">🎨 Color</div>
            <a role="menuitem" href="/tools/color-picker">Color Picker</a>
            <a role="menuitem" href="/tools/palette-extractor">Palette Extractor</a>
            <a role="menuitem" href="/tools/color-converter">Color Converter</a>
            <a role="menuitem" href="/tools/gradient-generator">Gradient Generator</a>
          </div>
          <div class="mega-col">
            <div class="mega-h">📝 Text &amp; Files</div>
            <a role="menuitem" href="/tools/word-counter">Word Counter</a>
            <a role="menuitem" href="/tools/case-converter">Case Converter</a>
            <a role="menuitem" href="/tools/text-to-pdf">Text to PDF</a>
            <a role="menuitem" href="/tools/qr-code">QR Code</a>
            <a role="menuitem" href="/tools/favicon">Favicon &amp; Icons</a>
            <a role="menuitem" class="all" href="https://elegant-crostata-510d7b.netlify.app/" target="_blank" rel="noopener">Video Downloader ↗</a>
          </div>
        </div>
      </div>
      <a href="/blog" class="hide-sm">Blog</a>
      <a href="/about" class="hide-sm">About</a>
      <button id="theme-toggle" class="theme-btn" type="button" aria-label="Toggle light or dark theme" title="Toggle theme">🌙</button>
    </div>
  </div></nav>

  <slot />

  <section class="trust-strip">
    <div class="wrap trust-in">
      <div class="trust-lead">🛡️ <b>Built for privacy.</b> Every tool runs entirely on your device — your files and data never reach a server.</div>
      <div class="trust-badges">
        <span class="tb">🔒 On-device processing</span>
        <span class="tb">🚫 No data collected</span>
        <span class="tb">🇪🇺 GDPR-friendly</span>
        <span class="tb">✅ No sign-up</span>
      </div>
    </div>
  </section>

  <footer>
    <div class="wrap foot-in">
      <div class="foot-col" style="max-width:280px">
        <a class="brand" href="/" style="margin-bottom:10px"><span class="logo">⚡</span> SnapJar</a>
        <p style="color:var(--dim)">29 free calculators &amp; image tools that run 100% in your browser. No signup, no upload — your data never leaves your device.</p>
      </div>
      <div class="foot-col">
        <h4>Finance</h4>
        <a href="/calculators/emi">EMI Calculator</a>
        <a href="/calculators/mortgage">Mortgage</a>
        <a href="/calculators/sip">SIP</a>
        <a href="/calculators/income-tax">Income Tax</a>
        <a href="/calculators/fd">FD Calculator</a>
        <a href="/#calculators">All finance →</a>
      </div>
      <div class="foot-col">
        <h4>Everyday</h4>
        <a href="/calculators/percentage">Percentage</a>
        <a href="/calculators/bmi">BMI</a>
        <a href="/calculators/age">Age</a>
        <a href="/calculators/discount">Discount &amp; GST</a>
        <a href="/calculators/unit-converter">Unit Converter</a>
      </div>
      <div class="foot-col">
        <h4>Image &amp; Files</h4>
        <a href="/tools/watermark">Watermark Studio</a>
        <a href="/tools/compress">Image Compressor</a>
        <a href="/tools/heic-to-jpg">HEIC → JPG</a>
        <a href="/#converters">JPG/PNG/WebP</a>
        <a href="/tools/pdf-tools">Merge PDF</a>
      </div>
      <div class="foot-col">
        <h4>Utilities</h4>
        <a href="/tools/qr-code">QR Code Generator</a>
        <a href="/tools/favicon">Favicon &amp; Icons</a>
        <a href="/tools/svg-optimizer">SVG Optimizer</a>
        <a href="/tools/color-picker">Color Picker</a>
        <a href="/tools/word-counter">Word Counter</a>
      </div>
    </div>
    <div class="foot-bottom">
      <p class="legal">© 2026 SnapJar. All tools run locally in your browser; no files or inputs are uploaded to any server. Calculator results are estimates for general information only and are not financial advice.</p>
      <nav class="foot-legal" aria-label="Legal"><a href="/about">About</a><a href="/privacy-policy">Privacy</a><a href="/terms">Terms</a></nav>
    </div>
  </footer>

  <script is:inline>
    (function () {
      var btn = document.getElementById('theme-toggle');
      if (!btn) return;
      function sync(){ btn.textContent = document.documentElement.getAttribute('data-theme') === 'dark' ? '☀️' : '🌙'; }
      sync();
      btn.addEventListener('click', function () {
        var next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        try { localStorage.setItem('theme', next); } catch (e) {}
        sync();
      });
    })();

    // Products mega menu — click to open, Esc / outside-click to close (keyboard-safe)
    (function () {
      var mb = document.getElementById('megaBtn'), mp = document.getElementById('megaPanel');
      if (!mb || !mp) return;
      function close(){ mp.classList.remove('open'); mb.setAttribute('aria-expanded','false'); }
      mb.addEventListener('click', function (e) {
        e.stopPropagation();
        var open = mp.classList.toggle('open');
        mb.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
      document.addEventListener('click', function (e) {
        if (!mp.contains(e.target) && e.target !== mb) close();
      });
      document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
      mp.querySelectorAll('a').forEach(function (a) { a.addEventListener('click', close); });
    })();
  </script>
</body>
</html>
