        btn.type = 'button'; btn.className = 'csel-btn';
        btn.setAttribute('aria-haspopup', 'listbox'); btn.setAttribute('aria-expanded', 'false');
        var lblEl = (sel.id && document.querySelector('label[for="' + sel.id + '"]')) || sel.closest('label');
        var lblTxt = sel.getAttribute('aria-label') || (lblEl && lblEl.textContent.trim());
        if (lblTxt) btn.setAttribute('aria-label', lblTxt);
        var lblNode = document.createElement('span'); lblNode.className = 'csel-lbl';
        btn.appendChild(lblNode);
        btn.insertAdjacentHTML('beforeend', SVG_CHEV);
        wrap.appendChild(btn);

        var pop = document.createElement('div');
        pop.className = 'csel-pop'; pop.setAttribute('role', 'listbox');
        document.body.appendChild(pop);

        var inst = { sel: sel, btn: btn, pop: pop, active: -1 };

        function syncBtn() {
          var o = sel.options[sel.selectedIndex];
          lblNode.innerHTML = '';
          fillNode(lblNode, splitLabel(o ? o.textContent : ''));
        }

        function buildPop() {
          pop.innerHTML = '';
          for (var i = 0; i < sel.options.length; i++) {
            (function (o, idx) {
              var opt = document.createElement('button');
              opt.type = 'button'; opt.className = 'csel-opt'; opt.setAttribute('role', 'option');
              opt.setAttribute('aria-selected', idx === sel.selectedIndex ? 'true' : 'false');
              var t = document.createElement('span'); t.className = 'csel-opt-txt';
              fillNode(t, splitLabel(o.textContent));
              opt.appendChild(t);
              opt.insertAdjacentHTML('beforeend', SVG_TICK);
              opt.addEventListener('click', function () { pick(idx); });
              opt.addEventListener('mousemove', function () { setActive(idx); });
              pop.appendChild(opt);
            })(sel.options[i], i);
          }
        }
        function setActive(i) {
          var opts = pop.children;
          if (inst.active >= 0 && opts[inst.active]) opts[inst.active].classList.remove('active');
          inst.active = i;
          if (i >= 0 && opts[i]) { opts[i].classList.add('active'); opts[i].scrollIntoView({ block: 'nearest' }); }
        }
        function place() {
          var r = btn.getBoundingClientRect();
          pop.style.width = r.width + 'px';
          pop.style.left = r.left + 'px';
          var h = pop.offsetHeight, gap = 6;
          var below = window.innerHeight - r.bottom, above = r.top;
          if (below < h + gap && above > below) {
            pop.classList.add('up'); pop.style.top = Math.max(gap, r.top - h - gap) + 'px';
          } else {
            pop.classList.remove('up'); pop.style.top = (r.bottom + gap) + 'px';
          }
        }
        function open() {
          if (openInst && openInst !== inst) openInst.close();
          buildPop();
          place();                    // offsetHeight is valid while still at opacity 0
          pop.classList.add('open');  // then animate in from the placed position
          btn.setAttribute('aria-expanded', 'true');
          setActive(sel.selectedIndex);
          openInst = inst;
          window.addEventListener('scroll', onScroll, true);
          window.addEventListener('resize', place);
        }
        function close() {
          pop.classList.remove('open'); btn.setAttribute('aria-expanded', 'false');
          window.removeEventListener('scroll', onScroll, true);
          window.removeEventListener('resize', place);
          if (openInst === inst) openInst = null;
        }
        function onScroll() { place(); }
        function pick(i) {
          if (i !== sel.selectedIndex) {
            sel.selectedIndex = i;
            sel.dispatchEvent(new Event('input', { bubbles: true }));
            sel.dispatchEvent(new Event('change', { bubbles: true }));
          }
          syncBtn(); close(); btn.focus();
        }
        inst.close = close;

        btn.addEventListener('click', function () {
          if (pop.classList.contains('open')) close(); else open();
        });
        btn.addEventListener('keydown', function (e) {
          var isOpen = pop.classList.contains('open');
          if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
            e.preventDefault();
            if (!isOpen) { open(); return; }
            var n = pop.children.length, next = inst.active < 0 ? 0 : inst.active + (e.key === 'ArrowDown' ? 1 : -1);
            setActive((next + n) % n);
          } else if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            if (!isOpen) open(); else if (inst.active >= 0) pick(inst.active);
          } else if (e.key === 'Escape') {
            if (isOpen) { e.preventDefault(); close(); }
          } else if (e.key === 'Home' && isOpen) { e.preventDefault(); setActive(0); }
          else if (e.key === 'End' && isOpen) { e.preventDefault(); setActive(pop.children.length - 1); }
        });
        pop.addEventListener('keydown', function (e) { if (e.key === 'Escape') { e.preventDefault(); close(); btn.focus(); } });

        // outside click / native change / dynamic option changes
        document.addEventListener('pointerdown', function (e) {
          if (pop.classList.contains('open') && !pop.contains(e.target) && !btn.contains(e.target)) close();
        });
        sel.addEventListener('change', syncBtn);
        try {
          new MutationObserver(function () { syncBtn(); if (pop.classList.contains('open')) buildPop(); })
            .observe(sel, { childList: true });
        } catch (e) {}

        syncBtn();
      }

      function init() {
        var sels = document.querySelectorAll('select');
        for (var i = 0; i < sels.length; i++) { try { enhance(sels[i]); } catch (e) {} }
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
      else init();
    })();
  </script>}
