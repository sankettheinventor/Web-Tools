---
import BottomNav from '../app/BottomNav.astro';
const {
  title = 'SnapJar — Free Online Calculators & Image Tools',
  description = 'Free, fast, private online tools. Calculators and image utilities that run entirely in your browser — no signup, no upload, your data never leaves your device.',
} = Astro.props;
const SITE = Astro.site ?? new URL('https://snapjar.sankettoraskar-business.workers.dev/');
const canonical = new URL(Astro.url.pathname, SITE).href;
const ogImage = new URL('/og.png', SITE).href;
const isHome = Astro.url.pathname === '/';

// Sitewide structured data: Organization + WebSite (helps Google understand the
// brand + enables sitelinks search box). Emitted once per page in the head.
const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'SnapJar',
  url: SITE.href,
  logo: new URL('/icon-512.png', SITE).href,
};
const siteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'SnapJar',
  url: SITE.href,
  description: 'Free online calculators and image tools that run entirely in your browser.',
};

// ===== AdSense: paste your publisher ID here once approved (e.g. ca-pub-1234567890123456)
// Leaving it empty keeps ads OFF site-wide (placeholders show instead). Hybrid model:
// this enables Google Auto Ads (ML placement); manual <AdSlot/> components add controlled spots.
const ADSENSE_CLIENT = '';

// ===== App build flag. Set PUBLIC_APP_BUILD=1 when building the bundle that ships
// inside the Capacitor (SnapJar mobile) app, e.g. `PUBLIC_APP_BUILD=1 npm run build`.
// In the app we strip everything that (a) reaches the network — so "your data never
// leaves your device" is literally true — or (b) would risk a Play/App Store rejection
// (the external video-downloader link, file 16 Rule #2). The plain web build is unchanged.
const IS_APP = import.meta.env.PUBLIC_APP_BUILD === '1';
// In the app, internal /tools/x and /calculators/x links must hit the real .html file —
// Capacitor's WebView serves exact files, and extensionless/dir paths fall back to the
// home. Intercept link clicks and append .html. The web build (pretty URLs) is untouched.
const APP_LINK_FIX = `(function(){document.addEventListener('click',function(e){var a=e.target&&e.target.closest&&e.target.closest('a[href]');if(!a)return;var h=a.getAttribute('href')||'';var m=h.match(/^(\\/(?:tools|calculators)\\/[a-z0-9-]+|\\/recent)([?#].*)?$/);if(m){e.preventDefault();location.href=m[1]+'.html'+(m[2]||'');}},true);})();`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="robots" content="index, follow" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="SnapJar" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="SnapJar — free online calculators & image tools" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="theme-color" content="#5b54e6" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚡</text></svg>" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <link rel="stylesheet" href="/assets/style.css" />
  {IS_APP && <link rel="stylesheet" href="/assets/app.css" />}
  <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
  {isHome && <script type="application/ld+json" set:html={JSON.stringify(siteLd)} />}
  {!IS_APP && <script is:inline defer src="/assets/cloud-import.js"></script>}
  <script is:inline>
    (function () {
      try {
        var t = localStorage.getItem('theme');
        if (!t) t = matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', t);
      } catch (e) { document.documentElement.setAttribute('data-theme', 'dark'); }
    })();
  </script>
  <script is:inline>
    /* ===== SnapJarKit — shared robustness toolkit (ONE source of truth) =====
       Loaded before every tool. Closes the recurring root-cause bugs (canvas OOM,
       frozen-on-bad-input, double-submit, blob leaks) so tools call helpers instead
       of each re-implementing (and re-breaking) them. Plain global so BOTH inline and
       bundled tool scripts can use it. */
    (function () {
      var MAX_SIDE = 4096, MAX_AREA = 16777216; // GPU-safe ceiling for budget Android WebViews
      var K = {
        MAX_SIDE: MAX_SIDE, MAX_AREA: MAX_AREA,
        /* Scale (w,h) down to a canvas a budget phone can actually allocate.
           Returns {w,h,scale,clamped}; scale=1 when no clamp needed (the common case). */
        fitDims: function (w, h) {
          w = Math.max(1, w | 0); h = Math.max(1, h | 0);
          var s = 1;
          if (w > MAX_SIDE || h > MAX_SIDE) s = Math.min(MAX_SIDE / w, MAX_SIDE / h);
          if (w * s * (h * s) > MAX_AREA) s = Math.min(s, Math.sqrt(MAX_AREA / (w * h)));
          return { w: Math.max(1, Math.floor(w * s)), h: Math.max(1, Math.floor(h * s)), scale: s, clamped: s < 1 };
        },
        /* Load an image with onerror + a timeout so a corrupt/huge file can NEVER hang
           the UI forever. Resolves an HTMLImageElement, rejects on error/timeout. */
        loadImage: function (src, timeoutMs) {
          return new Promise(function (resolve, reject) {
            var img = new Image(), done = false;
            var t = setTimeout(function () { if (!done) { done = true; img.src = ''; reject(new Error('Image load timed out')); } }, timeoutMs || 20000);
            img.onload = function () { if (!done) { done = true; clearTimeout(t); resolve(img); } };
            img.onerror = function () { if (!done) { done = true; clearTimeout(t); reject(new Error('Could not load this image — it may be corrupt or unsupported.')); } };
            img.src = src;
          });
        },
        /* Wrap an (async) action so it can't run twice at once: disables the button for
           the duration (kills double-submit + concurrent-op corruption). onErr(e) optional. */
        guard: function (btn, fn, onErr) {
          return function (ev) {
            var b = typeof btn === 'string' ? document.getElementById(btn) : btn;
            if (b && b.disabled) return;
            if (b) b.disabled = true;
            var self = this, args = arguments;
            Promise.resolve().then(function () { return fn.apply(self, args); })
              .catch(function (e) { try { (onErr || function (x) { console.error(x); })(e); } catch (_) {} })
              .then(function () { if (b) b.disabled = false; });
          };
        },
        /* Yield to the UI thread inside long loops so the page never looks frozen
           (and the GC can run between heavy pages). await SnapJarKit.breathe(). */
        breathe: function () { return new Promise(function (r) { setTimeout(r, 0); }); },
        /* Copy text that NEVER throws: tries the async clipboard, falls back to a
           hidden textarea + execCommand (older/locked-down WebViews). Resolves bool. */
        copy: function (text, label) {
          return new Promise(function (res) {
            function done(ok) { K.toast(ok ? (label || 'Copied to clipboard') : 'Couldn’t copy — try long-pressing to copy', ok ? 'ok' : 'err'); res(ok); }
            function fallback() { try { var ta = document.createElement('textarea'); ta.value = text; ta.setAttribute('readonly', ''); ta.style.cssText = 'position:fixed;left:-9999px;top:0;opacity:0'; document.body.appendChild(ta); ta.focus(); ta.select(); var ok = false; try { ok = document.execCommand('copy'); } catch (e) {} document.body.removeChild(ta); done(ok); } catch (e) { done(false); } }
            try {
              if (navigator.clipboard && navigator.clipboard.writeText) { navigator.clipboard.writeText(text).then(function () { done(true); }, fallback); }
              else fallback();
            } catch (e) { fallback(); }
          });
        },
        /* Resolve a Capacitor plugin across runtime variants: the native bridge exposes
           Capacitor.Plugins.X, while @capacitor/core exposes registerPlugin(). Returns
           the plugin object or null (web). One source of truth so tools stop guessing. */
        plugin: function (name) {
          var C = window.Capacitor; if (!C) return null;
          if (C.Plugins && C.Plugins[name]) return C.Plugins[name];
          if (typeof C.registerPlugin === 'function') { try { return C.registerPlugin(name); } catch (e) {} }
          return null;
        },
        /* Object-URL helpers: track() URLs for thumbnails and clear() them on reset
           so batch tools stop leaking decoded bitmaps for the whole session. */
        _urls: [],
        track: function (blob) { var u = URL.createObjectURL(blob); K._urls.push(u); return u; },
        clear: function () { K._urls.forEach(function (u) { try { URL.revokeObjectURL(u); } catch (e) {} }); K._urls = []; },

        /* ===== Messaging — ONE premium voice for every tool =====
           Consistent toasts, classified status states (working/done/error) and a
           styled prompt, so no tool re-invents (or ships an ugly system dialog). */
        _toastHost: null,
        _icon: function (type) {
          if (type === 'ok') return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>';
          if (type === 'err') return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round"><path d="M12 7v7"/><circle cx="12" cy="17.5" r="1.2" fill="currentColor" stroke="none"/></svg>';
          if (type === 'work') return '<span class="sj-spin"></span>';
          return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M12 11v6"/><circle cx="12" cy="7" r="1.2" fill="currentColor" stroke="none"/></svg>';
        },
        /* Transient floating confirmation. type: ok|err|work|info. Returns the node. */
        toast: function (msg, type, ms) {
          type = type || 'info';
          var host = K._toastHost;
          if (!host || !host.isConnected) { host = document.createElement('div'); host.className = 'sj-toasts'; host.setAttribute('role', 'status'); host.setAttribute('aria-live', 'polite'); (document.body || document.documentElement).appendChild(host); K._toastHost = host; }
          var t = document.createElement('div'); t.className = 'sj-toast sj-' + type;
          t.innerHTML = '<span class="sj-tic">' + K._icon(type) + '</span><span class="sj-tmsg"></span>';
          t.lastChild.textContent = msg;
          host.appendChild(t);
          requestAnimationFrame(function () { t.classList.add('in'); });
          var dur = ms || (type === 'err' ? 4200 : 2600);
          setTimeout(function () { t.classList.add('out'); setTimeout(function () { if (t.parentNode) t.parentNode.removeChild(t); }, 280); }, dur);
          return t;
        },
        /* Classify a status string into a state so colour/icon/motion match the message. */
        classify: function (s) {
          s = (s || '').toLowerCase();
          if (/cannot|can.?t |could ?n.?t|could not|fail|error|unable|unsupported|corrupt|invalid|too (large|big|many)|not supported|did ?n.?t|did not|denied|problem|wrong|no matches|nothing to/.test(s)) return 'err';
          if (/done|ready|copied|saved|success|complete|finished|downloaded|✓|✅|added|generated\b/.test(s)) return 'ok';
          if (/…|\.\.\.|please wait|loading|working|opening|building|rendering|processing|scanning|compress|preparing|generating|optimi|converting|reading|searching|merging|splitting|extracting/.test(s)) return 'work';
          return 'info';
        },
        /* Premium replacement for window.prompt(). Resolves the value or null on cancel. */
        ask: function (opts) {
          opts = opts || {};
          return new Promise(function (resolve) {
            var ov = document.createElement('div'); ov.className = 'sj-ask';
            ov.innerHTML = '<div class="sj-ask-card" role="dialog" aria-modal="true"><div class="sj-ask-t"></div>' +
              '<input class="sj-ask-in" type="' + (opts.type || 'text') + '"' + (opts.min != null ? ' min="' + opts.min + '"' : '') + (opts.max != null ? ' max="' + opts.max + '"' : '') + ' />' +
              '<div class="sj-ask-row"><button class="sj-ask-cancel" type="button">Cancel</button><button class="sj-ask-ok" type="button">' + (opts.ok || 'OK') + '</button></div></div>';
            ov.querySelector('.sj-ask-t').textContent = opts.title || '';
            var inp = ov.querySelector('.sj-ask-in'); inp.value = opts.value != null ? opts.value : '';
            if (opts.placeholder) inp.placeholder = opts.placeholder;
            function close(v) { ov.classList.add('out'); setTimeout(function () { if (ov.parentNode) ov.parentNode.removeChild(ov); }, 220); resolve(v); }
            ov.querySelector('.sj-ask-ok').onclick = function () { close(inp.value); };
            ov.querySelector('.sj-ask-cancel').onclick = function () { close(null); };
            ov.addEventListener('click', function (e) { if (e.target === ov) close(null); });
            inp.addEventListener('keydown', function (e) { if (e.key === 'Enter') close(inp.value); if (e.key === 'Escape') close(null); });
            (document.body || document.documentElement).appendChild(ov);
            requestAnimationFrame(function () { ov.classList.add('in'); inp.focus(); inp.select && inp.select(); });
          });
        },
        /* Auto-upgrade EVERY tool's status line: watch known status elements and, when
           their text changes, tag a state + replay the reveal — no per-tool code. */
        _initStatus: function () {
          var sel = '.status,.tmsg,[data-sj-status],[role=status]';
          function tag(el) {
            var txt = (el.textContent || '').trim();
            if (!txt) { el.removeAttribute('data-state'); el.classList.remove('sj-flash', 'sj-prog'); el.style.removeProperty('--sj-prog'); return; }
            el.setAttribute('data-state', K.classify(txt));
            if (/^[▼▲⚠✓✅❌•→➜]/.test(txt)) el.setAttribute('data-glyph', ''); else el.removeAttribute('data-glyph');
            // §7 auto progress bar: any "X of Y" / "X%" status grows a bar — no per-tool code
            var m = txt.match(/(\d+)\s*(?:of|\/)\s*(\d+)/) , pct = null;
            if (m && +m[2] > 0) pct = Math.min(100, Math.round(+m[1] / +m[2] * 100));
            else { var p = txt.match(/(\d{1,3})\s*%/); if (p) pct = Math.min(100, +p[1]); }
            if (pct != null && K.classify(txt) === 'work') { el.style.setProperty('--sj-prog', pct + '%'); el.classList.add('sj-prog'); }
            else { el.classList.remove('sj-prog'); el.style.removeProperty('--sj-prog'); }
            el.classList.remove('sj-flash'); void el.offsetWidth; el.classList.add('sj-flash');
          }
          function watch(el) {
            if (el._sjW) return; el._sjW = 1; tag(el);
            new MutationObserver(function () { tag(el); }).observe(el, { childList: true, characterData: true, subtree: true });
          }
          function scan() { try { document.querySelectorAll(sel).forEach(watch); } catch (e) {} }
          scan();
          // catch status elements added later (e.g. tool builds its own)
          try { new MutationObserver(scan).observe(document.body, { childList: true, subtree: true }); } catch (e) {}
        },
        /* Automatic success + heavy-file feedback for EVERY tool, no per-tool code:
           - any download (incl. programmatic a.click()) confirms "Saved to your device"
           - selecting a very large file warns it may take a few seconds (no UI freeze). */
        _saveToast: function () {
          var now = +new Date();
          if (K._lastSave && now - K._lastSave < 1200) return;   // dedupe (delegation + click patch)
          K._lastSave = now;
          K.toast('Saved to your device', 'ok');
        },
        _isNative: function () { try { return !!(window.Capacitor && window.Capacitor.isNativePlatform && window.Capacitor.isNativePlatform()); } catch (e) { return false; } },
        /* APP: take over a download → save to Documents/SnapJar (a known place) AND add
           it to My Files (Recent), so files are never "lost" and EVERY tool's output
           shows up in Recent. Returns the blob to the recents store with the right kind. */
        saveDownload: function (blob, name, opts) {
          opts = opts || {};
          name = (name || 'file').replace(/[\\/]/g, '_');
          var ext = (name.split('.').pop() || '').toLowerCase();
          var kind = ext === 'pdf' ? 'pdf' : (['png','jpg','jpeg','webp','gif','heic','heif','svg','ico','bmp'].indexOf(ext) >= 0 ? 'image' : 'file');
          // 1) add to My Files (Recent), capturing its id for the notification's tap-to-open
          function addRecent() {
            if (opts.skipRecent || !window.SJRecents) return Promise.resolve(null);
            if (kind === 'image') return K._imgThumb(blob).then(function (thumb) { return window.SJRecents.add({ name: name, kind: kind, blob: blob, thumb: thumb }); });
            return window.SJRecents.add({ name: name, kind: kind, blob: blob });
          }
          // 2) write to Documents/SnapJar and resolve its file uri
          function saveFile() {
            var Fs = K.plugin('Filesystem');
            if (!Fs || !Fs.writeFile) return Promise.resolve(null);
            return new Promise(function (resolve) {
              var r = new FileReader();
              r.onload = function () {
                var b64 = String(r.result).split(',')[1] || '';
                Fs.writeFile({ path: 'SnapJar/' + name, data: b64, directory: 'DOCUMENTS', recursive: true })
                  .then(function () { return (Fs.getUri ? Fs.getUri({ path: 'SnapJar/' + name, directory: 'DOCUMENTS' }).then(function (u) { return u && u.uri; }).catch(function () { return null; }) : null); })
                  .then(resolve).catch(function () { resolve(null); });
              };
              r.onerror = function () { resolve(null); };
              r.readAsDataURL(blob);
            });
          }
          return Promise.all([addRecent().catch(function () { return null; }), saveFile()]).then(function (out) {
            var recentId = out[0], uri = out[1];
            K.toast(uri ? 'Saved to Files › Documents › SnapJar — also in Recent' : 'Saved — find it in Recent', 'ok', 3800);
            if (!opts.skipRecent) {
              K._notifySaved(name, kind, recentId, uri);
              // show MORE ads at a natural success moment (throttled inside maybeInterstitial)
              if (K.maybeInterstitial) setTimeout(K.maybeInterstitial, 1400);
            }
            return { recentId: recentId, uri: uri };
          });
        },
        /* Fire a real OS notification for a saved file; tapping it opens the file in SnapJar. */
        _notifySaved: function (name, kind, recentId, uri) {
          var LN = K.plugin('LocalNotifications');
          if (!LN || !LN.schedule) return;
          K._ensureNotifPerm(LN).then(function (ok) {
            if (!ok) return;
            var id = (+new Date()) % 2000000000;
            LN.schedule({ notifications: [{
              id: id,
              title: 'Saved to SnapJar',
              body: name + ' — tap to open',
              smallIcon: 'ic_stat_snapjar',
              iconColor: '#5B5BD6',
              extra: { recentId: recentId || null, kind: kind, uri: uri || null, name: name }
            }] }).catch(function () {});
          });
        },
        _ensureNotifPerm: function (LN) {
          if (!LN.checkPermissions) return Promise.resolve(true);
          return LN.checkPermissions().then(function (p) {
            if (p && p.display === 'granted') return true;
            if (!LN.requestPermissions) return false;
            return LN.requestPermissions().then(function (r) { return !!(r && r.display === 'granted'); });
          }).catch(function () { return false; });
        },
        _initNotifTap: function () {
          var LN = K.plugin('LocalNotifications');
          if (!LN || !LN.addListener) return;
          try {
            LN.addListener('localNotificationActionPerformed', function (ev) {
              var ex = ev && ev.notification && ev.notification.extra; if (!ex) return;
              if (ex.kind === 'pdf' && ex.recentId) { location.href = '/tools/pdf-studio.html?recent=' + encodeURIComponent(ex.recentId); }
              else { location.href = '/recent.html'; }
            });
          } catch (e) {}
        },
        /* OPEN-WITH: another app sent SnapJar a PDF/image (tap a PDF in a file manager →
           pick SnapJar). MainActivity copied it to app storage; load + open it here. */
        _checkIncoming: function () {
          var IF = K.plugin('IncomingFile');
          if (!IF || !IF.getPending || K._incomingBusy) return;
          K._incomingBusy = true;
          IF.getPending().then(function (res) {
            K._incomingBusy = false;
            if (!res || res.none || !res.path) return;
            var src = (window.Capacitor && window.Capacitor.convertFileSrc) ? window.Capacitor.convertFileSrc(res.path) : res.path;
            var name = res.name || 'document.pdf';
            var isPdf = /pdf/i.test(res.mime || '') || /\.pdf$/i.test(name);
            K.toast('Opening ' + name + '…', 'work');
            fetch(src).then(function (r) { return r.blob(); }).then(function (blob) {
              if (!window.SJRecents) { K.toast('Could not open the file', 'warn'); return; }
              window.SJRecents.add({ name: name, kind: isPdf ? 'pdf' : 'file', blob: blob }).then(function (id) {
                if (!id) { K.toast('Could not open the file', 'warn'); return; }
                location.href = isPdf ? ('/tools/pdf-studio.html?recent=' + encodeURIComponent(id)) : '/recent.html';
              });
            }).catch(function () { K.toast('Could not open the file', 'warn'); });
          }).catch(function () { K._incomingBusy = false; });
        },
        _imgThumb: function (blob) {
          return new Promise(function (res) {
            try {
              var url = URL.createObjectURL(blob), img = new Image();
              img.onload = function () {
                try {
                  var S = 256, s = Math.min(S / img.width, S / img.height, 1), w = Math.max(1, img.width * s | 0), h = Math.max(1, img.height * s | 0);
                  var c = document.createElement('canvas'); c.width = w; c.height = h;
                  c.getContext('2d').drawImage(img, 0, 0, w, h);
                  URL.revokeObjectURL(url); res(c.toDataURL('image/jpeg', 0.7));
                } catch (e) { URL.revokeObjectURL(url); res(null); }
              };
              img.onerror = function () { URL.revokeObjectURL(url); res(null); };
              img.src = url;
            } catch (e) { res(null); }
          });
        },
        _grabDownload: function (a) {
          var href = (a.getAttribute && a.getAttribute('href')) || a.href || '';
          var name = (a.getAttribute && a.getAttribute('download')) || 'file';
          if (!/^blob:|^data:/.test(href)) return false;
          fetch(href).then(function (r) { return r.blob(); }).then(function (b) { K.saveDownload(b, name); }).catch(function () { K._saveToast(); });
          return true;
        },
        _initFeedback: function () {
          var native = K._isNative();
          // 1) real user clicks on in-DOM download links
          document.addEventListener('click', function (e) {
            var a = e.target && e.target.closest && e.target.closest('a[download],[data-sj-download]');
            if (!a || a._sjQuiet) return;
            if (native && /^blob:|^data:/.test((a.getAttribute('href') || a.href || ''))) { e.preventDefault(); K._grabDownload(a); }
            else setTimeout(K._saveToast, 60);
          }, true);
          // 2) programmatic downloads (jsPDF/pdf-lib/anchor.click()) — even detached anchors
          try {
            var proto = HTMLAnchorElement.prototype, orig = proto.click;
            proto.click = function () {
              try {
                if (this.hasAttribute && this.hasAttribute('download') && !this._sjQuiet) {
                  if (native && /^blob:|^data:/.test((this.getAttribute('href') || this.href || ''))) { if (K._grabDownload(this)) return; }
                  else setTimeout(K._saveToast, 60);
                }
              } catch (e) {}
              return orig.apply(this, arguments);
            };
          } catch (e) {}
          document.addEventListener('change', function (e) {
            var inp = e.target;
            if (!inp || inp.type !== 'file' || !inp.files || !inp.files.length) return;
            var big = 0, empty = 0, wrong = 0, n = inp.files.length, ex = K._acceptExts(inp.getAttribute('accept'));
